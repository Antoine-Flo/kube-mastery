{
  "name": "explain-command-suite",
  "clusterName": "conformance",
  "actions": [
    {
      "id": "platform-apply",
      "type": "applyYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/minimal"
    },
    {
      "id": "platform-cmd-1",
      "type": "command",
      "command": "kubectl explain pod"
    },
    {
      "id": "platform-cmd-2",
      "type": "command",
      "command": "kubectl explain pod.spec.containers"
    },
    {
      "id": "platform-cmd-3",
      "type": "command",
      "command": "kubectl explain deployment.spec.template.spec.containers"
    },
    {
      "id": "platform-cmd-4",
      "type": "command",
      "command": "kubectl explain service.spec.ports"
    },
    {
      "id": "platform-cmd-5",
      "type": "command",
      "command": "kubectl explain configmap.data"
    },
    {
      "id": "platform-cmd-6",
      "type": "command",
      "command": "kubectl explain secret.data"
    },
    {
      "id": "platform-cmd-7",
      "type": "command",
      "command": "kubectl explain namespace.metadata"
    },
    {
      "id": "platform-cmd-8",
      "type": "command",
      "command": "kubectl explain node.status"
    },
    {
      "id": "platform-cmd-9",
      "type": "command",
      "command": "kubectl explain replicaset.spec.replicas"
    },
    {
      "id": "platform-cmd-10",
      "type": "command",
      "command": "kubectl explain daemonset.spec.template"
    },
    {
      "id": "platform-cmd-11",
      "type": "command",
      "command": "kubectl explain persistentvolume.spec"
    },
    {
      "id": "platform-cmd-12",
      "type": "command",
      "command": "kubectl explain persistentvolumeclaim.spec"
    },
    {
      "id": "platform-cleanup",
      "type": "deleteYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/minimal",
      "ignoreNotFound": true
    },
    {
      "id": "errors-help-apply",
      "type": "applyYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/minimal"
    },
    {
      "id": "errors-help-cmd-1",
      "type": "command",
      "command": "kubectl explain pod.spec.notFound"
    },
    {
      "id": "errors-help-cmd-2",
      "type": "command",
      "command": "kubectl explain all"
    },
    {
      "id": "errors-help-cleanup",
      "type": "deleteYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/minimal",
      "ignoreNotFound": true
    }
  ]
}
