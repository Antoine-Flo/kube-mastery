{
  "name": "describe-command-suite",
  "clusterName": "conformance",
  "actions": [
    {
      "id": "minimal-apply",
      "type": "applyYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/minimal",
      "waitForPods": true
    },
    {
      "id": "minimal-cmd-1",
      "type": "command",
      "command": "kubectl describe pod kube-apiserver-conformance-control-plane -n kube-system",
      "compareMode": "normalized"
    },
    {
      "id": "minimal-cmd-2",
      "type": "command",
      "command": "kubectl describe node conformance-worker",
      "compareMode": "normalized"
    },
    {
      "id": "minimal-cmd-3",
      "type": "command",
      "command": "kubectl describe pv missing-pv",
      "compareMode": "normalized"
    },
    {
      "id": "minimal-cmd-4",
      "type": "command",
      "command": "kubectl describe pvc missing-pvc",
      "compareMode": "normalized"
    },
    {
      "id": "minimal-cleanup",
      "type": "deleteYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/minimal",
      "ignoreNotFound": true
    },
    {
      "id": "deploy-cm-apply",
      "type": "applyYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/deployment-with-configmap",
      "waitForPods": true
    },
    {
      "id": "deploy-cm-cmd-1",
      "type": "command",
      "command": "kubectl describe pod web",
      "compareMode": "normalized"
    },
    {
      "id": "deploy-cm-cmd-2",
      "type": "command",
      "command": "kubectl describe deployment exhaustive-web",
      "compareMode": "normalized"
    },
    {
      "id": "deploy-cm-cmd-3",
      "type": "command",
      "command": "kubectl describe svc web-svc",
      "compareMode": "none",
      "expectKind": {
        "exitCode": 0,
        "stdoutContains": [
          "Name:",
          "web-svc",
          "Selector:",
          "app=web"
        ]
      },
      "expectRunner": {
        "exitCode": 0,
        "stdoutContains": [
          "Name:",
          "web-svc",
          "Selector:",
          "app=web"
        ]
      }
    },
    {
      "id": "deploy-cm-cmd-4",
      "type": "command",
      "command": "kubectl describe svc web-svc",
      "compareMode": "none",
      "expectKind": {
        "exitCode": 1,
        "stderrContains": [
          "Error from server (NotFound): services \"web-svc\" not found"
        ]
      },
      "expectRunner": {
        "exitCode": 1,
        "stderrContains": [
          "Error from server (NotFound): services \"web-svc\" not found"
        ]
      }
    },
    {
      "id": "deploy-cm-cleanup",
      "type": "deleteYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/deployment-with-configmap",
      "ignoreNotFound": true
    },
    {
      "id": "platform-apply",
      "type": "applyYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/minimal"
    },
    {
      "id": "platform-cmd-1",
      "type": "command",
      "command": "kubectl describe node conformance-control-plane",
      "compareMode": "normalized"
    },
    {
      "id": "platform-cmd-2",
      "type": "command",
      "command": "kubectl describe node conformance-worker2",
      "compareMode": "normalized"
    },
    {
      "id": "platform-cleanup",
      "type": "deleteYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/minimal",
      "ignoreNotFound": true
    },
    {
      "id": "ingress-basics-apply",
