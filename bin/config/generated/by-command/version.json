{
  "name": "version-command-suite",
  "clusterName": "conformance",
  "actions": [
    {
      "id": "platform-apply",
      "type": "applyYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/minimal"
    },
    {
      "id": "platform-cmd-1",
      "type": "command",
      "command": "kubectl version",
      "compareMode": "normalized"
    },
    {
      "id": "platform-cmd-2",
      "type": "command",
      "command": "kubectl version --client",
      "compareMode": "normalized"
    },
    {
      "id": "platform-cmd-3",
      "type": "command",
      "command": "kubectl version --output json",
      "compareMode": "normalized"
    },
    {
      "id": "platform-cmd-4",
      "type": "command",
      "command": "kubectl version --output yaml",
      "compareMode": "normalized"
    },
    {
      "id": "platform-cleanup",
      "type": "deleteYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/minimal",
      "ignoreNotFound": true
    },
    {
      "id": "errors-help-apply",
      "type": "applyYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/minimal"
    },
    {
      "id": "errors-help-cmd-1",
      "type": "command",
      "command": "kubectl version --output wide",
      "compareMode": "normalized"
    },
    {
      "id": "errors-help-cleanup",
      "type": "deleteYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/minimal",
      "ignoreNotFound": true
    }
  ],
  "stopOnMismatch": false
}
