{
  "name": "api-resources-command-suite",
  "clusterName": "conformance",
  "actions": [
    {
      "id": "platform-apply",
      "type": "applyYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/minimal"
    },
    {
      "id": "platform-cmd-1",
      "type": "command",
      "command": "kubectl api-resources",
      "compareMode": "normalized"
    },
    {
      "id": "platform-cmd-2",
      "type": "command",
      "command": "kubectl api-resources --output wide",
      "compareMode": "normalized"
    },
    {
      "id": "platform-cmd-3",
      "type": "command",
      "command": "kubectl api-resources --output name",
      "compareMode": "normalized"
    },
    {
      "id": "platform-cmd-4",
      "type": "command",
      "command": "kubectl api-resources --output json",
      "compareMode": "normalized"
    },
    {
      "id": "platform-cmd-5",
      "type": "command",
      "command": "kubectl api-resources --output yaml",
      "compareMode": "normalized"
    },
    {
      "id": "platform-cmd-6",
      "type": "command",
      "command": "kubectl api-resources --namespaced=true",
      "compareMode": "normalized"
    },
    {
      "id": "platform-cmd-7",
      "type": "command",
      "command": "kubectl api-resources --namespaced=false",
      "compareMode": "normalized"
    },
    {
      "id": "platform-cmd-8",
      "type": "command",
      "command": "kubectl api-resources --sort-by=name",
      "compareMode": "normalized"
    },
    {
      "id": "platform-cmd-9",
      "type": "command",
      "command": "kubectl api-resources --sort-by=kind",
      "compareMode": "normalized"
    },
    {
      "id": "platform-cmd-10",
      "type": "command",
      "command": "kubectl api-resources --no-headers",
      "compareMode": "normalized"
    },
    {
      "id": "platform-cleanup",
      "type": "deleteYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/minimal",
      "ignoreNotFound": true
    },
    {
      "id": "errors-help-apply",
      "type": "applyYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/minimal"
    },
    {
      "id": "errors-help-cmd-1",
      "type": "command",
      "command": "kubectl api-resources --sort-by=age",
      "compareMode": "normalized"
    },
    {
      "id": "errors-help-cmd-2",
      "type": "command",
      "command": "kubectl api-resources --help",
      "compareMode": "normalized"
    },
    {
      "id": "errors-help-cleanup",
      "type": "deleteYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/minimal",
      "ignoreNotFound": true
    }
  ],
  "stopOnMismatch": false
}
