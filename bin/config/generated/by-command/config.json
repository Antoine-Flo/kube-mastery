{
  "name": "config-command-suite",
  "clusterName": "conformance",
  "actions": [
    {
      "id": "platform-apply",
      "type": "applyYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/minimal"
    },
    {
      "id": "platform-cmd-1",
      "type": "command",
      "command": "kubectl config get-contexts"
    },
    {
      "id": "platform-cmd-2",
      "type": "command",
      "command": "kubectl config current-context"
    },
    {
      "id": "platform-cmd-3",
      "type": "command",
      "command": "kubectl config view --minify"
    },
    {
      "id": "platform-cmd-4",
      "type": "command",
      "command": "kubectl config set-context --current --namespace=dev"
    },
    {
      "id": "platform-cleanup",
      "type": "deleteYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/minimal",
      "ignoreNotFound": true
    }
  ]
}
