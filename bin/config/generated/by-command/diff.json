{
  "name": "diff-command-suite",
  "clusterName": "conformance",
  "actions": [
    {
      "id": "deploy-cm-apply",
      "type": "applyYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/deployment-with-configmap",
      "waitForPods": true
    },
    {
      "id": "deploy-cm-cmd-1",
      "type": "command",
      "command": "kubectl diff -f src/courses/seeds/deployment-with-configmap/configmap.yaml"
    },
    {
      "id": "deploy-cm-cmd-2",
      "type": "command",
      "command": "kubectl diff -f src/courses/seeds/deployment-with-configmap/secret.yaml"
    },
    {
      "id": "deploy-cm-cmd-3",
      "type": "command",
      "command": "kubectl diff -f src/courses/seeds/diff-fixtures/configmap-changed.yaml"
    },
    {
      "id": "deploy-cm-cmd-4",
      "type": "command",
      "command": "kubectl diff -f src/courses/seeds/diff-fixtures/secret-changed.yaml"
    },
    {
      "id": "deploy-cm-cleanup",
      "type": "deleteYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/deployment-with-configmap",
      "ignoreNotFound": true
    }
  ]
}
