{
  "name": "scale-command-suite",
  "clusterName": "conformance",
  "actions": [
    {
      "id": "deploy-cm-apply",
      "type": "applyYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/deployment-with-configmap",
      "waitForPods": true
    },
    {
      "id": "deploy-cm-cmd-1",
      "type": "command",
      "command": "kubectl scale deployments exhaustive-web --replicas=3"
    },
    {
      "id": "deploy-cm-cleanup",
      "type": "deleteYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/deployment-with-configmap",
      "ignoreNotFound": true
    },
    {
      "id": "errors-help-apply",
      "type": "applyYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/minimal"
    },
    {
      "id": "errors-help-cmd-1",
      "type": "command",
      "command": "kubectl scale deployments missing-deploy --replicas=2"
    },
    {
      "id": "errors-help-cleanup",
      "type": "deleteYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/minimal",
      "ignoreNotFound": true
    }
  ]
}
