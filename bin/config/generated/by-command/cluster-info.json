{
  "name": "cluster-info-command-suite",
  "clusterName": "conformance",
  "actions": [
    {
      "id": "platform-apply",
      "type": "applyYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/minimal"
    },
    {
      "id": "platform-cmd-1",
      "type": "command",
      "command": "kubectl cluster-info"
    },
    {
      "id": "platform-cmd-2",
      "type": "command",
      "command": "kubectl cluster-info dump"
    },
    {
      "id": "platform-cmd-3",
      "type": "command",
      "command": "kubectl cluster-info dump -o yaml"
    },
    {
      "id": "platform-cmd-4",
      "type": "command",
      "command": "kubectl cluster-info dump --namespaces=default,kube-system"
    },
    {
      "id": "platform-cleanup",
      "type": "deleteYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/minimal",
      "ignoreNotFound": true
    },
    {
      "id": "errors-help-apply",
      "type": "applyYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/minimal"
    },
    {
      "id": "errors-help-cmd-1",
      "type": "command",
      "command": "kubectl cluster-info dump --output-directory /tmp/out"
    },
    {
      "id": "errors-help-cleanup",
      "type": "deleteYaml",
      "targetPath": "/home/af/code/kube-mastery/src/courses/seeds/minimal",
      "ignoreNotFound": true
    }
  ]
}
