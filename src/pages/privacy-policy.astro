---
import Layout from "../layouts/Layout.astro";
import * as m from "../paraglide/messages.js";

import "../styles/routes/privacy-policy.css";
---
<Layout>
	<div class="privacy-policy">
		<h1 class="privacy-policy__title">{m.privacyPolicy_title()}</h1>
		<p class="privacy-policy__last-updated">{m.privacyPolicy_lastUpdated()}</p>
		<p class="privacy-policy__intro">{m.privacyPolicy_intro()}</p>

		<section class="privacy-policy__section">
			<h2 class="privacy-policy__section-title">{m.privacyPolicy_collection_title()}</h2>
			<p class="privacy-policy__section-content">{m.privacyPolicy_collection_content()}</p>
		</section>

		<section class="privacy-policy__section">
			<h2 class="privacy-policy__section-title">{m.privacyPolicy_use_title()}</h2>
			<p class="privacy-policy__section-content">{m.privacyPolicy_use_content()}</p>
		</section>

		<section class="privacy-policy__section">
			<h2 class="privacy-policy__section-title">{m.privacyPolicy_security_title()}</h2>
			<p class="privacy-policy__section-content">{m.privacyPolicy_security_content()}</p>
		</section>

		<section class="privacy-policy__section">
			<h2 class="privacy-policy__section-title">{m.privacyPolicy_storage_title()}</h2>
			<p class="privacy-policy__section-content">{m.privacyPolicy_storage_content()}</p>
		</section>

		<section class="privacy-policy__section">
			<h2 class="privacy-policy__section-title">{m.privacyPolicy_sharing_title()}</h2>
			<p class="privacy-policy__section-content">{m.privacyPolicy_sharing_content()}</p>
		</section>

		<section class="privacy-policy__section">
			<h2 class="privacy-policy__section-title">{m.privacyPolicy_rights_title()}</h2>
			<p class="privacy-policy__section-content">{m.privacyPolicy_rights_content()}</p>
		</section>

		<section class="privacy-policy__section">
			<h2 class="privacy-policy__section-title">{m.privacyPolicy_retention_title()}</h2>
			<p class="privacy-policy__section-content">{m.privacyPolicy_retention_content()}</p>
		</section>

		<section class="privacy-policy__section">
			<h2 class="privacy-policy__section-title">{m.privacyPolicy_changes_title()}</h2>
			<p class="privacy-policy__section-content">{m.privacyPolicy_changes_content()}</p>
		</section>

		<section class="privacy-policy__section">
			<h2 class="privacy-policy__section-title">{m.privacyPolicy_contact_title()}</h2>
			<p class="privacy-policy__section-content">{m.privacyPolicy_contact_content()}</p>
		</section>
	</div>
</Layout>
