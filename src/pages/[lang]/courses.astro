---
import Layout from '../../layouts/Layout.astro'
import CourseCard from '../../components/CourseCard.astro'
import { useTranslations, useLocalePath } from '../../i18n/utils'
import { getCourses } from '../../content/courses/facade'
import { getLayoutAuthContext } from '../../lib/auth/server'
import '../../styles/components/page-halo.css'

const locale = Astro.params.lang as 'en' | 'fr'
const t = useTranslations(locale)
const localePath = useLocalePath(locale)

const courses = getCourses(locale)

const auth = await getLayoutAuthContext(
  Astro.locals,
  Astro.request,
  Astro.cookies
)
const emphasizePaidLearningPath = auth.hasPaidSubscription

type CourseVisualVariant = 'developer' | 'operator' | 'crash'

const visualVariantByCourseId: Partial<Record<string, CourseVisualVariant>> = {
  ckad: 'developer',
  cka: 'operator',
  'crash-course': 'crash'
}

const coursesListSeo = {
  title: `${t('courses_title')} | KubeMastery`,
  description: t('courses_subtitle'),
  canonical: new URL(localePath('/courses'), Astro.site ?? Astro.url).href,
  openGraphType: 'website' as const
}

const displayedCourseIds = ['crash-course', 'cka', 'ckad']
const courseById = new Map(courses.map((course) => [course.id, course]))
const displayedCourses = displayedCourseIds.flatMap((id) => {
  const course = courseById.get(id)
  return course ? [course] : []
})
---

<Layout seo={coursesListSeo}>
  <div class="page-halo">
    <div class="page-halo__bg" aria-hidden="true"></div>
    <main>
      <h1>{t('courses_title')}</h1>
      <p>{t('courses_subtitle')}</p>

      <section class="courses">
        {
          displayedCourses.map((course) => (
            <CourseCard
              title={course.title}
              description={course.shortDescription ?? course.description}
              totalLessons={course.totalLessons}
              href={localePath(`/courses/${course.id}`)}
              comingSoon={course.comingSoon}
              inProgress={course.inProgress}
              startHere={
                course.id === 'crash-course'
                  ? !emphasizePaidLearningPath
                  : emphasizePaidLearningPath && course.startHere
              }
              level={course.level}
              lessonsLabel={`${course.totalLessons} ${t('courses_lessons')}`}
              freeLabel={t('pricing_free')}
              comingSoonLabel={t('courses_comingSoon')}
              inProgressLabel={t('courses_inProgress')}
              startHereLabel={t('courses_startHere')}
              isFree={course.isFree}
              visualVariant={visualVariantByCourseId[course.id]}
            />
          ))
        }
      </section>

      <p class="modules-link">
        <a href={localePath('/modules')}>{t('courses_browseModules')}</a>
      </p>
    </main>
  </div>
</Layout>

<style>
  main {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 4rem 0;
  }

  main h1 {
    font-size: 1.875rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-12);
    text-align: center;
    margin-bottom: 0.2rem;
  }

  main > p {
    color: var(--color-gray-11);
    text-align: center;
    margin-bottom: 3rem;
    font-size: var(--text-lg);
  }

  .courses {
    display: flex;
    gap: 1.25rem;
    justify-content: center;
  }

  .courses > :global(*) {
    width: 320px;
    flex-shrink: 0;
  }

  .modules-link {
    text-align: center;
    margin-top: 3rem;
    color: var(--color-gray-9);
  }

  .modules-link a {
    font-size: var(--text-sm);
    color: var(--color-gray-9);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.15s ease;
  }

  .modules-link a:hover {
    color: var(--color-gray-11);
  }

  @media (max-width: 899px) {
    main {
      padding: 4rem 0.5rem;
    }

    .courses {
      flex-direction: column;
      align-items: stretch;
    }

    .courses > :global(*) {
      width: 100%;
    }
  }
</style>
