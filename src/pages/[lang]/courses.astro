---
import Layout from '../../layouts/Layout.astro'
import CourseCard from '../../components/CourseCard.astro'
import { useTranslations, useLocalePath } from '../../i18n/utils'
import { getCourses } from '../../content/courses/facade'
import '../../styles/components/page-halo.css'

const locale = Astro.params.lang as 'en' | 'fr'
const t = useTranslations(locale)
const localePath = useLocalePath(locale)

const courses = getCourses(locale)

type CourseVisualVariant =
  | 'fundamentals'
  | 'developer'
  | 'operator'
  | 'platform'
  | 'full'

const visualVariantByCourseId: Partial<Record<string, CourseVisualVariant>> = {
  'common-core': 'fundamentals',
  ckad: 'developer',
  cka: 'operator',
  kcna: 'platform',
  'kcna-to-ckad-delta': 'developer',
  'ckad-to-cka-delta': 'full'
}
---

<Layout>
  <div class="page-halo">
    <div class="page-halo__bg" aria-hidden="true"></div>
    <main>
      <h1>{t('courses_title')}</h1>
      <p>{t('courses_subtitle')}</p>

      <div class="grid">
        {
          courses.map((course) => {
            const visualVariant = visualVariantByCourseId[course.id]
            return (
              <CourseCard
                title={course.title}
                description={course.shortDescription ?? course.description}
                totalLessons={course.totalLessons}
                href={localePath(`/courses/${course.id}`)}
                comingSoon={course.comingSoon}
                inProgress={course.inProgress}
                level={course.level}
                lessonsLabel={`${course.totalLessons} ${t('courses_lessons')}`}
                comingSoonLabel={t('courses_comingSoon')}
                inProgressLabel={t('courses_inProgress')}
                visualVariant={visualVariant}
              />
            )
          })
        }
      </div>

      <p class="modules-link">
        <a href={localePath('/modules')}>{t('courses_browseModules')}</a>
      </p>
    </main>
  </div>
</Layout>

<style>
  main {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 4rem 2rem;
  }
  main h1,
  main h2 {
    font-size: 1.875rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-12);
    text-align: left;
    margin-bottom: 0.2rem;
  }
  main > p {
    color: var(--color-gray-11);
    text-align: left;
    margin-bottom: 3rem;
    font-size: var(--text-lg);
  }
  main .section {
    margin-top: 4rem;
  }
  main .section p {
    text-align: center;
    margin-bottom: 2rem;
    color: var(--color-gray-11);
    font-size: var(--text-lg);
  }

  main .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    main .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .modules-link {
    text-align: center;
    margin-top: 3rem;
    color: var(--color-gray-9);
  }

  .modules-link a {
    font-size: var(--text-sm);
    color: var(--color-gray-9);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.15s ease;
  }

  .modules-link a:hover {
    color: var(--color-gray-11);
  }
</style>
