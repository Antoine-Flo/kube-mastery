---
import Layout from '../../layouts/Layout.astro'
import CourseCard from '../../components/CourseCard.astro'
import { useTranslations, useLocalePath } from '../../i18n/utils'
import { getCourses, getModules } from '../../content/courses/facade'
import { getTaskGroups } from '../../content/tasks/facade'

const locale = Astro.params.lang as 'en' | 'fr'
const t = useTranslations(locale)
const localePath = useLocalePath(locale)

const courses = getCourses(locale)
const modules = getModules(locale)
const taskGroups = getTaskGroups(locale)
---

<Layout>
  <main>
    <h1>{t('courses_title')}</h1>
    <p>{t('courses_subtitle')}</p>

    <div class="grid">
      {
        courses.map((course) => (
          <CourseCard
            title={course.title}
            description={course.shortDescription ?? course.description}
            totalLessons={course.totalLessons}
            href={localePath(`/courses/${course.id}`)}
            isFree={course.isFree}
            comingSoon={course.comingSoon}
            level={course.level}
            lessonsLabel={`${course.totalLessons} ${t('courses_lessons')}`}
            freeBadgeLabel={t('courses_freeBadge')}
            comingSoonLabel={t('courses_comingSoon')}
          />
        ))
      }
    </div>

    <div class="section">
      <h2>{t('tasks_title')}</h2>
      <p>{t('tasks_subtitle')}</p>

      <div class="grid">
        {
          taskGroups.map((group) => (
            <CourseCard
              title={group.title}
              description={group.description}
              totalLessons={group.totalTasks}
              href={localePath(`/tasks/${group.id}`)}
              lessonsLabel={
                group.totalTasks === 1
                  ? `1 ${t('tasks_task')}`
                  : `${group.totalTasks} ${t('tasks_tasks')}`
              }
              comingSoonLabel={t('courses_comingSoon')}
            />
          ))
        }
      </div>
    </div>

    <div class="section">
      <h2>{t('modules_title')}</h2>
      <p>{t('modules_subtitle')}</p>

      <div class="grid">
        {
          modules.map((mod) => (
            <CourseCard
              title={mod.title}
              description={mod.description}
              totalLessons={mod.totalLessons}
              href={localePath(`/modules/${mod.id}`)}
              lessonsLabel={`${mod.totalLessons} ${t('courses_lessons')}`}
              comingSoonLabel={t('courses_comingSoon')}
            />
          ))
        }
      </div>
    </div>
  </main>
</Layout>

<style>
  main {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 4rem 2rem;
  }
  main h1,
  main h2 {
    font-size: 1.875rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-12);
    text-align: center;
    margin-bottom: 0.2rem;
  }
  main > p {
    color: var(--color-gray-11);
    text-align: center;
    margin-bottom: 3rem;
    font-size: var(--text-lg);
  }
  main .section {
    margin-top: 4rem;
  }
  main .section p {
    text-align: center;
    margin-bottom: 2rem;
    color: var(--color-gray-11);
    font-size: var(--text-lg);
  }

  main .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    main .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
