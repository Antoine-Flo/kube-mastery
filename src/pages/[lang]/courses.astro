---
import Layout from "../../layouts/Layout.astro";
import CourseCard from "../../components/CourseCard.astro";
import { useTranslations, useLocalePath } from "../../i18n/utils";
import { getCourses, getModules } from "../../content/courses/facade";
import {
  getCourseOverview,
  getModuleOverview,
} from "../../content/overview/facade";
import { getProgressContext } from "../../lib/progress/server";
import { computeProgressMap } from "../../lib/progress/domain";

const locale = Astro.params.lang as "en" | "fr";
const t = useTranslations(locale);
const localePath = useLocalePath(locale);

const { completed } = await getProgressContext(
  Astro.locals,
  Astro.request,
  Astro.cookies,
);

const courses = getCourses(locale);
const modules = getModules(locale);

const coursesWithLessonIds = courses.map((course) => {
  const overview = getCourseOverview(course.id, locale);
  const lessonIds = overview
    ? overview.content.chapters.flatMap((ch) => ch.lessons.map((l) => l.id))
    : [];
  return { id: course.id, lessonIds };
});
const modulesWithLessonIds = modules.map((mod) => {
  const overview = getModuleOverview(mod.id, locale);
  const lessonIds = overview
    ? overview.content.chapters.flatMap((ch) => ch.lessons.map((l) => l.id))
    : [];
  return { id: mod.id, lessonIds };
});

const courseProgressMap = computeProgressMap(coursesWithLessonIds, completed);
const moduleProgressMap = computeProgressMap(modulesWithLessonIds, completed);

const courseCards = courses.map((course) => {
  const entry = coursesWithLessonIds.find((e) => e.id === course.id);
  const progress = courseProgressMap.get(course.id);
  const lessonIds = entry?.lessonIds ?? [];
  const targetLessonId = progress?.currentLessonId ?? lessonIds[0];
  const ctaLabel = progress?.hasStarted
    ? t("courses_resume")
    : t("courses_startNow");
  const ctaHref =
    !course.comingSoon && targetLessonId
      ? localePath(`/courses/${course.id}/${targetLessonId}`)
      : undefined;
  return { course, ctaLabel, ctaHref };
});

const moduleCards = modules.map((mod) => {
  const entry = modulesWithLessonIds.find((e) => e.id === mod.id);
  const progress = moduleProgressMap.get(mod.id);
  const lessonIds = entry?.lessonIds ?? [];
  const targetLessonId = progress?.currentLessonId ?? lessonIds[0];
  const ctaLabel = progress?.hasStarted
    ? t("courses_resume")
    : t("courses_startNow");
  const ctaHref = targetLessonId
    ? localePath(`/modules/${mod.id}/${targetLessonId}`)
    : undefined;
  return { mod, ctaLabel, ctaHref };
});
---

<Layout>
  <main>
    <h1>{t("courses_title")}</h1>
    <p>{t("courses_subtitle")}</p>

    {
      courses.length === 0 ? (
        <div class="empty">{t("coursesList_noCoursesYet")}</div>
      ) : (
        <div class="grid">
          {courseCards.map(({ course, ctaLabel, ctaHref }) => (
            <CourseCard
              title={course.title}
              description={course.shortDescription ?? course.description}
              totalLessons={course.totalLessons}
              href={localePath(`/courses/${course.id}`)}
              isFree={course.isFree}
              comingSoon={course.comingSoon}
              level={course.level}
              lessonsLabel={`${course.totalLessons} ${t("courses_lessons")}`}
              freeBadgeLabel={t("courses_freeBadge")}
              comingSoonLabel={t("courses_comingSoon")}
              ctaLabel={ctaLabel}
              ctaHref={ctaHref}
            />
          ))}
        </div>
      )
    }

    <div class="section">
      <h2>{t("modules_title")}</h2>
      <p>{t("modules_subtitle")}</p>

      {
        modules.length === 0 ? (
          <div class="empty">{t("modulesList_noModulesYet")}</div>
        ) : (
          <div class="grid">
            {moduleCards.map(({ mod, ctaLabel, ctaHref }) => (
              <CourseCard
                title={mod.title}
                description={mod.description}
                totalLessons={mod.totalLessons}
                href={localePath(`/modules/${mod.id}`)}
                lessonsLabel={`${mod.totalLessons} ${t("courses_lessons")}`}
                ctaLabel={ctaLabel}
                ctaHref={ctaHref}
              />
            ))}
          </div>
        )
      }
    </div>
  </main>
</Layout>

<style>
  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }
  main h1,
  main h2 {
    font-size: 1.875rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-12);
    text-align: center;
    margin-bottom: 0.2rem;
  }
  main > p {
    color: var(--color-gray-11);
    text-align: center;
    margin-bottom: 3rem;
    font-size: var(--text-lg);
  }
  main .section {
    margin-top: 4rem;
  }
  main .section p {
    text-align: center;
    margin-bottom: 2rem;
    color: var(--color-gray-11);
    font-size: var(--text-lg);
  }
  main .empty {
    padding: 4rem;
    text-align: center;
    color: var(--color-gray-11);
  }
  main .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    main .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
