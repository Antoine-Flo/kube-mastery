---
import Layout from '../../layouts/Layout.astro'
import Dialog from '../../components/ui/Dialog.astro'
import { useLocalePath, useTranslations } from '../../i18n/utils'
import '../../styles/components/page-halo.css'
import { getDrills, type DrillTagId } from '../../content/drills/facade'
import { Bug, HardDrive, Layers, Network, Timer } from '@lucide/astro'

const DRILL_TAG_ICON = {
  storage: HardDrive,
  troubleshooting: Bug,
  services_networking: Network,
  cluster_architecture_installation: Layers
} as const satisfies Record<DrillTagId, typeof HardDrive>

const lang = Astro.params.lang as 'en' | 'fr'
const t = useTranslations(lang)
const localePath = useLocalePath(lang)

const drills = getDrills(lang)

const DRILL_TAG_UI_KEY: Record<
  DrillTagId,
  | 'drills_tag_storage'
  | 'drills_tag_troubleshooting'
  | 'drills_tag_services_networking'
  | 'drills_tag_cluster_architecture_installation'
> = {
  storage: 'drills_tag_storage',
  troubleshooting: 'drills_tag_troubleshooting',
  services_networking: 'drills_tag_services_networking',
  cluster_architecture_installation: 'drills_tag_cluster_architecture_installation'
}
---

<Layout>
  <div class="page-halo">
    <div class="page-halo__bg" aria-hidden="true"></div>
    <main>
      <h1>{t('nav_drills')}</h1>
      <p>{t('drills_subtitle')}</p>

      <ul class="drill-grid">
        {
          drills.map((drill) => {
            const CategoryIcon = drill.tag ? DRILL_TAG_ICON[drill.tag] : null
            return (
              <li>
                <button
                  type="button"
                  class="drill-card"
                  data-drill-id={drill.id}
                  data-drill-title={drill.title}
                  data-drill-base-href={localePath(`/drills/${drill.id}`)}
                >
                  {drill.tag && CategoryIcon && (
                    <div class="drill-card__top">
                      <span class="drill-card__tag">
                        {t(DRILL_TAG_UI_KEY[drill.tag])}
                      </span>
                      <span
                        class={`drill-card__category-icon drill-card__category-icon--${drill.tag}`}
                      >
                        <CategoryIcon size={14} stroke-width={1.65} aria-hidden="true" />
                      </span>
                    </div>
                  )}

                  <div class="drill-card__body">
                    <span class="drill-card__title">{drill.title}</span>
                    {drill.description && (
                      <span class="drill-card__description">
                        {drill.description}
                      </span>
                    )}
                  </div>

                  <div class="drill-card__footer">
                    <span class="drill-card__meta">
                      <Timer size={12} aria-hidden="true" />
                      {drill.totalTasks} {drill.totalTasks === 1 ? t('drills_step') : t('drills_steps')}
                    </span>
                    <span
                      class="drill-card__best"
                      data-drill-best-for={drill.id}
                      hidden
                    >
                    </span>
                  </div>
                </button>
              </li>
            )
          })
        }
      </ul>
    </main>
  </div>

  <Dialog id="drill-mode-dialog" title="" size="md">
    <div class="mode-cards">
      <a href="" id="drill-mode-guided" class="mode-card">
        <strong>{t('drills_mode_guidedCta')}</strong>
        <p>{t('drills_mode_subGuided')}</p>
      </a>
      <a href="" id="drill-mode-exam" class="mode-card">
        <strong>{t('drills_mode_examCta')}</strong>
        <p>{t('drills_mode_subExam')}</p>
      </a>
    </div>
  </Dialog>
</Layout>

<script>
  function initDrillModalTriggers() {
    const dialog = document.getElementById('drill-mode-dialog') as HTMLDialogElement | null
    const titleEl = document.getElementById('drill-mode-dialog-title')
    const guidedLink = document.getElementById('drill-mode-guided') as HTMLAnchorElement | null
    const examLink = document.getElementById('drill-mode-exam') as HTMLAnchorElement | null

    document.querySelectorAll<HTMLButtonElement>('[data-drill-id]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const baseHref = btn.dataset.drillBaseHref ?? ''
        if (titleEl) {
          titleEl.textContent = btn.dataset.drillTitle ?? ''
        }
        if (guidedLink) {
          guidedLink.href = `${baseHref}?mode=guided`
        }
        if (examLink) {
          examLink.href = `${baseHref}?mode=exam`
        }
        dialog?.showModal()
      })
    })
  }

  initDrillModalTriggers()
  document.addEventListener('astro:page-load', initDrillModalTriggers)
</script>

<script is:inline define:vars={{ bestLabel: t('drills_list_bestTime') }}>
  function formatSec(sec) {
    const m = Math.floor(sec / 60)
    const s = sec % 60
    return `${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`
  }

  function showBestTimes() {
    document.querySelectorAll('[data-drill-best-for]').forEach((el) => {
      if (!(el instanceof HTMLElement)) {
        return
      }
      const id = el.dataset.drillBestFor
      if (!id) {
        return
      }
      const raw = localStorage.getItem(`drillBestSeconds:${id}`)
      if (!raw) {
        return
      }
      const sec = Number(raw)
      if (!Number.isFinite(sec) || sec < 0) {
        return
      }
      el.textContent = `${bestLabel}: ${formatSec(sec)}`
      el.removeAttribute('hidden')
    })
  }

  showBestTimes()
  document.addEventListener('astro:page-load', showBestTimes)
</script>

<style>
  main {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 4rem 0;
  }

  main h1,
  main h2 {
    font-size: 1.875rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-12);
    text-align: center;
    margin-bottom: 0.2rem;
  }

  main > p {
    color: var(--color-gray-11);
    text-align: center;
    margin-bottom: 3rem;
    font-size: var(--text-lg);
  }

  .drill-grid {
    list-style: none;
    display: grid;
    max-width: 1000px;
    margin: 0 auto;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  @media (max-width: 520px) {
    .drill-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 1024px) {
    .drill-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .drill-grid li {
    margin: 0;
  }

  .drill-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1rem 1.125rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-gray-6);
    background: var(--color-gray-1);
    color: inherit;
    text-align: left;
    cursor: pointer;
    font: inherit;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    transition:
      border-color 0.15s,
      background 0.15s;
    width: 100%;
    height: 100%;
    box-sizing: border-box;
  }

  .drill-card:hover {
    border-color: var(--color-cyan-7);
    background: var(--color-cyan-2);
  }

  .drill-card:active {
    background: var(--color-gray-2);
  }

  :global([data-theme='dark']) .drill-card:active {
    background: var(--color-gray-3);
  }

  .drill-card:hover:active {
    background: var(--color-cyan-1);
  }

  :global([data-theme='dark']) .drill-card:hover:active {
    background: var(--color-cyan-4);
  }

  .drill-card__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .drill-card__tag {
    flex: 1;
    min-width: 0;
    font-size: var(--text-xs);
    font-weight: var(--font-weight-normal);
    color: var(--color-gray-9);
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .drill-card__category-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    line-height: 0;
    opacity: 0.7;
  }

  .drill-card__category-icon :global(svg) {
    display: block;
  }

  .drill-card__category-icon--storage :global(svg) {
    color: var(--color-green-10);
  }

  .drill-card__category-icon--troubleshooting :global(svg) {
    color: var(--color-ruby-10);
  }

  .drill-card__category-icon--services_networking :global(svg) {
    color: var(--color-cyan-10);
  }

  .drill-card__category-icon--cluster_architecture_installation :global(svg) {
    color: var(--color-amber-10);
  }

  .drill-card__best {
    flex-shrink: 0;
    font-size: var(--text-xs);
    color: var(--color-gray-9);
    font-variant-numeric: tabular-nums;
    text-align: right;
  }

  .drill-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    flex: 1;
  }

  .drill-card__title {
    font-weight: var(--font-weight-semibold);
    font-size: var(--text-base);
    color: var(--color-gray-12);
    line-height: 1.3;
  }

  .drill-card__description {
    font-size: var(--text-sm);
    color: var(--color-gray-10);
    line-height: 1.45;
  }

  .drill-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding-top: 0.375rem;
    border-top: 1px solid var(--color-gray-4);
  }

  .drill-card__meta {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: var(--text-xs);
    color: var(--color-gray-9);
    min-width: 0;
  }

  .drill-card__meta :global(svg) {
    flex-shrink: 0;
  }

  .mode-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .mode-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem 1.125rem;
    border: 1px solid var(--color-gray-6);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.15s,
      background 0.15s;
  }

  .mode-card:hover {
    border-color: var(--color-cyan-7);
    background: var(--color-cyan-2);
  }

  .mode-card strong {
    font-size: var(--text-base);
    font-weight: var(--font-weight-semibold);
    color: var(--color-gray-12);
  }

  .mode-card p {
    font-size: var(--text-sm);
    color: var(--color-gray-10);
    margin: 0;
    line-height: 1.45;
  }

  @media (max-width: 899px) {
    main {
      padding: 4rem 0.5rem;
    }
  }
</style>
