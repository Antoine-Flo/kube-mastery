---
import Layout from '../../layouts/Layout.astro'
import Dialog from '../../components/ui/Dialog.astro'
import { useLocalePath, useTranslations } from '../../i18n/utils'
import '../../styles/components/page-halo.css'
import {
  getDrills,
  type DrillListItem,
  type DrillTagId
} from '../../content/drills/facade'
import { getLayoutAuthContext } from '../../lib/auth/server'
import { Bug, HardDrive, Layers, Network, Timer } from '@lucide/astro'

const DRILL_TAG_ICON = {
  storage: HardDrive,
  troubleshooting: Bug,
  services_networking: Network,
  cluster_architecture_installation: Layers
} as const satisfies Record<DrillTagId, typeof HardDrive>

const lang = Astro.params.lang as 'en' | 'fr'
const t = useTranslations(lang)
const localePath = useLocalePath(lang)

function compareDrillListOrder(a: DrillListItem, b: DrillListItem): number {
  const rank = (d: DrillListItem) => {
    if (d.comingSoon) {
      return 2
    }
    if (d.isFree) {
      return 0
    }
    return 1
  }
  const diff = rank(a) - rank(b)
  if (diff !== 0) {
    return diff
  }
  return a.id.localeCompare(b.id)
}

const drills = [...getDrills(lang)].sort(compareDrillListOrder)
const auth = await getLayoutAuthContext(
  Astro.locals,
  Astro.request,
  Astro.cookies
)
const firstFreeDrill = drills.find((d) => d.isFree && !d.comingSoon)
const tryFreeDrillHref = firstFreeDrill
  ? `${localePath(`/drills/${firstFreeDrill.id}`)}?mode=guided`
  : localePath('/drills')
const pricingHref = localePath('/pricing')

const DRILL_TAG_UI_KEY: Record<
  DrillTagId,
  | 'drills_tag_storage'
  | 'drills_tag_troubleshooting'
  | 'drills_tag_services_networking'
  | 'drills_tag_cluster_architecture_installation'
> = {
  storage: 'drills_tag_storage',
  troubleshooting: 'drills_tag_troubleshooting',
  services_networking: 'drills_tag_services_networking',
  cluster_architecture_installation:
    'drills_tag_cluster_architecture_installation'
}
---

<Layout>
  <div class="page-halo">
    <div class="page-halo__bg" aria-hidden="true"></div>
    <main>
      <h1>{t('nav_drills')}</h1>
      <p>{t('drills_subtitle')}</p>

      <ul class="drill-grid">
        {
          drills.map((drill) => {
            const CategoryIcon = drill.tag
              ? DRILL_TAG_ICON[drill.tag]
              : null
            const showTopRow =
              drill.comingSoon ||
              drill.tag ||
              (drill.isFree && !auth.hasPaidSubscription)
            return (
              <li>
                <button
                  type="button"
                  class:list={{
                    'drill-card': true,
                    'drill-card--coming-soon': drill.comingSoon
                  }}
                  disabled={drill.comingSoon}
                  data-drill-id={drill.id}
                  data-drill-title={drill.title}
                  data-drill-base-href={localePath(`/drills/${drill.id}`)}
                  data-drill-can-access={
                    drill.comingSoon
                      ? 'false'
                      : drill.isFree || auth.hasPaidSubscription
                        ? 'true'
                        : 'false'
                  }
                >
                  {showTopRow && (
                    <div class="drill-card__top">
                      <div class="drill-card__top-left">
                        {drill.comingSoon ? (
                          <span class="drill-card__tag">
                            {t('drills_badge_comingSoon')}
                          </span>
                        ) : (
                          drill.tag && (
                            <span class="drill-card__tag">
                              {t(DRILL_TAG_UI_KEY[drill.tag])}
                            </span>
                          )
                        )}
                      </div>
                      <div class="drill-card__top-right">
                        {drill.isFree && !auth.hasPaidSubscription && (
                          <span class="drill-card__free-badge">
                            {t('drills_badge_free')}
                          </span>
                        )}
                        {CategoryIcon && drill.tag && (
                          <span
                            class={`drill-card__category-icon drill-card__category-icon--${drill.tag}`}
                          >
                            <CategoryIcon
                              size={14}
                              stroke-width={1.65}
                              aria-hidden="true"
                            />
                          </span>
                        )}
                      </div>
                    </div>
                  )}

                  <div class="drill-card__body">
                    <span class="drill-card__title">{drill.title}</span>
                    {drill.description && (
                      <span class="drill-card__description">
                        {drill.description}
                      </span>
                    )}
                  </div>

                  <div class="drill-card__footer">
                    <span class="drill-card__meta">
                      <Timer size={12} aria-hidden="true" />
                      {drill.totalTasks}{' '}
                      {drill.totalTasks === 1
                        ? t('drills_step')
                        : t('drills_steps')}
                    </span>
                  </div>
                </button>
              </li>
            )
          })
        }
      </ul>
    </main>
  </div>

  <Dialog
    id="drill-pro-required-dialog"
    title={t('drills_proOnly_title')}
    description={t('drills_proOnly_body')}
    size="md"
  >
    <div slot="footer" class="dialog__footer drill-pro-dialog__footer">
      <a
        href={tryFreeDrillHref}
        class="drill-pro-dialog__cta drill-pro-dialog__cta--secondary"
      >
        {t('drills_proOnly_tryFree')}
      </a>
      <a
        href={pricingHref}
        class="drill-pro-dialog__cta drill-pro-dialog__cta--primary"
      >
        {t('drills_proOnly_viewPlans')}
      </a>
    </div>
  </Dialog>
</Layout>

<script>
  function initDrillCardTriggers() {
    const proDialog = document.getElementById(
      'drill-pro-required-dialog'
    ) as HTMLDialogElement | null

    document
      .querySelectorAll<HTMLButtonElement>('[data-drill-id]')
      .forEach((btn) => {
        btn.addEventListener('click', () => {
          if (btn.disabled) {
            return
          }
          const baseHref = btn.dataset.drillBaseHref ?? ''
          const canAccess = btn.dataset.drillCanAccess === 'true'
          if (!canAccess) {
            proDialog?.showModal()
            return
          }
          window.location.href = `${baseHref}?mode=guided`
        })
      })
  }

  initDrillCardTriggers()
  document.addEventListener('astro:page-load', initDrillCardTriggers)
</script>

<style>
  main {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 4rem 0;
  }

  main h1,
  main h2 {
    font-size: 1.875rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-12);
    text-align: center;
    margin-bottom: 0.2rem;
  }

  main > p {
    color: var(--color-gray-11);
    text-align: center;
    margin-bottom: 3rem;
    font-size: var(--text-lg);
  }

  .drill-grid {
    list-style: none;
    display: grid;
    max-width: 1000px;
    margin: 0 auto;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  @media (max-width: 520px) {
    .drill-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 1024px) {
    .drill-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .drill-grid li {
    margin: 0;
  }

  .drill-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1rem 1.125rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-gray-6);
    background: var(--color-gray-1);
    text-align: left;
    cursor: pointer;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    transition:
      border-color 0.15s,
      background 0.15s;
    width: 100%;
    height: 100%;
    box-sizing: border-box;
  }

  .drill-card:not(:disabled):hover {
    border-color: var(--color-cyan-7);
    background: var(--color-cyan-2);
  }

  .drill-card:not(:disabled):active {
    background: var(--color-gray-2);
  }

  :global([data-theme='dark']) .drill-card:not(:disabled):active {
    background: var(--color-gray-3);
  }

  .drill-card:not(:disabled):hover:active {
    background: var(--color-cyan-1);
  }

  :global([data-theme='dark']) .drill-card:not(:disabled):hover:active {
    background: var(--color-cyan-4);
  }

  .drill-card--coming-soon,
  .drill-card--coming-soon:hover,
  .drill-card--coming-soon:hover:active {
    opacity: 0.72;
    cursor: not-allowed;
    border-color: var(--color-gray-6);
    background: var(--color-gray-2);
  }

  :global([data-theme='dark']) .drill-card--coming-soon,
  :global([data-theme='dark']) .drill-card--coming-soon:hover,
  :global([data-theme='dark']) .drill-card--coming-soon:hover:active {
    background: var(--color-gray-3);
  }

  .drill-card__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .drill-card__top-left {
    flex: 1;
    min-width: 0;
  }

  .drill-card__top-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .drill-card__free-badge {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--color-cyan-11);
    background: var(--color-cyan-3);
    border: 1px solid var(--color-cyan-6);
    border-radius: var(--radius-sm);
    padding: 0.1rem 0.4rem;
    line-height: 1.3;
  }

  .drill-card__tag {
    flex: 1;
    min-width: 0;
    font-size: var(--text-xs);
    font-weight: var(--font-weight-normal);
    color: var(--color-gray-9);
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .drill-card__category-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    line-height: 0;
    opacity: 0.7;
  }

  .drill-card__category-icon :global(svg) {
    display: block;
  }

  .drill-card__category-icon--storage :global(svg) {
    color: var(--color-green-10);
  }

  .drill-card__category-icon--troubleshooting :global(svg) {
    color: var(--color-ruby-10);
  }

  .drill-card__category-icon--services_networking :global(svg) {
    color: var(--color-cyan-10);
  }

  .drill-card__category-icon--cluster_architecture_installation :global(svg) {
    color: var(--color-amber-10);
  }

  .drill-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    flex: 1;
  }

  .drill-card__title {
    font-weight: var(--font-weight-semibold);
    font-size: var(--text-base);
    color: var(--color-gray-12);
    line-height: 1.3;
  }

  .drill-card__description {
    font-size: var(--text-sm);
    color: var(--color-gray-10);
    line-height: 1.45;
  }

  .drill-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding-top: 0.375rem;
    border-top: 1px solid var(--color-gray-4);
  }

  .drill-card__meta {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: var(--text-xs);
    color: var(--color-gray-9);
    min-width: 0;
  }

  .drill-card__meta :global(svg) {
    flex-shrink: 0;
  }

  .drill-pro-dialog__footer {
    width: 100%;
    flex-wrap: nowrap;
    justify-content: flex-end;
    gap: 0.625rem;
  }

  .drill-pro-dialog__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0.5rem 0.9rem;
    border-radius: var(--radius-sm);
    font-weight: var(--font-weight-semibold);
    font-size: var(--text-sm);
    text-decoration: none;
    white-space: nowrap;
    flex: 0 1 auto;
    min-width: 0;
    transition:
      border-color 0.15s,
      background 0.15s,
      color 0.15s;
  }

  .drill-pro-dialog__cta--primary {
    border: 1px solid var(--color-cyan-7);
    background: var(--color-cyan-9);
    color: var(--color-gray-1);
  }

  .drill-pro-dialog__cta--primary:hover {
    background: var(--color-cyan-10);
  }

  .drill-pro-dialog__cta--secondary {
    border: 1px solid var(--color-gray-6);
    background: var(--color-gray-1);
    color: var(--color-gray-12);
  }

  .drill-pro-dialog__cta--secondary:hover {
    border-color: var(--color-cyan-7);
    background: var(--color-cyan-2);
  }

  @media (max-width: 380px) {
    .drill-pro-dialog__footer {
      flex-wrap: wrap;
    }

    .drill-pro-dialog__cta {
      flex: 1 1 calc(50% - 0.35rem);
      white-space: normal;
    }
  }

  @media (max-width: 899px) {
    main {
      padding: 4rem 0.5rem;
    }
  }
</style>
