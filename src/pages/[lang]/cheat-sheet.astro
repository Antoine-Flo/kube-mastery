---
import Layout from '../../layouts/Layout.astro'
import ContentWithTerminalLayout from '../../components/lesson/ContentWithTerminalLayout.astro'
import '../../styles/components/lesson-content.css'
import '../../styles/components/cluster-visualization.css'
import QuickRefContent from '../../courses/cheat-sheets/kubectl-quick-ref.md'

const lang = Astro.params.lang as 'en' | 'fr'
---

<Layout bodyClass="lp-fill navbar-app cheat-sheet-page" showFooter={false}>
  <ContentWithTerminalLayout
    seedName="minimal"
    lang={lang}
    showSidebar={false}
    terminalInteractive={true}
  >
    <article class="lesson-content cheat-sheet-content">
      <QuickRefContent />
    </article>
  </ContentWithTerminalLayout>
</Layout>

<style is:global>
  body.cheat-sheet-page .lesson-layout__main {
    max-width: none;
  }

  body.cheat-sheet-page .cheat-sheet-content {
    max-width: none;
  }
</style>
