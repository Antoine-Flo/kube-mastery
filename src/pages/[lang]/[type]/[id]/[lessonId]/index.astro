---
import Layout from '../../../../../layouts/Layout.astro'
import CourseOutline from '../../../../../components/CourseOutline.astro'
import ContentWithTerminalLayout from '../../../../../components/lesson/ContentWithTerminalLayout.astro'
import LessonNav from '../../../../../components/lesson/LessonNav.astro'
import { useLocalePath } from '../../../../../i18n/utils'
import {
  getCourseOverview,
  getModuleOverview,
  getLessonContent,
  type LessonFrontmatter,
  type OverviewType
} from '../../../../../content/overview/facade'
import { getLayoutAuthContext } from '../../../../../lib/auth/server'
import { getProgressContext } from '../../../../../lib/progress/server'
import { getCourseMarkdown } from '../../../../../content/courses/facade'
import { isLessonTerminalInteractive } from '../../../../../lib/lesson/lessonTerminalAccess'
import {
  buildLessonNavigationState,
  buildLessonSeo,
  buildTerminalLockSecondaryHref,
  getModuleCourseContext
} from '../../../../../lib/lesson/lessonPageContext'
import '../../../../../styles/components/lesson-content.css'
import '../../../../../styles/components/cluster-visualization.css'

const lang = Astro.params.lang as 'en' | 'fr'
const type = Astro.params.type as OverviewType
const id = Astro.params.id!
const lessonId = Astro.params.lessonId!
const localePath = useLocalePath(lang)
const pricingHref = localePath('/pricing')

const lessonEntry = getLessonContent(type, id, lessonId, lang)
if (!lessonEntry) {
  return Astro.redirect(localePath(`/${type}/${id}`))
}

const overview = (
  type === 'courses' ? getCourseOverview(id, lang) : getModuleOverview(id, lang)
)!
const { completed, userId } = await getProgressContext(
  Astro.locals,
  Astro.request,
  Astro.cookies
)
const auth = await getLayoutAuthContext(
  Astro.locals,
  Astro.request,
  Astro.cookies
)
const moduleCourseFallbackContext = {
  moduleIsInFreeCourse: false,
  canonicalCourseIdForModule: null
}
const moduleCourseContext =
  type === 'modules'
    ? getModuleCourseContext(lang, id)
    : moduleCourseFallbackContext
const courseIsFree =
  type === 'courses' && getCourseMarkdown(id, lang)?.frontmatter.isFree === true
const moduleIsInFreeCourse = moduleCourseContext.moduleIsInFreeCourse
const learnableIsFree = courseIsFree || moduleIsInFreeCourse
const hasUserSession = userId != null && userId !== ''
const terminalInteractive = isLessonTerminalInteractive({
  overviewType: type,
  hasUserSession,
  learnableIsFree,
  hasPaidSubscription: auth.hasPaidSubscription
})
const terminalLockSecondaryHref = buildTerminalLockSecondaryHref(lang, localePath)

const allLessons = overview.content.sections.flatMap((s) =>
  s.modules.flatMap((m) => m.lessons)
)
const navigation = buildLessonNavigationState({
  allLessons,
  currentLessonId: lessonId,
  overviewType: type,
  learnableId: id,
  localePath
})
const currentLessonTitle = navigation.currentLessonTitle ?? overview.title
const lessonBaseUrl = localePath(`/${type}/${id}`)
const { Content } = lessonEntry

const lessonFrontmatter = (lessonEntry.frontmatter ?? {}) as LessonFrontmatter
const lessonSeo = buildLessonSeo({
  lessonFrontmatter,
  currentLessonTitle,
  defaultDescription: overview.shortDescription ?? overview.description ?? undefined,
  overviewType: type,
  learnableId: id,
  currentLessonId: lessonId,
  canonicalCourseIdForModule: moduleCourseContext.canonicalCourseIdForModule,
  localePath,
  origin: Astro.url.origin
})
---

<Layout bodyClass="lp-fill navbar-app" showFooter={false} seo={lessonSeo}>
  <ContentWithTerminalLayout
    seedName="minimal"
    lang={lang}
    showSidebar
    supportContextId={lessonId}
    terminalInteractive={terminalInteractive}
    terminalLockPrimaryHref={pricingHref}
    terminalLockSecondaryHref={terminalLockSecondaryHref}
  >
    <div slot="sidebar">
      <CourseOutline
        overview={overview}
        currentLessonId={lessonId}
        lessonBaseUrl={lessonBaseUrl}
        completedLessonIds={completed}
      />
    </div>
    <article class="lesson-content" data-lesson-tour="lesson-main">
      <Content />
    </article>
    <LessonNav
      lang={lang}
      prevHref={navigation.prevHref}
      nextHref={navigation.nextHref}
      isFirst={navigation.isFirst}
      isLast={navigation.isLast}
      lessonId={lessonId}
    />
  </ContentWithTerminalLayout>
  <script>
    import {
      bootLessonLayoutTour,
      destroyLessonLayoutTourIfActive
    } from '../../../../../lib/lesson/lessonLayoutTour'

    const startLessonTour = () => {
      bootLessonLayoutTour()
    }

    document.addEventListener('astro:page-load', startLessonTour)
    startLessonTour()

    document.addEventListener('astro:before-swap', () => {
      destroyLessonLayoutTourIfActive()
    })
  </script>
</Layout>
