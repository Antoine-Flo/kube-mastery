---
import Layout from '../../../../../layouts/Layout.astro'
import CourseOutline from '../../../../../components/CourseOutline.astro'
import ContentWithTerminalLayout from '../../../../../components/lesson/ContentWithTerminalLayout.astro'
import LessonQuizNav from '../../../../../components/lesson/LessonQuizNav.astro'
import { useLocalePath, useTranslations } from '../../../../../i18n/utils'
import {
  getCourseOverview,
  getModuleOverview,
  getLessonContent,
  getLessonQuiz,
  type LessonFrontmatter,
  type OverviewType
} from '../../../../../content/overview/facade'
import { getLayoutAuthContext } from '../../../../../lib/auth/server'
import { getProgressContext } from '../../../../../lib/progress/server'
import {
  getCourseMarkdown,
  getCourses,
  getCourseStructure
} from '../../../../../content/courses/facade'
import {
  getFirstNonPlaceholderLessonIdFromSections,
  isLessonTerminalInteractive
} from '../../../../../lib/courses/lessonTerminalAccess'
import '../../../../../styles/components/lesson-content.css'
import '../../../../../styles/components/cluster-visualization.css'

const lang = Astro.params.lang as 'en' | 'fr'
const type = Astro.params.type as OverviewType
const id = Astro.params.id!
const lessonId = Astro.params.lessonId!
const localePath = useLocalePath(lang)
const t = useTranslations(lang)

const lessonEntry = getLessonContent(type, id, lessonId, lang)
if (!lessonEntry) {
  return Astro.redirect(localePath(`/${type}/${id}`))
}

const overview = (
  type === 'courses' ? getCourseOverview(id, lang) : getModuleOverview(id, lang)
)!
const { completed, userId } = await getProgressContext(
  Astro.locals,
  Astro.request,
  Astro.cookies
)
const auth = await getLayoutAuthContext(
  Astro.locals,
  Astro.request,
  Astro.cookies
)
const courseMarkdown = type === 'courses' ? getCourseMarkdown(id, lang) : null
const courseIsFree = courseMarkdown?.frontmatter.isFree === true
const moduleIsInFreeCourse =
  type === 'modules'
    ? getCourses(lang).some((course) => {
        if (!course.isFree) {
          return false
        }
        const structure = getCourseStructure(course.id)
        if (!structure) {
          return false
        }
        return structure.sections.some((section) =>
          section.moduleIds.includes(id)
        )
      })
    : false
const learnableIsFree = courseIsFree || moduleIsInFreeCourse
const terminalInteractive = isLessonTerminalInteractive({
  overviewType: type,
  hasUserSession: userId != null && userId !== '',
  learnableIsFree,
  hasPaidSubscription: auth.hasPaidSubscription
})

const crashOverview = getCourseOverview('crash-course', lang)
const crashFirstLessonId = crashOverview
  ? getFirstNonPlaceholderLessonIdFromSections(crashOverview.content.sections)
  : null
const terminalLockTryFreeHref = crashFirstLessonId
  ? localePath(`/courses/crash-course/${crashFirstLessonId}`)
  : localePath('/courses')
const hasSession = userId != null && userId !== ''
const terminalLockSecondaryHref = hasSession
  ? localePath('/pricing')
  : `${localePath('/auth')}?redirect=${encodeURIComponent(Astro.url.pathname)}`
const terminalLockSecondaryLabel = hasSession
  ? t('lesson_terminalLock_ctaPricing')
  : t('lesson_terminalLock_ctaSignIn')

const allLessons = overview.content.sections.flatMap((s) =>
  s.modules.flatMap((m) => m.lessons)
)
const currentIndex = allLessons.findIndex((l) => l.id === lessonId)
const currentLesson = currentIndex >= 0 ? allLessons[currentIndex] : null
const currentLessonTitle = currentLesson?.title ?? overview.title
const prevLesson = currentIndex > 0 ? allLessons[currentIndex - 1] : null
const nextLesson =
  currentIndex < allLessons.length - 1 ? allLessons[currentIndex + 1] : null
const lessonBaseUrl = localePath(`/${type}/${id}`)
const { Content } = lessonEntry

const seedName = 'minimal'
const quiz = getLessonQuiz(type, id, lessonId, lang)
const prevLessonHref = prevLesson
  ? localePath(`/${type}/${id}/${prevLesson.id}`)
  : ''
const nextLessonHref = nextLesson
  ? localePath(`/${type}/${id}/${nextLesson.id}`)
  : localePath(`/${type}/${id}/complete`)
const isFirstLesson = currentIndex === 0
const isLastLesson = currentIndex >= allLessons.length - 1

const quizNavLabels = {
  quizTitle: t('quiz_title'),
  questionInfo: t('quiz_questionInfo'),
  hint: t('quiz_hint'),
  previous: t('courseLesson_previousLesson'),
  nextLesson: t('courseLesson_nextLesson'),
  courseComplete: t('courseLesson_courseComplete'),
  nextQuestion: t('courseLesson_nextQuestion')
}

const contentBarLabels = {
  labelVisualizer: t('lesson_visualizer'),
  labelCourse: t('lesson_viewCourse'),
  labelShowTerminal: t('lesson_showTerminal'),
  labelHideTerminal: t('lesson_hideTerminal'),
  labelContactSupport: t('lesson_contactSupport'),
  labelReloadTerminal: t('lesson_reloadTerminal')
}

function getOptionalString(value: unknown): string | undefined {
  if (typeof value !== 'string') {
    return undefined
  }
  const trimmed = value.trim()
  if (trimmed.length === 0) {
    return undefined
  }
  return trimmed
}

const lessonFrontmatter = (lessonEntry.frontmatter ?? {}) as LessonFrontmatter
const frontmatterSeoTitle = getOptionalString(lessonFrontmatter.seoTitle)
const frontmatterSeoDescription = getOptionalString(
  lessonFrontmatter.seoDescription
)
const frontmatterOpenGraphImage = getOptionalString(lessonFrontmatter.ogImage)
const frontmatterTwitterImage = getOptionalString(lessonFrontmatter.twitterImage)
const fallbackDescription =
  lang === 'fr'
    ? `Lecon ${currentLessonTitle} dans ${overview.title} sur KubeMastery, avec explications et pratique kubectl.`
    : `Learn ${currentLessonTitle} in ${overview.title} on KubeMastery with practical kubectl-focused guidance.`
const lessonSeoTitle =
  frontmatterSeoTitle ?? `${currentLessonTitle} | ${overview.title} | KubeMastery`
const lessonSeoDescription =
  frontmatterSeoDescription ??
  overview.shortDescription ??
  overview.description ??
  fallbackDescription
const canonicalCourseIdForModule =
  type === 'modules'
    ? getCourses(lang).find((course) => {
        const structure = getCourseStructure(course.id)
        if (!structure) {
          return false
        }
        return structure.sections.some((section) => {
          return section.moduleIds.includes(id)
        })
      })?.id
    : null
const canonicalLessonPath =
  type === 'modules' && canonicalCourseIdForModule
    ? localePath(`/courses/${canonicalCourseIdForModule}/${lessonId}`)
    : localePath(`/${type}/${id}/${lessonId}`)
const canonicalLessonUrl = new URL(canonicalLessonPath, Astro.url.origin).href
const lessonSeo = {
  title: lessonSeoTitle,
  description: lessonSeoDescription,
  canonical: canonicalLessonUrl,
  openGraphType: 'article',
  openGraphImage: frontmatterOpenGraphImage,
  twitterImage: frontmatterTwitterImage
}
---

<Layout bodyClass="lp-fill navbar-app" showFooter={false} seo={lessonSeo}>
  <ContentWithTerminalLayout
    seedName={seedName}
    lang={lang}
    showSidebar={true}
    labels={contentBarLabels}
    supportContextId={lessonId}
    terminalInteractive={terminalInteractive}
    terminalLockTitle={t('lesson_terminalLock_title')}
    terminalLockBody={t('lesson_terminalLock_body')}
    terminalLockTryFreeLabel={t('lesson_terminalLock_tryFree')}
    terminalLockTryFreeHref={terminalLockTryFreeHref}
    terminalLockSecondaryLabel={terminalLockSecondaryLabel}
    terminalLockSecondaryHref={terminalLockSecondaryHref}
  >
    <div slot="sidebar">
      <CourseOutline
        overview={overview}
        currentLessonId={lessonId}
        lessonBaseUrl={lessonBaseUrl}
        completedLessonIds={completed}
      />
    </div>
    <article class="lesson-content">
      <Content />
    </article>
    <LessonQuizNav
      quiz={quiz}
      prevHref={prevLessonHref}
      nextHref={nextLessonHref}
      isFirst={isFirstLesson}
      isLast={isLastLesson}
      labels={quizNavLabels}
      lessonId={lessonId}
    />
  </ContentWithTerminalLayout>
</Layout>
