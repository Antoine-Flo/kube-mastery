---
import Layout from '../../../../layouts/Layout.astro'
import OverviewLayout from '../../../../components/overview/OverviewLayout.astro'
import OverviewHeader from '../../../../components/overview/OverviewHeader.astro'
import OverviewStructure from '../../../../components/overview/OverviewStructure.astro'
import { useTranslations, useLocalePath } from '../../../../i18n/utils'
import {
  getCourseOverview,
  getModuleOverview
} from '../../../../content/overview/facade'
import { getLayoutAuthContext } from '../../../../lib/auth/server'
import { getProgressContext } from '../../../../lib/progress/server'
import { computeProgress } from '../../../../lib/progress/domain'
import { isOpenLearningEnabled } from '../../../../lib/env'

const TYPE_COURSES = 'courses'
const TYPE_MODULES = 'modules'
type OverviewType = typeof TYPE_COURSES | typeof TYPE_MODULES

const lang = Astro.params.lang as 'en' | 'fr'
const type = Astro.params.type as OverviewType
const id = Astro.params.id!
const t = useTranslations(lang)
const localePath = useLocalePath(lang)

const overview =
  type === TYPE_COURSES
    ? getCourseOverview(id, lang)
    : getModuleOverview(id, lang)
if (!overview) {
  return Astro.redirect(localePath('/courses'))
}

const { completed, userId } = await getProgressContext(
  Astro.locals,
  Astro.request,
  Astro.cookies
)
const auth = await getLayoutAuthContext(
  Astro.locals,
  Astro.request,
  Astro.cookies
)
const isLoggedIn = !!userId
const hasPaidSubscription = auth.hasPaidSubscription
const openLearning = isOpenLearningEnabled(Astro.locals)

const lessonIds = overview.content.sections.flatMap((s) =>
  s.modules.flatMap((m) =>
    m.lessons
      .filter((lesson) => !lesson.isPlaceholder)
      .map((lesson) => lesson.id)
  )
)
const progress = computeProgress(lessonIds, completed)
const targetLessonId = progress.currentLessonId ?? lessonIds[0]
const firstLessonUrl = targetLessonId
  ? localePath(`/${type}/${id}/${targetLessonId}`)
  : null

let ctaHref: string
let ctaLabel: string
const canStartCourse =
  openLearning || (isLoggedIn && hasPaidSubscription)
if (!canStartCourse) {
  ctaLabel = t('home_cta_join')
  ctaHref = localePath('/pricing')
} else {
  ctaHref = firstLessonUrl ?? '#'
  ctaLabel = progress.hasStarted
    ? t('courses_resume')
    : t('courseOverview_startCourse')
}

const lessonBaseUrl = localePath(`/${type}/${id}`)
const breadcrumbHref = localePath(`/${type}`)
const breadcrumbRootLabel = type
---

<Layout>
  <OverviewLayout>
    <div class="ol">
      <OverviewHeader
        overview={overview}
        t={t}
        ctaHref={ctaHref}
        ctaLabel={ctaLabel}
        breadcrumbHref={breadcrumbHref}
        breadcrumbRootLabel={breadcrumbRootLabel}
      />
    </div>
    <div class="or">
      <OverviewStructure
        sections={overview.content.sections}
        lessonBaseUrl={lessonBaseUrl}
        t={t}
        completedLessonIds={completed}
        currentLessonId={progress.currentLessonId}
      />
    </div>
  </OverviewLayout>
</Layout>

<style>
  .ol {
    flex: 1;
    min-width: 0;
  }
  .or {
    flex: 1;
    min-width: 0;
  }
  @media (min-width: 1024px) {
    .or {
      flex: 0 0 450px;
    }
  }
</style>
