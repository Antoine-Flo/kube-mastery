---
import Layout from '../../layouts/Layout.astro'
import { useTranslations, useLocalePath } from '../../i18n/utils'
import { CONFIG } from '../../config'
import { readAppEnv } from '../../lib/env'
import { getLayoutAuthContext } from '../../lib/auth/server'
import Button from '../../components/ui/Button.astro'
import Dialog from '../../components/ui/Dialog.astro'
import guaranteeBadge from '../../assets/guarantee-badge.svg'
import '../../styles/components/card.css'
import '../../styles/components/accordion.css'
import '../../styles/components/guarantee.css'
import '../../styles/components/page-halo.css'
import '../../styles/routes/pricing.css'

const lang = Astro.params.lang as 'en' | 'fr'
const t = useTranslations(lang)
const localePath = useLocalePath(lang)
const auth = await getLayoutAuthContext(Astro.locals, Astro.request, Astro.cookies)
const loggedInCustomerEmail = auth.user?.email?.trim() ?? ''
const loggedInCustomerUserId = auth.user?.id?.trim() ?? ''

const environment = (readAppEnv('ENVIRONMENT', Astro.locals) ?? '')
  .toLowerCase()
  .trim()
const isProduction = environment === 'production'
const paddleClientToken = isProduction
  ? (readAppEnv('PADDLE_CLIENT_TOKEN', Astro.locals) ?? '')
  : (readAppEnv('PADDLE_CLIENT_TOKEN_STAGING', Astro.locals) ?? '')

if (paddleClientToken === '') {
  throw new Error(
    'Missing Paddle client token. Set PADDLE_CLIENT_TOKEN[_STAGING].'
  )
}

const paddleEnvironment = isProduction ? 'production' : 'sandbox'

const activePaddlePriceIds = isProduction
  ? CONFIG.billing.paddlePriceIds.production
  : CONFIG.billing.paddlePriceIds.staging
const BASIC_MONTHLY_PRICE_ID = activePaddlePriceIds.BASIC_MONTHLY
const BASIC_YEARLY_PRICE_ID = activePaddlePriceIds.BASIC_YEARLY
const PRO_MONTHLY_PRICE_ID = activePaddlePriceIds.PRO_MONTHLY
const PRO_YEARLY_PRICE_ID = activePaddlePriceIds.PRO_YEARLY

const basicDetailYearlyText = t('pricing_detail_yearly', {
  total: '--'
})
const basicDetailMonthlyText = t('pricing_detail_monthly')

const detailYearlyText = t('pricing_detail_yearly', {
  total: '--'
})
const detailMonthlyText = t('pricing_detail_monthly')
const CHECKOUT_EMAIL_DIALOG_ID = 'pricing-checkout-email-dialog'
const checkoutDialogTitle =
  lang === 'fr' ? 'Continuer vers le paiement' : 'Continue to checkout'
const checkoutDialogDescription =
  lang === 'fr'
    ? 'Renseigne ton email pour ouvrir la page de paiement.'
    : 'Enter your email to open the checkout page.'
const checkoutEmailLabel = lang === 'fr' ? 'Adresse email' : 'Email address'
const checkoutEmailPlaceholder =
  lang === 'fr' ? 'vous@exemple.com' : 'you@example.com'
const checkoutCancelLabel = lang === 'fr' ? 'Annuler' : 'Cancel'
const checkoutContinueLabel =
  lang === 'fr' ? 'Continuer au paiement' : 'Continue to checkout'
const checkoutInvalidEmailError =
  lang === 'fr'
    ? 'Merci de saisir une adresse email valide.'
    : 'Please enter a valid email address.'
const checkoutSuccessPath = localePath('/checkout/success')

const faqItems = [
  { id: 'q1', q: t('pricing_faq_q1'), a: t('pricing_faq_a1') },
  { id: 'q2', q: t('pricing_faq_q2'), a: t('pricing_faq_a2') },
  { id: 'q3', q: t('pricing_faq_q3'), a: t('pricing_faq_a3') },
  { id: 'q4', q: t('pricing_faq_q4'), a: t('pricing_faq_a4') },
  { id: 'q5', q: t('pricing_faq_q5'), a: t('pricing_faq_a5') },
  { id: 'q6', q: t('pricing_faq_q6'), a: t('pricing_faq_a6') },
  { id: 'q7', q: t('pricing_faq_q7'), a: t('pricing_faq_a7') }
]
---

<Layout>
  <div class="page-halo">
    <div class="page-halo__bg" aria-hidden="true"></div>
    <div class="pricing">
      <h2 class="pricing__title">{t('pricing_title')}</h2>

      <div class="pricing__toggle" role="group" aria-label="Billing period">
        <span
          class="pricing__toggle-option"
          id="pricing-option-monthly"
          aria-pressed="false"
        >
          {t('pricing_toggle_monthly')}
        </span>
        <button
          type="button"
          class="pricing__toggle-switch"
          id="pricing-billing-toggle"
          aria-pressed="true"
          aria-label="Toggle yearly billing"
          title={t('pricing_toggle_yearly')}
        >
        </button>
        <span class="pricing__toggle-yearly-wrap">
          <span
            class="pricing__toggle-option"
            id="pricing-option-yearly"
            aria-pressed="true"
          >
            {t('pricing_toggle_yearly')}
          </span>
          <span class="pricing__toggle-yearly-badge"
            >{t('pricing_toggle_yearly_badge')}</span
          >
        </span>
      </div>

      <div class="pricing__promo-wrap" role="status" aria-live="polite">
        <span class="pricing__promo-banner-text">
          {t('pricing_pro_badge')}
        </span>
      </div>

      <div class="pricing__plans">
        <!-- Basic plan -->
        <article
          class="card card--outline pricing__plan-card"
          data-billing="monthly"
        >
          <div class="card__header">
            <h2 class="card__title pricing__plan-title">
              {t('pricing_basic_name')}
            </h2>
            <div class="pricing__plan-price">
              <div
                class="pricing__plan-price-banner"
                data-detail-yearly={basicDetailYearlyText}
                data-detail-yearly-template={basicDetailYearlyText}
                data-detail-monthly={basicDetailMonthlyText}
                data-price-id-month={BASIC_MONTHLY_PRICE_ID}
                data-price-id-year={BASIC_YEARLY_PRICE_ID}
              >
                <div class="pricing__plan-price-current">
                  <span class="pricing__plan-price-struck"> </span>
                  <span class="pricing__plan-price-amount"> -- </span>
                  <span class="pricing__plan-price-period">
                    {t('pricing_per_month')}
                  </span>
                </div>
                <div class="pricing__plan-price-detail-wrap">
                  <span class="pricing__plan-price-detail">
                    {basicDetailYearlyText}
                  </span>
                </div>
              </div>
            </div>
          </div>
          <div class="card__body">
            <ul class="pricing__plan-features">
              <li class="pricing__plan-feature">
                <span class="pricing__plan-feature-check">✓</span>
                {t('pricing_basic_feature1')}
              </li>
              <li class="pricing__plan-feature">
                <span class="pricing__plan-feature-check">✓</span>
                {t('pricing_basic_feature2')}
              </li>
              <li class="pricing__plan-feature pricing__plan-feature--excluded">
                <span class="pricing__plan-feature-x" aria-hidden="true">—</span
                >
                {t('pricing_basic_feature3')}
              </li>
            </ul>
          </div>
          <div class="card__footer pricing__plan-footer">
            <Button
              href={localePath('/courses')}
              variant="outline"
              size="lg"
              class="pricing__plan-button"
            >
              {t('pricing_basic_cta')}
            </Button>
          </div>
        </article>

        <!-- KubeMastery Pro plan -->
        <article
          class="card card--outline pricing__plan-card pricing__plan-card--highlighted"
          data-billing="monthly"
        >
          <div class="card__header">
            <h2 class="card__title pricing__plan-title">
              {t('pricing_pro_name')}
            </h2>
            <div class="pricing__plan-price">
              <div
                class="pricing__plan-price-banner"
                data-detail-yearly={detailYearlyText}
                data-detail-yearly-template={detailYearlyText}
                data-detail-monthly={detailMonthlyText}
                data-price-id-month={PRO_MONTHLY_PRICE_ID}
                data-price-id-year={PRO_YEARLY_PRICE_ID}
              >
                <div class="pricing__plan-price-current">
                  <span class="pricing__plan-price-struck"> </span>
                  <span class="pricing__plan-price-amount"> -- </span>
                  <span class="pricing__plan-price-period">
                    {t('pricing_per_month')}
                  </span>
                </div>
                <div class="pricing__plan-price-detail-wrap">
                  <span class="pricing__plan-price-detail">
                    {detailYearlyText}
                  </span>
                </div>
              </div>
            </div>
          </div>
          <div class="card__body">
            <ul class="pricing__plan-features">
              <li class="pricing__plan-feature">
                <span class="pricing__plan-feature-check">✓</span>
                {t('pricing_pro_feature1')}
              </li>
              <li class="pricing__plan-feature">
                <span class="pricing__plan-feature-check">✓</span>
                {t('pricing_pro_feature2')}
              </li>
              <li class="pricing__plan-feature">
                <span class="pricing__plan-feature-check">✓</span>
                {t('pricing_pro_feature4')}
              </li>
            </ul>
          </div>
          <div class="card__footer pricing__plan-footer">
            <Button
              type="button"
              variant="solid"
              size="lg"
              color="cyan"
              class="pricing__plan-button"
              data-open-checkout="pro"
            >
              {t('pricing_pro_cta')}
            </Button>
          </div>
        </article>

        <!-- Business (coming soon) -->
        <article
          class="card card--outline pricing__plan-card pricing__plan-card--coming-soon"
        >
          <div class="card__header">
            <div class="pricing__badge">
              <span class="pricing__badge-text pricing__badge-text--cyan">
                {t('pricing_business_comingSoon')}
              </span>
            </div>
            <h2 class="card__title pricing__plan-title">
              {t('pricing_business_name')}
            </h2>
            <div class="pricing__plan-header-spacer" aria-hidden="true"></div>
          </div>
          <div class="card__body">
            <ul class="pricing__plan-features">
              <li class="pricing__plan-feature">
                <span class="pricing__plan-feature-check">✓</span>
                {t('pricing_business_feature1')}
              </li>
              <li class="pricing__plan-feature">
                <span class="pricing__plan-feature-check">✓</span>
                {t('pricing_business_feature2')}
              </li>
            </ul>
          </div>
          <div class="card__footer pricing__plan-footer">
            <Button
              variant="outline"
              size="lg"
              disabled
              class="pricing__plan-button"
            >
              {t('pricing_business_comingSoon')}
            </Button>
          </div>
        </article>
      </div>

      <div class="guarantee">
        <div class="content">
          <div class="guarantee-row">
            <div class="guarantee-badge">
              <img
                src={guaranteeBadge.src}
                alt={t('home_guarantee_image_alt')}
                loading="lazy"
              />
            </div>
            <div class="guarantee-text">
              <h2>{t('home_guarantee_title')}</h2>
              <p>{t('home_guarantee_subtitle')}</p>
              <ul class="guarantee-bullets">
                <li>{t('home_guarantee_point1')}</li>
                <li>{t('home_guarantee_point2')}</li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <section class="pricing__stats">
        <h2 class="pricing__stats-title">{t('home_stats_title')}</h2>
        <p class="pricing__stats-subtitle">{t('home_stats_subtitle')}</p>
        <div class="pricing__stats-grid">
          <div class="pricing__stats-card">
            <div class="pricing__stats-val">
              {t('home_stats_adoption_value')}
            </div>
            <h3>{t('home_stats_adoption_label')}</h3>
            <p>{t('home_stats_adoption_description')}</p>
            <p class="pricing__stats-src">{t('home_stats_adoption_source')}</p>
          </div>
          <div class="pricing__stats-card">
            <div class="pricing__stats-val">{t('home_stats_market_value')}</div>
            <h3>{t('home_stats_market_label')}</h3>
            <p>{t('home_stats_market_description')}</p>
            <p class="pricing__stats-src">{t('home_stats_market_source')}</p>
          </div>
          <div class="pricing__stats-card">
            <div class="pricing__stats-val">
              {t('home_stats_companies_value')}
            </div>
            <h3>{t('home_stats_companies_label')}</h3>
            <p>{t('home_stats_companies_description')}</p>
            <p class="pricing__stats-src">{t('home_stats_companies_source')}</p>
          </div>
        </div>
      </section>

      <section class="pricing__faq-section">
        <h2 class="pricing__faq-title">{t('pricing_faq_title')}</h2>
        <div class="pricing__faq-container">
          <div class="accordion accordion--size-md pricing__faq-accordion">
            {
              faqItems.map((faq) => (
                <details
                  class="accordion__item accordion__item--variant-outline"
                  id={faq.id}
                >
                  <summary class="accordion__item-trigger">
                    <span class="pricing__faq-question">{faq.q}</span>
                    <span class="accordion__item-indicator" aria-hidden="true">
                      ▼
                    </span>
                  </summary>
                  <div class="accordion__item-content">
                    <div class="accordion__item-body">
                      <p class="pricing__faq-answer">{faq.a}</p>
                    </div>
                  </div>
                </details>
              ))
            }
          </div>
        </div>
      </section>
      <Dialog
        id={CHECKOUT_EMAIL_DIALOG_ID}
        title={checkoutDialogTitle}
        description={checkoutDialogDescription}
        size="sm"
      >
        <form id="pricing-checkout-email-form" class="pricing-checkout-form">
          <label
            class="pricing-checkout-form__label"
            for="pricing-checkout-email"
          >
            {checkoutEmailLabel}
          </label>
          <input
            id="pricing-checkout-email"
            name="email"
            type="email"
            class="pricing-checkout-form__input"
            placeholder={checkoutEmailPlaceholder}
            autocomplete="email"
            required
          />
          <p
            id="pricing-checkout-email-error"
            class="pricing-checkout-form__error"
            aria-live="polite"
            hidden
          >
          </p>
          <footer class="dialog__footer pricing-checkout-form__footer">
            <Button
              type="button"
              variant="subtle"
              color="gray"
              data-dialog-close
            >
              {checkoutCancelLabel}
            </Button>
            <Button type="submit" variant="solid" color="cyan">
              {checkoutContinueLabel}
            </Button>
          </footer>
        </form>
      </Dialog>
    </div>
  </div>
</Layout>

<script id="paddle-js" src="https://cdn.paddle.com/paddle/v2/paddle.js"
></script>
<script
  define:vars={{
    paddleClientToken,
    paddleEnvironment,
    checkoutDialogId: CHECKOUT_EMAIL_DIALOG_ID,
    checkoutInvalidEmailError,
    checkoutSuccessPath,
    checkoutLang: lang,
    loggedInCustomerEmail,
    loggedInCustomerUserId
  }}
>
  const PRICING_INITED = 'data-pricing-toggle-inited'
  const PADDLE_INITED = 'data-paddle-inited'
  const CHECKOUT_DIALOG_INITED = 'data-pricing-checkout-dialog-inited'
  const PRICING_VIEW_SENT = 'data-pricing-view-sent'
  const YEAR_MONTHS = 12
  const PRICING_PAGE_KEY = 'pricing'

  function getCurrentBillingCycle() {
    const toggle = document.getElementById('pricing-billing-toggle')
    return toggle?.getAttribute('aria-pressed') === 'true' ? 'yearly' : 'monthly'
  }

  function capturePricingEvent(eventName, properties = {}) {
    window.posthog?.capture?.(eventName, {
      page_key: PRICING_PAGE_KEY,
      lang: checkoutLang,
      billing_cycle: getCurrentBillingCycle(),
      ...properties
    })
  }

  function capturePricingViewOnce() {
    const root = document.documentElement
    if (root.hasAttribute(PRICING_VIEW_SENT)) {
      return
    }
    root.setAttribute(PRICING_VIEW_SENT, '')
    capturePricingEvent('pricing_view')
  }

  function toYearlyPerMonth(total) {
    const match = total.trim().match(/(\d+[.,]\d+|\d+)/)
    if (match == null) {
      return total
    }
    const amount = Number.parseFloat(match[0].replace(',', '.'))
    if (!Number.isFinite(amount)) {
      return total
    }
    return total.replace(match[0], String(Math.round(amount / YEAR_MONTHS)))
  }

  function stripTrailingZeroCents(value) {
    return value.replace(/([.,])00\b/g, '')
  }

  function roundDisplayedPrice(value) {
    const match = value.match(/(\d+[.,]\d+|\d+)/)
    if (match == null) {
      return value
    }

    const amount = Number.parseFloat(match[0].replace(',', '.'))
    if (!Number.isFinite(amount)) {
      return value
    }

    return value.replace(match[0], String(Math.round(amount)))
  }

  function moveEuroSymbolAfterAmount(value) {
    return value.replace(/€\s*(\d+(?:[.,]\d+)?)/g, '$1€')
  }

  function showCheckoutError(message) {
    const errorEl = document.getElementById('pricing-checkout-email-error')
    if (errorEl == null) {
      return
    }
    errorEl.textContent = message
    errorEl.removeAttribute('hidden')
  }

  function hideCheckoutError() {
    const errorEl = document.getElementById('pricing-checkout-email-error')
    if (errorEl == null) {
      return
    }
    errorEl.textContent = ''
    errorEl.setAttribute('hidden', '')
  }

  function doubleDisplayedPrice(value) {
    const doubled = value.replace(/(\d+[.,]?\d*)/, (_, raw) =>
      String(Math.round(Number.parseFloat(raw.replace(',', '.')) * 2))
    )
    return doubled === value ? '' : doubled
  }

  async function preview(
    paddle,
    items,
    valueKey,
    bannersByPriceId,
    yearlyMode
  ) {
    if (items.length === 0) {
      return
    }
    const result = await paddle.PricePreview({ items })
    const lineItems = result.data.details.lineItems

    lineItems.forEach((lineItem) => {
      const priceId = lineItem.price.id
      const total = moveEuroSymbolAfterAmount(
        roundDisplayedPrice(
          stripTrailingZeroCents(lineItem.formattedTotals.total)
        )
      )
      const banner = bannersByPriceId.get(priceId)
      if (banner == null) {
        return
      }
      const value = yearlyMode ? toYearlyPerMonth(total) : total
      banner.setAttribute(valueKey, value)
      if (yearlyMode) {
        const template =
          banner.getAttribute('data-detail-yearly-template') ?? ''
        banner.setAttribute('data-detail-yearly', template.replace('--', total))
      }
    })
  }

  async function hydrateLocalizedPrices(banners) {
    if (banners.length === 0) {
      return
    }

    const monthlyItems = []
    const yearlyItems = []
    const monthBanners = new Map()
    const yearBanners = new Map()

    banners.forEach((banner) => {
      const monthId = banner.getAttribute('data-price-id-month') ?? ''
      const yearId = banner.getAttribute('data-price-id-year') ?? ''
      if (monthId !== '') {
        monthlyItems.push({ priceId: monthId, quantity: 1 })
        monthBanners.set(monthId, banner)
      }
      if (yearId !== '') {
        yearlyItems.push({ priceId: yearId, quantity: 1 })
        yearBanners.set(yearId, banner)
      }
    })

    const paddle = window.Paddle
    if (paddle == null) {
      return
    }

    try {
      if (!document.documentElement.hasAttribute(PADDLE_INITED)) {
        if (
          paddleEnvironment === 'sandbox' &&
          paddle.Environment != null &&
          typeof paddle.Environment.set === 'function'
        ) {
          paddle.Environment.set('sandbox')
        }
        paddle.Initialize({ token: paddleClientToken })
        document.documentElement.setAttribute(PADDLE_INITED, '')
      }

      await Promise.all([
        preview(
          paddle,
          monthlyItems,
          'data-month-price-localized',
          monthBanners,
          false
        ),
        preview(
          paddle,
          yearlyItems,
          'data-year-price-localized',
          yearBanners,
          true
        )
      ])
    } catch (error) {
      console.error('[Paddle] localized prices hydration failed', error)
    }
  }

  async function ensurePaddleInitialized() {
    const paddle = window.Paddle
    if (paddle == null) {
      return null
    }

    if (!document.documentElement.hasAttribute(PADDLE_INITED)) {
      if (
        paddleEnvironment === 'sandbox' &&
        paddle.Environment != null &&
        typeof paddle.Environment.set === 'function'
      ) {
        paddle.Environment.set('sandbox')
      }
      paddle.Initialize({ token: paddleClientToken })
      document.documentElement.setAttribute(PADDLE_INITED, '')
    }

    return paddle
  }

  function getActivePriceIdForPlan(planName) {
    const button = document.querySelector(`[data-open-checkout="${planName}"]`)
    if (!(button instanceof HTMLElement)) {
      return null
    }

    const planCard = button.closest('.pricing__plan-card')
    if (!(planCard instanceof HTMLElement)) {
      return null
    }

    const banner = planCard.querySelector('.pricing__plan-price-banner')
    if (!(banner instanceof HTMLElement)) {
      return null
    }

    const toggle = document.getElementById('pricing-billing-toggle')
    const isYearly = toggle?.getAttribute('aria-pressed') === 'true'
    const attributeName = isYearly
      ? 'data-price-id-year'
      : 'data-price-id-month'
    return banner.getAttribute(attributeName)
  }

  async function openCheckoutForPlan(planName, email) {
    const priceId = getActivePriceIdForPlan(planName)
    const paddle = await ensurePaddleInitialized()
    if (!priceId || !paddle) {
      capturePricingEvent('checkout_open_failed', {
        plan: planName,
        reason: priceId ? 'paddle_unavailable' : 'missing_price_id'
      })
      if (!paddle) {
        console.error('[Paddle] unavailable for checkout open.')
      }
      return false
    }

    const successUrl = `${window.location.origin}${checkoutSuccessPath}`
    const checkoutCustomData = {
      lang: checkoutLang,
      email
    }
    if (loggedInCustomerUserId !== '') {
      checkoutCustomData.user_id = loggedInCustomerUserId
    }

    paddle.Checkout.open({
      items: [{ priceId, quantity: 1 }],
      customer: { email },
      customData: checkoutCustomData,
      settings: {
        displayMode: 'overlay',
        successUrl
      }
    })
    capturePricingEvent('checkout_opened', {
      plan: planName,
      price_id: priceId
    })
    return true
  }

  /** Réexécuter à chaque chargement / swap (premier load, reload, navigation, changement de langue). */
  function initPricingToggle() {
    const toggle = document.getElementById('pricing-billing-toggle')
    const optionMonthly = document.getElementById('pricing-option-monthly')
    const optionYearly = document.getElementById('pricing-option-yearly')
    const banners = document.querySelectorAll('.pricing__plan-price-banner')

    if (!toggle || !optionMonthly || !optionYearly || banners.length === 0) {
      return
    }
    /** @param {boolean} yearly */
    // @ts-expect-error - inline script, yearly is boolean at runtime
    function setBilling(yearly) {
      const isYearly = Boolean(yearly)
      toggle?.setAttribute('aria-pressed', String(isYearly))
      optionMonthly?.setAttribute('aria-pressed', String(!isYearly))
      optionYearly?.setAttribute('aria-pressed', String(isYearly))

      banners.forEach((banner) => {
        const monthPriceLocalized = banner.getAttribute(
          'data-month-price-localized'
        )
        const yearPriceLocalized = banner.getAttribute(
          'data-year-price-localized'
        )
        const detailYearly = banner.getAttribute('data-detail-yearly') ?? ''
        const detailMonthly = banner.getAttribute('data-detail-monthly') ?? ''

        const currentEl = banner.querySelector('.pricing__plan-price-amount')
        const struckEl = banner.querySelector('.pricing__plan-price-struck')
        const detailEl = banner.querySelector('.pricing__plan-price-detail')

        if (currentEl) {
          if (isYearly) {
            currentEl.textContent = yearPriceLocalized ?? '--'
          } else {
            currentEl.textContent = monthPriceLocalized ?? '--'
          }
        }
        if (struckEl) {
          const shownPrice = isYearly
            ? (yearPriceLocalized ?? '')
            : (monthPriceLocalized ?? '')
          const struckValue = doubleDisplayedPrice(shownPrice)
          if (struckValue === '') {
            struckEl.style.display = 'none'
          } else {
            struckEl.style.display = ''
            struckEl.textContent = struckValue
          }
        }
        if (detailEl) {
          detailEl.textContent = isYearly ? detailYearly : detailMonthly
        }
      })
    }

    if (!toggle.hasAttribute(PRICING_INITED)) {
      toggle.setAttribute(PRICING_INITED, '')

      toggle.addEventListener('click', () => {
        const isYearly = toggle.getAttribute('aria-pressed') === 'true'
        setBilling(!isYearly)
        capturePricingEvent('billing_cycle_changed')
      })

      optionMonthly.addEventListener('click', () => {
        setBilling(false)
        capturePricingEvent('billing_cycle_changed')
      })

      optionYearly.addEventListener('click', () => {
        setBilling(true)
        capturePricingEvent('billing_cycle_changed')
      })

      setBilling(true)
    }

    hydrateLocalizedPrices(Array.from(banners)).finally(() => {
      const isYearly = toggle.getAttribute('aria-pressed') === 'true'
      setBilling(isYearly)
    })
  }

  /** First load/reload: wait until the DOM is ready. */
  function runWhenReady() {
    const run = () => {
      requestAnimationFrame(initPricingToggle)
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', run)
    } else {
      run()
    }
  }

  runWhenReady()
  const paddleScript = document.getElementById('paddle-js')
  if (paddleScript != null) {
    paddleScript.addEventListener('load', initPricingToggle)
  }
  document.addEventListener('astro:after-swap', initPricingToggle)
  document.addEventListener('astro:page-load', initPricingToggle)

  function setupCheckoutDialog() {
    const dialog = document.getElementById(checkoutDialogId)
    const form = document.getElementById('pricing-checkout-email-form')
    if (
      !(dialog instanceof HTMLDialogElement) ||
      !(form instanceof HTMLFormElement)
    ) {
      return
    }
    if (dialog.hasAttribute(CHECKOUT_DIALOG_INITED)) {
      return
    }
    dialog.setAttribute(CHECKOUT_DIALOG_INITED, '')

    document.querySelectorAll('[data-open-checkout]').forEach((trigger) => {
      if (!(trigger instanceof HTMLElement)) {
        return
      }
      trigger.addEventListener('click', async () => {
        const planName = trigger.getAttribute('data-open-checkout') ?? ''
        if (planName === '') {
          return
        }
        capturePricingEvent('pricing_cta_clicked', { plan: planName })
        if (loggedInCustomerEmail !== '') {
          capturePricingEvent('checkout_started', {
            plan: planName,
            source: 'logged_in_direct'
          })
          await openCheckoutForPlan(planName, loggedInCustomerEmail)
          return
        }
        dialog.setAttribute('data-checkout-plan', planName)
        hideCheckoutError()
        const emailInput = form.elements.namedItem('email')
        if (emailInput instanceof HTMLInputElement) {
          emailInput.value = ''
        }
        dialog.showModal()
      })
    })

    form.addEventListener('submit', async (event) => {
      event.preventDefault()
      hideCheckoutError()

      const emailInput = form.elements.namedItem('email')
      if (!(emailInput instanceof HTMLInputElement)) {
        showCheckoutError(checkoutInvalidEmailError)
        return
      }

      const email = emailInput.value.trim()
      if (!emailInput.checkValidity()) {
        showCheckoutError(checkoutInvalidEmailError)
        return
      }

      const planName = dialog.getAttribute('data-checkout-plan') ?? ''
      if (planName === '') {
        return
      }

      capturePricingEvent('checkout_started', { plan: planName })
      const checkoutOpened = await openCheckoutForPlan(planName, email)
      if (checkoutOpened) {
        dialog.close()
      }
    })
  }

  capturePricingViewOnce()
  setupCheckoutDialog()
  document.addEventListener('astro:page-load', setupCheckoutDialog)
  document.addEventListener('astro:page-load', capturePricingViewOnce)
</script>

