---
import Layout from '../../layouts/Layout.astro'
import { useTranslations, useLocalePath } from '../../i18n/utils'
import Button from '../../components/ui/Button.astro'
import guaranteeBadge from '../../assets/guarantee-badge.svg'
import { SUBSCRIPTION_PLANS } from '../../lib/subscription-plans'
import '../../styles/components/card.css'
import '../../styles/components/accordion.css'
import '../../styles/components/guarantee.css'
import '../../styles/routes/pricing.css'

const lang = Astro.params.lang as 'en' | 'fr'
const t = useTranslations(lang)
const localePath = useLocalePath(lang)

const standardPlan = SUBSCRIPTION_PLANS.standard
const standardPricing = standardPlan.pricing!
const standardPriceMonth = standardPricing.priceMonth
const standardPriceYearTotal = standardPricing.priceYearTotal
const standardPriceYearPerMonth = standardPricing.priceYearPerMonth
const standardStruckMonth = standardPricing.struckMonth
const standardStruckYearPerMonth = standardPricing.struckYearPerMonth
const standardYearlyMonthsFree = standardPricing.yearlyMonthsFree
const standardDetailYearlyText = `${t('pricing_earlyaccess_paid_yearly_label')} ${standardPriceYearTotal}€ - ${t('pricing_earlyaccess_detail_yearly', { count: standardYearlyMonthsFree })}`

const proPlan = SUBSCRIPTION_PLANS.individual
const pricing = proPlan.pricing!
const priceMonth = pricing.priceMonth
const priceYearTotal = pricing.priceYearTotal
const priceYearPerMonth = pricing.priceYearPerMonth
const struckMonth = pricing.struckMonth
const struckYearPerMonth = pricing.struckYearPerMonth
const yearlyMonthsFree = pricing.yearlyMonthsFree
const detailYearlyText = `${t('pricing_earlyaccess_paid_yearly_label')} ${priceYearTotal}€ - ${t('pricing_earlyaccess_detail_yearly', { count: yearlyMonthsFree })}`

const faqItems = [
  { id: 'q1', q: t('pricing_faq_q1'), a: t('pricing_faq_a1') },
  { id: 'q2', q: t('pricing_faq_q2'), a: t('pricing_faq_a2') },
  { id: 'q3', q: t('pricing_faq_q3'), a: t('pricing_faq_a3') },
  { id: 'q4', q: t('pricing_faq_q4'), a: t('pricing_faq_a4') }
]
---

<Layout>
  <div class="pricing">
    <h1 class="pricing__title">{t('pricing_title')}</h1>
    <p class="pricing__subtitle">{t('pricing_subtitle')}</p>

    <div class="pricing__toggle" role="group" aria-label="Billing period">
      <span
        class="pricing__toggle-option"
        id="pricing-option-monthly"
        aria-pressed="false"
      >
        {t('pricing_toggle_monthly')}
      </span>
      <button
        type="button"
        class="pricing__toggle-switch"
        id="pricing-billing-toggle"
        aria-pressed="true"
        aria-label="Toggle yearly billing"
        title={t('pricing_toggle_yearly')}
      >
      </button>
      <span
        class="pricing__toggle-option"
        id="pricing-option-yearly"
        aria-pressed="true"
      >
        {t('pricing_toggle_yearly')}
      </span>
    </div>

    <div class="pricing__promo-wrap" role="status" aria-live="polite">
      <span class="pricing__promo-banner-text">
        {t('pricing_earlyaccess_badge')}
      </span>
    </div>

    <div class="pricing__plans">
      <!-- Standard plan -->
      <article
        class="card card--outline pricing__plan-card"
        data-billing="monthly"
      >
        <div class="card__header">
          <h2 class="card__title pricing__plan-title">
            {t('pricing_standard_name')}
          </h2>
          <div class="pricing__plan-price">
            <div
              class="pricing__plan-price-banner"
              data-month-price={String(standardPriceMonth)}
              data-year-price={String(standardPriceYearPerMonth)}
              data-struck-month={String(standardStruckMonth)}
              data-struck-year={String(standardStruckYearPerMonth)}
              data-detail-yearly={standardDetailYearlyText}
            >
              <div class="pricing__plan-price-current">
                <span class="pricing__plan-price-struck">
                  {standardStruckYearPerMonth}€
                </span>
                <span class="pricing__plan-price-amount">
                  {standardPriceYearPerMonth}€
                </span>
                <span class="pricing__plan-price-period">
                  {t('pricing_per_month')}
                </span>
              </div>
              <div class="pricing__plan-price-detail-wrap">
                <span
                  class="pricing__plan-price-detail pricing__plan-price-detail--top"
                >
                  {standardDetailYearlyText}
                </span>
                <span
                  class="pricing__plan-price-detail pricing__plan-price-detail--discreet"
                >
                  {t('pricing_earlyaccess_detail_monthly')}
                </span>
              </div>
            </div>
          </div>
        </div>
        <div class="card__body">
          <ul class="pricing__plan-features">
            <li class="pricing__plan-feature">
              <span class="pricing__plan-feature-check">✓</span>
              {t('pricing_standard_feature1')}
            </li>
            <li class="pricing__plan-feature">
              <span class="pricing__plan-feature-check">✓</span>
              {t('pricing_standard_feature2')}
            </li>
            <li class="pricing__plan-feature pricing__plan-feature--excluded">
              <span class="pricing__plan-feature-x" aria-hidden="true">—</span>
              {t('pricing_standard_feature3')}
            </li>
            <li class="pricing__plan-feature pricing__plan-feature--excluded">
              <span class="pricing__plan-feature-x" aria-hidden="true">—</span>
              {t('pricing_standard_feature4')}
            </li>
          </ul>
        </div>
        <div class="card__footer pricing__plan-footer">
          <Button
            href={localePath('/courses')}
            variant="outline"
            size="lg"
            class="pricing__plan-button"
          >
            {t('pricing_standard_cta')}
          </Button>
        </div>
      </article>

      <!-- KubeMastery Pro plan -->
      <article
        class="card card--outline pricing__plan-card pricing__plan-card--highlighted"
        data-billing="monthly"
      >
        <div class="card__header">
          <h2 class="card__title pricing__plan-title">
            {t('pricing_earlyaccess_name')}
          </h2>
          <div class="pricing__plan-price">
            <div
              class="pricing__plan-price-banner"
              data-month-price={String(priceMonth)}
              data-year-price={String(priceYearPerMonth)}
              data-struck-month={String(struckMonth)}
              data-struck-year={String(struckYearPerMonth)}
              data-detail-yearly={detailYearlyText}
            >
              <div class="pricing__plan-price-current">
                <span class="pricing__plan-price-struck">
                  {struckYearPerMonth}€
                </span>
                <span class="pricing__plan-price-amount">
                  {priceYearPerMonth}€
                </span>
                <span class="pricing__plan-price-period">
                  {t('pricing_per_month')}
                </span>
              </div>
              <div class="pricing__plan-price-detail-wrap">
                <span
                  class="pricing__plan-price-detail pricing__plan-price-detail--top"
                >
                  {detailYearlyText}
                </span>
                <span
                  class="pricing__plan-price-detail pricing__plan-price-detail--discreet"
                >
                  {t('pricing_earlyaccess_detail_monthly')}
                </span>
              </div>
            </div>
          </div>
        </div>
        <div class="card__body">
          <ul class="pricing__plan-features">
            <li class="pricing__plan-feature">
              <span class="pricing__plan-feature-check">✓</span>
              {t('pricing_earlyaccess_feature1')}
            </li>
            <li class="pricing__plan-feature">
              <span class="pricing__plan-feature-check">✓</span>
              {t('pricing_earlyaccess_feature2')}
            </li>
            <li class="pricing__plan-feature">
              <span class="pricing__plan-feature-check">✓</span>
              {t('pricing_earlyaccess_feature3')}
            </li>
            <li class="pricing__plan-feature">
              <span class="pricing__plan-feature-check">✓</span>
              {t('pricing_earlyaccess_feature4')}
            </li>
          </ul>
        </div>
        <div class="card__footer pricing__plan-footer">
          <Button
            href={localePath('/courses')}
            variant="solid"
            size="lg"
            color="cyan"
            class="pricing__plan-button"
          >
            {t('pricing_earlyaccess_cta')}
          </Button>
        </div>
      </article>

      <!-- Business (coming soon) -->
      <article
        class="card card--outline pricing__plan-card pricing__plan-card--coming-soon"
      >
        <div class="card__header">
          <div class="pricing__badge">
            <span class="pricing__badge-text pricing__badge-text--cyan">
              {t('pricing_business_comingSoon')}
            </span>
          </div>
          <h2 class="card__title pricing__plan-title">
            {t('pricing_business_name')}
          </h2>
          <div class="pricing__plan-header-spacer" aria-hidden="true"></div>
        </div>
        <div class="card__body">
          <ul class="pricing__plan-features">
            <li class="pricing__plan-feature">
              <span class="pricing__plan-feature-check">✓</span>
              {t('pricing_business_feature1')}
            </li>
            <li class="pricing__plan-feature">
              <span class="pricing__plan-feature-check">✓</span>
              {t('pricing_business_feature2')}
            </li>
          </ul>
        </div>
        <div class="card__footer pricing__plan-footer">
          <Button
            variant="outline"
            size="lg"
            disabled
            class="pricing__plan-button"
          >
            {t('pricing_business_comingSoon')}
          </Button>
        </div>
      </article>
    </div>

    <div class="guarantee">
      <div class="content">
        <div class="guarantee-row">
          <div class="guarantee-badge">
            <img
              src={guaranteeBadge.src}
              alt={t('home_guarantee_image_alt')}
              loading="lazy"
            />
          </div>
          <div class="guarantee-text">
            <h2>{t('home_guarantee_title')}</h2>
            <p>{t('home_guarantee_subtitle')}</p>
            <ul class="guarantee-bullets">
              <li>{t('home_guarantee_point1')}</li>
              <li>{t('home_guarantee_point2')}</li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <section class="pricing__features-section">
      <h2 class="pricing__features-title">
        {t('pricing_features_title')}
      </h2>
      <div class="pricing__features-grid">
        <div class="pricing__feature-card">
          <h3 class="pricing__feature-card-title">
            {t('pricing_features_speed_title')}
          </h3>
          <p class="pricing__feature-card-description">
            {t('pricing_features_speed_desc')}
          </p>
        </div>
        <div class="pricing__feature-card">
          <h3 class="pricing__feature-card-title">
            {t('pricing_features_stability_title')}
          </h3>
          <p class="pricing__feature-card-description">
            {t('pricing_features_stability_desc')}
          </p>
        </div>
        <div class="pricing__feature-card">
          <h3 class="pricing__feature-card-title">
            {t('pricing_features_price_title')}
          </h3>
          <p class="pricing__feature-card-description">
            {t('pricing_features_price_desc')}
          </p>
        </div>
      </div>
    </section>

    <section class="pricing__faq-section">
      <h2 class="pricing__faq-title">{t('pricing_faq_title')}</h2>
      <div class="pricing__faq-container">
        <div class="accordion accordion--size-md pricing__faq-accordion">
          {
            faqItems.map((faq) => (
              <details
                class="accordion__item accordion__item--variant-outline"
                id={faq.id}
              >
                <summary class="accordion__item-trigger">
                  <span class="pricing__faq-question">{faq.q}</span>
                  <span class="accordion__item-indicator" aria-hidden="true">
                    ▼
                  </span>
                </summary>
                <div class="accordion__item-content">
                  <div class="accordion__item-body">
                    <p class="pricing__faq-answer">{faq.a}</p>
                  </div>
                </div>
              </details>
            ))
          }
        </div>
      </div>
    </section>
  </div>
</Layout>

<script>
  const PRICING_INITED = 'data-pricing-toggle-inited'

  /** Réexécuter à chaque chargement / swap (premier load, reload, navigation, changement de langue). */
  function initPricingToggle() {
    const toggle = document.getElementById('pricing-billing-toggle')
    const optionMonthly = document.getElementById('pricing-option-monthly')
    const optionYearly = document.getElementById('pricing-option-yearly')
    const banners = document.querySelectorAll('.pricing__plan-price-banner')

    if (!toggle || !optionMonthly || !optionYearly || banners.length === 0) {
      return
    }
    if (toggle.hasAttribute(PRICING_INITED)) {
      return
    }
    toggle.setAttribute(PRICING_INITED, '')

    /** @param {boolean} yearly */
    // @ts-expect-error - inline script, yearly is boolean at runtime
    function setBilling(yearly) {
      const isYearly = Boolean(yearly)
      toggle?.setAttribute('aria-pressed', String(isYearly))
      optionMonthly?.setAttribute('aria-pressed', String(!isYearly))
      optionYearly?.setAttribute('aria-pressed', String(isYearly))

      banners.forEach((banner) => {
        const monthPrice = banner.getAttribute('data-month-price') ?? '12'
        const yearPrice = banner.getAttribute('data-year-price') ?? '10'
        const struckMonth = banner.getAttribute('data-struck-month') ?? '24'
        const struckYear = banner.getAttribute('data-struck-year') ?? '20'
        const detailYearly = banner.getAttribute('data-detail-yearly') ?? ''

        const currentEl = banner.querySelector('.pricing__plan-price-amount')
        const struckEl = banner.querySelector('.pricing__plan-price-struck')
        const detailTopEl = banner.querySelector(
          '.pricing__plan-price-detail--top'
        )

        if (currentEl) {
          currentEl.textContent = isYearly ? `${yearPrice}€` : `${monthPrice}€`
        }
        if (struckEl) {
          struckEl.textContent = isYearly ? `${struckYear}€` : `${struckMonth}€`
        }
        if (detailTopEl) {
          detailTopEl.textContent = isYearly ? detailYearly : '\u00A0'
          detailTopEl.classList.toggle(
            'pricing__plan-price-detail--highlight',
            isYearly
          )
        }
      })
    }

    toggle.addEventListener('click', () => {
      const isYearly = toggle.getAttribute('aria-pressed') === 'true'
      setBilling(!isYearly)
    })

    optionMonthly.addEventListener('click', () => {
      setBilling(false)
    })

    optionYearly.addEventListener('click', () => {
      setBilling(true)
    })

    setBilling(true)
  }

  /** Premier chargement / reload : attendre que le DOM (et le swap View Transitions) soit prêt. */
  function runWhenReady() {
    const run = () => {
      requestAnimationFrame(initPricingToggle)
      setTimeout(initPricingToggle, 0)
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', run)
    } else {
      run()
    }
  }

  runWhenReady()
  document.addEventListener('astro:after-swap', initPricingToggle)
  document.addEventListener('astro:page-load', initPricingToggle)
</script>
