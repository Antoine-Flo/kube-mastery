---
import Layout from '../../../../layouts/Layout.astro'
import { useLocalePath } from '../../../../i18n/utils'
import { getTaskGroupOverview } from '../../../../content/tasks/facade'
import { getCompletedTaskIds } from '../../../../lib/progress/server'
import { CirclePlay, CircleCheck } from '@lucide/astro'

const lang = Astro.params.lang as 'en' | 'fr'
const groupId = Astro.params.groupId!
const localePath = useLocalePath(lang)

const overview = getTaskGroupOverview(groupId, lang)
if (!overview) {
  return Astro.redirect(localePath('/courses'))
}

const completedTaskIds = await getCompletedTaskIds(
  Astro.locals,
  Astro.request,
  Astro.cookies
)
---

<Layout>
  <main class="task-overview">
    <h1>{overview.title}</h1>
    {overview.description && <p class="desc">{overview.description}</p>}
    <ul class="task-list">
      {
        overview.tasks.map((task) => {
          const taskTargetId = `${groupId}/${task.id}`
          const completed = completedTaskIds.has(taskTargetId)
          return (
            <li>
              <a
                href={localePath(`/tasks/${groupId}/${task.id}`)}
                class={`task-link${completed ? ' task-link--completed' : ''}`}
              >
                {completed ? (
                  <CircleCheck size={18} aria-hidden="true" />
                ) : (
                  <CirclePlay size={18} aria-hidden="true" />
                )}
                <div class="task-link__text">
                  <span class="task-link__title">{task.title}</span>
                  {task.description && (
                    <span class="task-link__description">
                      {task.description}
                    </span>
                  )}
                </div>
              </a>
            </li>
          )
        })
      }
    </ul>
  </main>
</Layout>

<style>
  .task-overview {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .task-overview h1 {
    font-size: 1.875rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-12);
    margin: 0 0 0.5rem;
  }

  .task-overview .desc {
    color: var(--color-gray-11);
    font-size: var(--text-lg);
    margin: 0 0 2rem;
  }

  .task-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .task-list li {
    margin: 0;
  }

  .task-link {
    display: inline-flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-gray-6);
    background: var(--color-gray-1);
    color: inherit;
    text-decoration: none;
    transition:
      border-color 0.15s,
      background 0.15s;
    width: 100%;
    box-sizing: border-box;
  }

  .task-link:hover {
    border-color: var(--color-primary-6);
    background: var(--color-primary-1);
  }

  .task-link :global(svg) {
    flex-shrink: 0;
    color: var(--color-gray-9);
    margin-top: 0.15rem;
  }

  .task-link--completed :global(svg) {
    color: var(--color-green-9);
  }

  .task-link__text {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .task-link__title {
    font-weight: var(--font-weight-semibold);
    color: var(--color-gray-12);
  }

  .task-link__description {
    font-size: var(--text-sm);
    color: var(--color-gray-11);
    line-height: 1.4;
  }
</style>
