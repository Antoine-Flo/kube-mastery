---
import Layout from '../../../../../layouts/Layout.astro'
import ContentWithTerminalLayout from '../../../../../components/lesson/ContentWithTerminalLayout.astro'
import Button from '../../../../../components/ui/Button.astro'
import { useLocalePath, useTranslations } from '../../../../../i18n/utils'
import {
  getTaskContent,
  getTaskGroupOverview
} from '../../../../../content/tasks/facade'
import { DEMO_TASK_GROUP_ID } from '../../../../../content/tasks/constants'
import { getCourseOverview } from '../../../../../content/overview/facade'
import { getLayoutAuthContext } from '../../../../../lib/auth/server'
import { getProgressContext } from '../../../../../lib/progress/server'
import { getFirstNonPlaceholderLessonIdFromSections } from '../../../../../lib/courses/lessonTerminalAccess'
import '../../../../../styles/components/lesson-content.css'
import '../../../../../styles/components/cluster-visualization.css'

const lang = Astro.params.lang as 'en' | 'fr'
const groupId = Astro.params.groupId!
const taskId = Astro.params.taskId!
const localePath = useLocalePath(lang)
const t = useTranslations(lang)

const { userId } = await getProgressContext(
  Astro.locals,
  Astro.request,
  Astro.cookies
)
const auth = await getLayoutAuthContext(
  Astro.locals,
  Astro.request,
  Astro.cookies
)
const isDemoTask = groupId === DEMO_TASK_GROUP_ID
if (!userId && !isDemoTask) {
  return Astro.redirect(
    localePath('/auth') + '?redirect=' + encodeURIComponent(Astro.url.pathname)
  )
}

const taskEntry = getTaskContent(groupId, taskId, lang)
if (!taskEntry) {
  return Astro.redirect(localePath(`/tasks/${groupId}`))
}

const overview = getTaskGroupOverview(groupId, lang)
if (!overview) {
  return Astro.redirect(localePath('/courses'))
}

const { Content } = taskEntry
const env = overview.environment?.trim().toLowerCase()
const seedName = env && env !== 'empty' ? env : 'minimal'

const taskIndex = overview.tasks.findIndex((task) => task.id === taskId)
const prevTask = taskIndex > 0 ? overview.tasks[taskIndex - 1] : null
const nextTask =
  taskIndex >= 0 && taskIndex < overview.tasks.length - 1
    ? overview.tasks[taskIndex + 1]
    : null

const taskTargetId = `${groupId}/${taskId}`
const completeTaskUrl = `/api/progress/complete?type=task&targetId=${encodeURIComponent(taskTargetId)}&redirect=${encodeURIComponent(localePath(`/tasks/${groupId}/${taskId}/complete`))}`

const contentBarLabels = {
  labelVisualizer: t('lesson_visualizer'),
  labelCourse: t('lesson_viewCourse'),
  labelShowTerminal: t('lesson_showTerminal'),
  labelHideTerminal: t('lesson_hideTerminal'),
  labelContactSupport: t('lesson_contactSupport'),
  labelReloadTerminal: t('lesson_reloadTerminal')
}

const terminalInteractive = isDemoTask || auth.hasPaidSubscription
const crashOverview = getCourseOverview('crash-course', lang)
const crashFirstLessonId = crashOverview
  ? getFirstNonPlaceholderLessonIdFromSections(crashOverview.content.sections)
  : null
const terminalLockTryFreeHref = crashFirstLessonId
  ? localePath(`/courses/crash-course/${crashFirstLessonId}`)
  : localePath('/courses')
const hasSession = userId != null && userId !== ''
const terminalLockSecondaryHref = hasSession
  ? localePath('/pricing')
  : `${localePath('/auth')}?redirect=${encodeURIComponent(Astro.url.pathname)}`
const terminalLockSecondaryLabel = hasSession
  ? t('lesson_terminalLock_ctaPricing')
  : t('lesson_terminalLock_ctaSignIn')
---

<Layout bodyClass="lp-fill navbar-app" showFooter={false}>
  <ContentWithTerminalLayout
    seedName={seedName}
    lang={lang}
    showSidebar={false}
    labels={contentBarLabels}
    supportContextId={`tasks/${groupId}/${taskId}`}
    terminalInteractive={terminalInteractive}
    terminalLockTitle={t('lesson_terminalLock_title')}
    terminalLockBody={t('lesson_terminalLock_body')}
    terminalLockTryFreeLabel={t('lesson_terminalLock_tryFree')}
    terminalLockTryFreeHref={terminalLockTryFreeHref}
    terminalLockSecondaryLabel={terminalLockSecondaryLabel}
    terminalLockSecondaryHref={terminalLockSecondaryHref}
  >
    <article class="lesson-content">
      <Content />
    </article>
    <nav class="lp__nav--bt">
      {
        prevTask ? (
          <a
            href={localePath(`/tasks/${groupId}/${prevTask.id}`)}
            class="lp__lnk"
          >
            ← {prevTask.title}
          </a>
        ) : (
          <span />
        )
      }
      {
        nextTask ? (
          <a
            href={localePath(`/tasks/${groupId}/${nextTask.id}`)}
            class="lp__lnk lp__lnk--next"
          >
            {nextTask.title} →
          </a>
        ) : null
      }
    </nav>
    <div class="lp__task-complete">
      {
        isDemoTask && !userId ? (
          <Button
            href={localePath('/pricing')}
            variant="solid"
            color="cyan"
            size="md"
          >
            {t('home_cta_join')}
          </Button>
        ) : (
          <Button href={completeTaskUrl} variant="solid" color="cyan" size="md">
            {t('tasks_doneButton')}
          </Button>
        )
      }
    </div>
  </ContentWithTerminalLayout>
</Layout>
