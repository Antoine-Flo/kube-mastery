---
import Layout from '../../layouts/Layout.astro'
import CourseCard from '../../components/CourseCard.astro'
import { useTranslations, useLocalePath } from '../../i18n/utils'
import { getModules } from '../../content/courses/facade'

const locale = Astro.params.lang as 'en' | 'fr'
const t = useTranslations(locale)
const localePath = useLocalePath(locale)

const modules = getModules(locale)
---

<Layout>
  <main>
    <h1>{t('modules_title')}</h1>
    <p>{t('modules_subtitle')}</p>

    <div class="grid">
      {
        modules.map((mod) => (
          <CourseCard
            title={mod.title}
            description={mod.description}
            totalLessons={mod.totalLessons}
            href={localePath(`/modules/${mod.id}`)}
            lessonsLabel={`${mod.totalLessons} ${t('courses_lessons')}`}
            comingSoonLabel={t('courses_comingSoon')}
          />
        ))
      }
    </div>
  </main>
</Layout>

<style>
  main {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 4rem 2rem;
  }
  main h1 {
    font-size: 1.875rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-12);
    text-align: center;
    margin-bottom: 0.2rem;
  }
  main > p {
    color: var(--color-gray-11);
    text-align: center;
    margin-bottom: 3rem;
    font-size: var(--text-lg);
  }
  main .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    main .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
