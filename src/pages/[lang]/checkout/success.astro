---
import Layout from '../../../layouts/Layout.astro'
import Button from '../../../components/ui/Button.astro'
import { useTranslations, useLocalePath } from '../../../i18n/utils'
import '../../../styles/components/card.css'
import '../../../styles/components/page-halo.css'

const lang = (Astro.params.lang || 'en') as 'en' | 'fr'
const t = useTranslations(lang)
const localePath = useLocalePath(lang)
---

<Layout>
  <div class="page-halo">
    <div class="page-halo__bg" aria-hidden="true"></div>
    <div class="checkout-success-page">
      <article class="card card--outline checkout-success-card">
        <div class="card__header checkout-success-card__header">
          <h1 class="card__title">{t('checkout_success_title')}</h1>
        </div>
        <div class="card__body checkout-success-card__body">
          <p>{t('checkout_success_message')}</p>
          <p>{t('checkout_success_supportHint')}</p>
          <div class="checkout-success-card__actions">
            <Button href={localePath('/contact')} variant="outline" size="lg">
              {t('checkout_success_contactCta')}
            </Button>
          </div>
        </div>
      </article>
    </div>
  </div>
</Layout>

<script define:vars={{ checkoutLang: lang }}>
  const CHECKOUT_COMPLETED_SENT = 'data-checkout-completed-sent'

  function captureCheckoutCompleted() {
    const root = document.documentElement
    if (root.hasAttribute(CHECKOUT_COMPLETED_SENT)) {
      return
    }
    root.setAttribute(CHECKOUT_COMPLETED_SENT, '')
    window.posthog?.capture?.('checkout_completed', {
      page_key: 'checkout_success',
      lang: checkoutLang
    })
  }

  captureCheckoutCompleted()
  document.addEventListener('astro:page-load', captureCheckoutCompleted)
</script>

<style>
  .checkout-success-page {
    display: flex;
    justify-content: center;
    width: 100%;
    padding: clamp(2.5rem, 5vw, 5rem) 1.25rem;
  }

  .checkout-success-card {
    max-width: 42rem;
    width: 100%;
  }

  .checkout-success-card__header {
    padding-bottom: var(--spacing-3);
  }

  .checkout-success-card__body {
    display: grid;
    gap: var(--spacing-3);
  }

  .checkout-success-card__actions {
    margin-top: var(--spacing-2);
    display: flex;
    justify-content: flex-start;
  }
</style>
