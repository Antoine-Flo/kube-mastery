---
export const prerender = true

import Layout from '../../../layouts/Layout.astro'
import { getNewsFeed } from '../../../blog/news-feed'
import type { NewsLang } from '../../../blog/news-feed'
import { enabledLanguages } from '../../../i18n/ui'
import { useTranslations } from '../../../i18n/utils'
import '../../../styles/routes/news.css'

export function getStaticPaths() {
  return enabledLanguages.map((lang) => ({ params: { lang } }))
}

const lang = Astro.params.lang as NewsLang
const t = useTranslations(lang)
const newsFeed = getNewsFeed(lang)
const isFrench = lang === 'fr'

function formatDate(dateValue: string): string {
  const locale = isFrench ? 'fr-FR' : 'en-US'
  return new Intl.DateTimeFormat(locale, { dateStyle: 'long' }).format(
    new Date(dateValue)
  )
}
---

<Layout title={t('news_index_title')} description={t('news_index_description')}>
  <main class="news-page">
    <h1>{t('news_index_title')}</h1>

    <ul class="news-list">
      {
        newsFeed.map((item) => (
          <li class="news-list-item">
            <div class="news-list-meta">
              <span>{formatDate(item.publishedAt)}</span>
              <span>·</span>
              <a href={item.sourceUrl} rel="noopener noreferrer" target="_blank">
                {item.sourceName}
              </a>
            </div>
            <h2>
              <a href={item.sourceUrl} rel="noopener noreferrer" target="_blank">
                {item.headline}
              </a>
            </h2>
            <p>{item.tldr}</p>
            <p class="news-why">{item.whyItMatters}</p>
            <div class="news-tags">
              {item.tags.map((tag) => (
                <span class="news-tag">{tag}</span>
              ))}
            </div>
          </li>
        ))
      }
    </ul>
  </main>
</Layout>
