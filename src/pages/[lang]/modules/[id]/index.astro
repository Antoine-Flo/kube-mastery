---
import Layout from "../../../../layouts/Layout.astro";
import OverviewLayout from "../../../../components/overview/OverviewLayout.astro";
import OverviewHeader from "../../../../components/overview/OverviewHeader.astro";
import OverviewStructure from "../../../../components/overview/OverviewStructure.astro";
import { useTranslations, useLocalePath } from "../../../../i18n/utils.js";
import { getModules } from "../../../../data/courses.js";
import { getModuleOverview } from "../../../../data/overview.js";

export function getStaticPaths() {
	const paths: { params: { lang: string; id: string } }[] = [];
	for (const lang of ["en", "fr"] as const) {
		const modules = getModules(lang);
		for (const m of modules) {
			paths.push({ params: { lang, id: m.id } });
		}
	}
	return paths;
}

const lang = Astro.params.lang as "en" | "fr";
const id = Astro.params.id!;
const t = useTranslations(lang);
const localePath = useLocalePath(lang);

const overview = getModuleOverview(id, lang);
if (!overview) {
	return Astro.redirect(localePath("/courses"));
}

const firstChapter = overview.content.chapters[0];
const firstLessonId = firstChapter?.lessons[0]?.id;
const startHref = firstLessonId
	? localePath(`/modules/${id}/lessons/${firstLessonId}`)
	: "#";
const lessonBaseUrl = localePath(`/modules/${id}/lessons`);
---
<Layout>
	<OverviewLayout>
		<div class="l">
			<OverviewHeader overview={overview} t={t} startHref={startHref} />
		</div>
		<div class="r">
			<OverviewStructure
				chapters={overview.content.chapters}
				groupByModule={false}
				lessonBaseUrl={lessonBaseUrl}
				t={t}
			/>
		</div>
	</OverviewLayout>
</Layout>
