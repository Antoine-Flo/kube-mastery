---
import Layout from '../../../../layouts/Layout.astro'
import ContentWithTerminalLayout from '../../../../components/lesson/ContentWithTerminalLayout.astro'
import DrillValidations from '../../../../components/drills/DrillValidations.astro'
import Button from '../../../../components/ui/Button.astro'
import { useLocalePath, useTranslations } from '../../../../i18n/utils'
import { getDrillDetail } from '../../../../content/drills/facade'
import { getCourseOverview } from '../../../../content/overview/facade'
import { getLayoutAuthContext } from '../../../../lib/auth/server'
import { getProgressContext } from '../../../../lib/progress/server'
import { getFirstNonPlaceholderLessonIdFromSections } from '../../../../lib/lesson/lessonTerminalAccess'
import '../../../../styles/components/lesson-content.css'
import '../../../../styles/components/cluster-visualization.css'

const lang = Astro.params.lang as 'en' | 'fr'
const drillId = Astro.params.drillId!
const localePath = useLocalePath(lang)
const t = useTranslations(lang)

const modeRaw = Astro.url.searchParams.get('mode')
const runMode = modeRaw === 'guided' || modeRaw === 'exam' ? modeRaw : null

const { userId } = await getProgressContext(
  Astro.locals,
  Astro.request,
  Astro.cookies
)
const auth = await getLayoutAuthContext(
  Astro.locals,
  Astro.request,
  Astro.cookies
)

const drillDetail = getDrillDetail(drillId, lang)
if (!drillDetail) {
  return Astro.redirect(localePath('/drills'))
}

const allowUnauthenticated = drillDetail.isFree === true
if (!userId && !allowUnauthenticated) {
  const redirectTarget = `${Astro.url.pathname}${Astro.url.search}`
  return Astro.redirect(
    localePath('/auth') + '?redirect=' + encodeURIComponent(redirectTarget)
  )
}

if (runMode === null) {
  return Astro.redirect(`${localePath(`/drills/${drillId}`)}?mode=guided`)
}

const withMode = (path: string) =>
  `${path}${path.includes('?') ? '&' : '?'}mode=${runMode}`

const env = drillDetail.environment?.trim().toLowerCase()
const seedName = env && env !== 'empty' ? env : 'minimal'

const terminalInteractive =
  drillDetail.isFree === true || auth.hasPaidSubscription
const crashOverview = getCourseOverview('crash-course', lang)
const crashFirstLessonId = crashOverview
  ? getFirstNonPlaceholderLessonIdFromSections(crashOverview.content.sections)
  : null
const terminalLockCrashCourseHref = crashFirstLessonId
  ? localePath(`/courses/crash-course/${crashFirstLessonId}`)
  : localePath('/courses')
const terminalLockPrimaryHref = localePath('/pricing')
const terminalLockSecondaryHref = terminalLockCrashCourseHref
const drillBackHref = localePath('/drills')
const retryHref = withMode(localePath(`/drills/${drillId}`))

const kubernetesDocsUrl = 'https://kubernetes.io/docs/home/'

const tasks = drillDetail.tasks
---

<Layout bodyClass="lp-fill navbar-app" showFooter={false}>
  <ContentWithTerminalLayout
    seedName={seedName}
    lang={lang}
    showSidebar={false}
    supportContextId={`drills/${drillId}`}
    terminalInteractive={terminalInteractive}
    terminalLockPrimaryHref={terminalLockPrimaryHref}
    terminalLockSecondaryHref={terminalLockSecondaryHref}
    terminalDocsHref={kubernetesDocsUrl}
    terminalDocsTabLabel="Docs"
    terminalShellTabLabel="Terminal"
  >
    <div class="drill-timer-bar" data-drill-timer-wrap aria-live="polite">
      <a class="drill-back-link" href={drillBackHref}>
        ← {t('drillComplete_backToDrills')}
      </a>
      <span class="drill-timer-bar__timer">
        <span>{t('drills_timer_label')}</span>
        <span class="drill-timer-bar__value" data-drill-timer-display>
          00:00
        </span>
      </span>
    </div>

    <article class="lesson-content" data-drill-mode={runMode}>
      <p class="drill-section-label">{t('drills_tasks')}</p>
      <ol class="drill-tasks">
        {
          tasks.map((task, index) => (
            <li class="drill-task">
              <div class="drill-task__header">
                <p class="drill-task__description">{task.task}</p>
                {task.validation && (
                  <span
                    class="task-validation-badge task-validation-badge--not-run"
                    data-task-validation-badge={index}
                    aria-label="Not checked"
                  >
                    ○
                  </span>
                )}
              </div>
              {task.validation && (
                <p
                  class="drill-task__validation-error"
                  data-task-validation-error={index}
                  hidden
                />
              )}
              <details class="drill-task__solution">
                <summary>{t('drills_solution')}</summary>
                {task.instructionMarkdown && (
                  <p class="drill-task__explanation">
                    {task.instructionMarkdown}
                  </p>
                )}
                <p class="drill-task__explanation">{task.explanation}</p>
                <div class="drill-task__commands">
                  {Array.isArray(task.command) ? (
                    task.command.map((cmd) => (
                      <pre class="drill-task__code">
                        <code>{cmd}</code>
                      </pre>
                    ))
                  ) : (
                    <pre class="drill-task__code">
                      <code>{task.command}</code>
                    </pre>
                  )}
                </div>
              </details>
            </li>
          ))
        }
      </ol>
    </article>

    <div class="lp__drill-complete">
      <div class="lp__drill-done-wrap" data-drill-target-id={drillId}>
        <Button
          type="button"
          variant="solid"
          color="cyan"
          size="md"
          data-drill-done-button
        >
          {t('drills_doneButton')}
        </Button>
        <div class="lp__drill-post-actions" data-drill-post-actions hidden>
          <Button href={drillBackHref} variant="subtle" color="gray" size="sm">
            {t('drillComplete_backToDrills')}
          </Button>
          <Button href={retryHref} variant="solid" color="cyan" size="sm">
            Do another
          </Button>
        </div>
      </div>
    </div>

    <DrillValidations tasks={tasks} />
  </ContentWithTerminalLayout>
</Layout>

<script>
  import { sendProgressCompleteBeacon } from '../../../../lib/progress/sendProgressBeacon'

  function initDrillDoneFlow() {
    const wrap = document.querySelector<HTMLElement>('.lp__drill-done-wrap')
    const targetId = wrap?.dataset.drillTargetId
    const doneBtn = wrap?.querySelector<HTMLButtonElement>(
      '[data-drill-done-button]'
    )
    const postActions = wrap?.querySelector<HTMLElement>(
      '[data-drill-post-actions]'
    )
    if (
      !wrap ||
      !targetId ||
      !doneBtn ||
      !postActions ||
      wrap.dataset.progressBeaconBound === 'true'
    ) {
      return
    }
    wrap.dataset.progressBeaconBound = 'true'

    doneBtn.addEventListener(
      'click',
      () => {
        const onValidationComplete = (event: Event) => {
          const detail = (event as CustomEvent<{ allPassed?: boolean }>).detail
          if (!detail?.allPassed) {
            doneBtn.disabled = false
            return
          }
          sendProgressCompleteBeacon({ type: 'drill', targetId })
          const elapsedMs =
            (window as { __drillElapsedMs?: number }).__drillElapsedMs ?? 0
          const elapsedSec = Math.max(0, Math.round(elapsedMs / 1000))
          const bestKey = `drillBestSeconds:${targetId}`
          const previousRaw = localStorage.getItem(bestKey)
          const previous =
            previousRaw != null && Number.isFinite(Number(previousRaw))
              ? Number(previousRaw)
              : null
          if (previous == null || elapsedSec < previous) {
            localStorage.setItem(bestKey, String(elapsedSec))
          }
          doneBtn.hidden = true
          postActions.hidden = false
          doneBtn.disabled = false
        }
        document.addEventListener(
          'drill-validations:complete',
          onValidationComplete as EventListener,
          { once: true }
        )
        doneBtn.disabled = true
        document.dispatchEvent(new CustomEvent('drill-validations:run'))
      },
      true
    )
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDrillDoneFlow)
  } else {
    initDrillDoneFlow()
  }

  document.addEventListener('astro:page-load', initDrillDoneFlow)
</script>

<script>
  declare global {
    interface Window {
      __drillElapsedMs?: number
    }
  }

  const TIMER_INTERVAL_MS = 500

  function formatMs(ms: number): string {
    const totalSec = Math.floor(ms / 1000)
    const m = Math.floor(totalSec / 60)
    const s = totalSec % 60
    return `${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`
  }

  function initDrillTimer() {
    const display = document.querySelector<HTMLElement>(
      '[data-drill-timer-display]'
    )
    if (!display || display.dataset.drillTimerBound === 'true') {
      return
    }
    display.dataset.drillTimerBound = 'true'
    const start = performance.now()
    const tick = () => {
      const elapsed = performance.now() - start
      window.__drillElapsedMs = elapsed
      display.textContent = formatMs(elapsed)
    }
    tick()
    window.setInterval(tick, TIMER_INTERVAL_MS)
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initDrillTimer()
    })
  } else {
    initDrillTimer()
  }

  document.addEventListener('astro:page-load', () => {
    initDrillTimer()
  })
</script>

<style>
  .drill-back-link {
    color: var(--color-gray-11);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    margin-right: auto;
  }

  .drill-back-link:hover {
    color: var(--color-gray-12);
    text-decoration: underline;
  }

  .drill-timer-bar {
    justify-content: flex-start;
    padding-block: var(--spacing-6);
    padding-inline: var(--spacing-4);
  }

  .drill-timer-bar__timer {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .drill-section-label {
    margin: 0 0 0.9rem;
  }

  .drill-tasks {
    list-style: decimal;
    padding-left: 1.5rem;
    margin: 0;
  }

  .drill-task {
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-gray-4);
  }

  .drill-task:last-child {
    border-bottom: none;
  }

  .drill-task__description {
    margin: 0 0 0.35rem;
    flex: 1;
  }

  .drill-task__solution {
    margin-top: 0.5rem;
  }

  .drill-task__solution summary {
    cursor: pointer;
    user-select: none;
    color: var(--color-gray-10);
    font-size: var(--text-sm);
    font-weight: 400;
  }

  .drill-task__explanation {
    margin: 0.5rem 0 0.375rem;
  }

  .drill-task__solution[open] summary {
    color: var(--color-gray-11);
  }

  [data-drill-mode='exam'] .drill-task__solution {
    display: none;
  }

  .lp__drill-post-actions {
    margin-top: 0.75rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .drill-task__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .drill-task__header .drill-task__description {
    flex: 1;
    margin: 0 0 0.35rem;
  }

  .task-validation-badge {
    flex-shrink: 0;
    font-size: 1rem;
    line-height: 1;
    margin-top: 0.1rem;
    font-family: var(--font-mono);
    transition: color 0.15s ease;
  }

  .task-validation-badge--not-run {
    color: var(--color-gray-8);
  }

  .task-validation-badge--running {
    color: var(--color-amber-9);
  }

  .task-validation-badge--pass {
    color: var(--color-green-10);
  }

  .task-validation-badge--fail {
    color: var(--color-ruby-10);
  }

  .drill-task__commands {
    padding-top: 0.5rem;
  }

  .drill-task__commands :global(pre) {
    margin: 0;
    border-radius: var(--radius-2);
    font-size: var(--text-sm);
  }

  .drill-task__code {
    background: var(--color-gray-2);
    border: 1px solid var(--color-gray-5);
    padding: 0.55rem 0.7rem;
    overflow-x: auto;
  }

  .drill-task__code code {
    font-family: var(--font-mono);
    white-space: pre;
  }

  .drill-task__validation-error {
    margin: 0 0 0.35rem 0;
    padding: 0.3rem 0.5rem;
    background: color-mix(in srgb, var(--color-ruby-3) 60%, transparent);
    border-left: 2px solid var(--color-ruby-7);
    border-radius: 0 var(--radius-1) var(--radius-1) 0;
    color: var(--color-ruby-11);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
  }
</style>
