---
import Layout from '../../../../layouts/Layout.astro'
import ContentWithTerminalLayout from '../../../../components/lesson/ContentWithTerminalLayout.astro'
import Button from '../../../../components/ui/Button.astro'
import { Code } from 'astro-expressive-code/components'
import { useLocalePath, useTranslations } from '../../../../i18n/utils'
import { getDrillDetail } from '../../../../content/drills/facade'
import { getCourseOverview } from '../../../../content/overview/facade'
import { getLayoutAuthContext } from '../../../../lib/auth/server'
import { getProgressContext } from '../../../../lib/progress/server'
import { getFirstNonPlaceholderLessonIdFromSections } from '../../../../lib/courses/lessonTerminalAccess'
import '../../../../styles/components/lesson-content.css'
import '../../../../styles/components/cluster-visualization.css'

const lang = Astro.params.lang as 'en' | 'fr'
const drillId = Astro.params.drillId!
const localePath = useLocalePath(lang)
const t = useTranslations(lang)

const modeRaw = Astro.url.searchParams.get('mode')
const runMode =
  modeRaw === 'guided' || modeRaw === 'exam' ? modeRaw : null

const { userId } = await getProgressContext(
  Astro.locals,
  Astro.request,
  Astro.cookies
)
const auth = await getLayoutAuthContext(
  Astro.locals,
  Astro.request,
  Astro.cookies
)

const isDemoDrill = drillId === 'intro-kubernetes'
if (!userId && !isDemoDrill) {
  return Astro.redirect(
    localePath('/auth') + '?redirect=' + encodeURIComponent(Astro.url.pathname)
  )
}

const drillDetail = getDrillDetail(drillId, lang)
if (!drillDetail) {
  return Astro.redirect(localePath('/drills'))
}

const withMode = (path: string) =>
  runMode === null ? path : `${path}${path.includes('?') ? '&' : '?'}mode=${runMode}`

const env = drillDetail.environment?.trim().toLowerCase()
const seedName = env && env !== 'empty' ? env : 'minimal'

const drillCompleteHref = withMode(localePath(`/drills/${drillId}/complete`))

const contentBarLabels = {
  labelVisualizer: t('lesson_visualizer'),
  labelCourse: t('lesson_viewCourse'),
  labelShowTerminal: t('lesson_showTerminal'),
  labelHideTerminal: t('lesson_hideTerminal'),
  labelContactSupport: t('lesson_contactSupport'),
  labelReloadTerminal: t('lesson_reloadTerminal')
}

const terminalInteractive = isDemoDrill || auth.hasPaidSubscription
const crashOverview = getCourseOverview('crash-course', lang)
const crashFirstLessonId = crashOverview
  ? getFirstNonPlaceholderLessonIdFromSections(crashOverview.content.sections)
  : null
const terminalLockCrashCourseHref = crashFirstLessonId
  ? localePath(`/courses/crash-course/${crashFirstLessonId}`)
  : localePath('/courses')
const terminalLockPrimaryHref = localePath('/pricing')
const terminalLockPrimaryLabel = t('lesson_terminalLock_ctaUpgrade')
const terminalLockSecondaryHref = terminalLockCrashCourseHref
const terminalLockSecondaryLabel = t('lesson_terminalLock_tryFreeCrashCourse')
const drillBackHref = localePath('/drills')

const guidedHref = `${localePath(`/drills/${drillId}`)}?mode=guided`
const examHref = `${localePath(`/drills/${drillId}`)}?mode=exam`
const kubernetesDocsUrl = 'https://kubernetes.io/docs/home/'

const tasks = drillDetail.tasks
---

{
  runMode === null && (
    <Layout>
      <main class="drill-mode-choice">
        <h1>{drillDetail.title}</h1>
        <p class="drill-mode-choice__hint">{t('drills_mode_title')}</p>
        <div class="drill-mode-choice__actions">
          <Button href={guidedHref} variant="solid" color="cyan" size="md">
            {t('drills_mode_guidedCta')}
          </Button>
          <p class="drill-mode-choice__hint">{t('drills_mode_subGuided')}</p>
          <Button href={examHref} variant="subtle" color="gray" size="md">
            {t('drills_mode_examCta')}
          </Button>
          <p class="drill-mode-choice__hint">{t('drills_mode_subExam')}</p>
        </div>
      </main>
    </Layout>
  )
}
{
  runMode !== null && (
    <Layout bodyClass="lp-fill navbar-app" showFooter={false}>
      <ContentWithTerminalLayout
        seedName={seedName}
        lang={lang}
        showSidebar={false}
        labels={contentBarLabels}
        supportContextId={`drills/${drillId}`}
        terminalInteractive={terminalInteractive}
        terminalLockTitle={t('lesson_terminalLock_title')}
        terminalLockBody={t('lesson_terminalLock_body')}
        terminalLockPrimaryLabel={terminalLockPrimaryLabel}
        terminalLockPrimaryHref={terminalLockPrimaryHref}
        terminalLockSecondaryLabel={terminalLockSecondaryLabel}
        terminalLockSecondaryHref={terminalLockSecondaryHref}
        terminalDocsHref={kubernetesDocsUrl}
        terminalDocsTabLabel="Docs"
        terminalShellTabLabel="Terminal"
      >
        <div
          class="drill-timer-bar"
          data-drill-timer-wrap
          aria-live="polite"
        >
          <a class="drill-back-link" href={drillBackHref}>
            ← {t('drillComplete_backToDrills')}
          </a>
          <span class="drill-timer-bar__timer">
            <span>{t('drills_timer_label')}</span>
            <span class="drill-timer-bar__value" data-drill-timer-display>
              00:00
            </span>
          </span>
        </div>

        <article class="lesson-content" data-drill-mode={runMode}>
          <p class="drill-section-label">{t('drills_tasks')}</p>
          <ol class="drill-tasks">
            {tasks.map((task) => (
              <li class="drill-task">
                <p class="drill-task__description">{task.task}</p>
                <details class="drill-task__solution">
                  <summary>{t('drills_solution')}</summary>
                  <p class="drill-task__explanation">{task.explanation}</p>
                  <Code code={task.command} lang="bash" />
                </details>
              </li>
            ))}
          </ol>
        </article>

        <div class="lp__drill-complete">
          {isDemoDrill && !userId ? (
            <Button
              href={localePath('/pricing')}
              variant="solid"
              color="cyan"
              size="md"
            >
              {t('home_cta_join')}
            </Button>
          ) : (
            <span
              class="lp__drill-done-wrap"
              data-drill-target-id={drillId}
            >
              <Button
                href={drillCompleteHref}
                variant="solid"
                color="cyan"
                size="md"
              >
                {t('drills_doneButton')}
              </Button>
            </span>
          )}
        </div>
      </ContentWithTerminalLayout>
    </Layout>
  )
}

<script>
  import { sendProgressCompleteBeacon } from '../../../../lib/progress/sendProgressBeacon'

  function initDrillDoneBeacon() {
    const wrap = document.querySelector<HTMLElement>('.lp__drill-done-wrap')
    const targetId = wrap?.dataset.drillTargetId
    if (!wrap || !targetId || wrap.dataset.progressBeaconBound === 'true') {
      return
    }
    wrap.dataset.progressBeaconBound = 'true'

    wrap.addEventListener(
      'click',
      () => {
        sendProgressCompleteBeacon({ type: 'drill', targetId })
      },
      true
    )
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDrillDoneBeacon)
  } else {
    initDrillDoneBeacon()
  }

  document.addEventListener('astro:page-load', initDrillDoneBeacon)
</script>

<script>
  declare global {
    interface Window {
      __drillElapsedMs?: number
    }
  }

  const TIMER_INTERVAL_MS = 500

  function formatMs(ms: number): string {
    const totalSec = Math.floor(ms / 1000)
    const m = Math.floor(totalSec / 60)
    const s = totalSec % 60
    return `${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`
  }

  function initDrillTimer() {
    const display = document.querySelector<HTMLElement>(
      '[data-drill-timer-display]'
    )
    if (!display || display.dataset.drillTimerBound === 'true') {
      return
    }
    display.dataset.drillTimerBound = 'true'
    const start = performance.now()
    const tick = () => {
      const elapsed = performance.now() - start
      window.__drillElapsedMs = elapsed
      display.textContent = formatMs(elapsed)
    }
    tick()
    window.setInterval(tick, TIMER_INTERVAL_MS)
  }

  function persistElapsedBeforeComplete() {
    const wrap = document.querySelector<HTMLElement>('.lp__drill-done-wrap')
    const link = wrap?.querySelector<HTMLAnchorElement>('a[href*="complete"]')
    const targetId = wrap?.dataset.drillTargetId
    if (!link || !targetId || link.dataset.drillTimeBound === 'true') {
      return
    }
    link.dataset.drillTimeBound = 'true'
    link.addEventListener('click', () => {
      const ms = window.__drillElapsedMs ?? 0
      sessionStorage.setItem(`drillElapsed:${targetId}`, String(Math.round(ms)))
    })
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initDrillTimer()
      persistElapsedBeforeComplete()
    })
  } else {
    initDrillTimer()
    persistElapsedBeforeComplete()
  }

  document.addEventListener('astro:page-load', () => {
    initDrillTimer()
    persistElapsedBeforeComplete()
  })
</script>

<style>
  .drill-mode-choice {
    max-width: 480px;
    margin: 6rem auto;
    padding: 0 1rem;
    text-align: center;
  }

  .drill-mode-choice h1 {
    font-size: 1.5rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-12);
    margin: 0 0 0.5rem;
  }

  .drill-mode-choice__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  .drill-mode-choice__hint {
    color: var(--color-gray-10);
    font-size: var(--text-sm);
    margin: 0;
  }

  .drill-back-link {
    color: var(--color-gray-11);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    margin-right: auto;
  }

  .drill-back-link:hover {
    color: var(--color-gray-12);
    text-decoration: underline;
  }

  .drill-timer-bar {
    justify-content: flex-start;
    padding-block: var(--spacing-6);
    padding-inline: var(--spacing-4);
  }

  .drill-timer-bar__timer {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .drill-section-label {
    margin: 0 0 0.9rem;
  }

  .drill-tasks {
    list-style: decimal;
    padding-left: 1.5rem;
    margin: 0;
  }

  .drill-task {
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-gray-4);
  }

  .drill-task:last-child {
    border-bottom: none;
  }

  .drill-task__description {
    margin: 0 0 0.35rem;
  }

  .drill-task__solution {
    margin-top: 0.5rem;
  }

  .drill-task__solution summary {
    cursor: pointer;
    user-select: none;
    color: var(--color-gray-10);
    font-size: var(--text-sm);
    font-weight: 400;
  }

  .drill-task__explanation {
    margin: 0.5rem 0 0.375rem;
  }

  .drill-task__solution[open] summary {
    color: var(--color-gray-11);
  }

  [data-drill-mode='exam'] .drill-task__solution {
    display: none;
  }
</style>
