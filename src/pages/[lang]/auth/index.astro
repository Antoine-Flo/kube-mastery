---
import Layout from '../../../layouts/Layout.astro'

import Button from '../../../components/ui/Button.astro'
import { useTranslations, useLocalePath } from '../../../i18n/utils'
import { getSupabaseServer } from '../../../lib/supabase'

const lang = (Astro.params.lang || 'en') as 'en' | 'fr'
const t = useTranslations(lang)
const localePath = useLocalePath(lang)

const rawRedirect = Astro.url.searchParams.get('redirect') ?? ''
const redirect =
  rawRedirect.startsWith('/') && !rawRedirect.includes('//') ? rawRedirect : ''

const authError = Astro.url.searchParams.get('auth_error') === '1'
const authErrorMessageKey = Astro.url.searchParams.get('message_key') ?? ''
const authErrorMessageRaw = Astro.url.searchParams.get('message') ?? ''
const authErrorMessage = authErrorMessageKey
  ? t(authErrorMessageKey)
  : authErrorMessageRaw

try {
  const supabase = getSupabaseServer(Astro.locals, Astro.request, Astro.cookies)
  const {
    data: { user }
  } = await supabase.auth.getUser()
  if (user) {
    return Astro.redirect(redirect || localePath('/courses'))
  }
} catch {
  // Missing Supabase env or other error → show login page
}
---

<Layout>
  <div class="auth">
    <h1 class="auth__title">{t('auth_loginTitle')}</h1>

    {
      authError && authErrorMessage && (
        <div class="auth__error" role="alert">
          <strong>{t('auth_oauthErrorTitle')}</strong>
          <p>{authErrorMessage}</p>
        </div>
      )
    }

    <div class="auth__card-body">
      <div id="auth-providers" class="auth__buttons">
        <form
          action="/api/auth/signin"
          method="post"
          class="auth__provider-form"
          data-astro-reload
        >
          <input type="hidden" name="provider" value="github" />
          <input type="hidden" name="lang" value={lang} />
          <input type="hidden" name="redirect" value={redirect} />
          <Button
            type="submit"
            variant="outline"
            size="lg"
            class="auth__provider-button auth__provider-button--github"
          >
            <span class="auth__provider-btn-inner">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                ><path
                  d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
                ></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
              >
              {t('auth_continueWithGitHub')}
            </span>
          </Button>
        </form>
        <div id="auth-show-email">
          <Button
            type="button"
            variant="outline"
            size="lg"
            class="auth__provider-button auth__provider-button--mail"
          >
            <span class="auth__provider-btn-inner">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                ><rect width="20" height="16" x="2" y="4" rx="2"></rect><path
                  d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
              >
              {t('auth_continueWithMail')}
            </span>
          </Button>
        </div>
      </div>

      <div id="auth-email-form" class="auth__form-wrapper" hidden>
        <form
          id="auth-form-magic"
          class="auth__form"
          action="/api/auth/signin"
          method="post"
          data-astro-reload
        >
          <input type="hidden" name="magic" value="1" />
          <input type="hidden" name="lang" value={lang} />
          <input type="hidden" name="redirect" value={redirect} />
          <div class="auth__field">
            <label for="auth-email-magic" class="auth__label"
              >{t('auth_email')}</label
            >
            <input
              type="email"
              id="auth-email-magic"
              name="email"
              placeholder="email@example.com"
              required
              class="auth__input"
            />
          </div>
          <Button
            type="submit"
            variant="solid"
            size="lg"
            class="auth__submit-button"
          >
            {t('auth_sendLoginLink')}
          </Button>
        </form>

        <button type="button" class="auth__back" id="auth-back">
          ← {t('auth_back')}
        </button>
      </div>
    </div>
  </div>
</Layout>

<style>
  .auth {
    max-width: 370px;
    width: 100%;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .auth__title {
    font-size: 1.5rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-12);
    text-align: center;
    margin-bottom: 1rem;
  }

  .auth__form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
  }

  .auth__error {
    padding: var(--spacing-3);
    margin-bottom: var(--spacing-4);
    border-radius: var(--radius-md);
    background-color: var(--color-ruby-3);
    color: var(--color-ruby-11);
    font-size: var(--text-sm);
  }

  .auth__error p {
    margin: 0.25rem 0 0;
  }

  .auth__card-body {
    padding-top: var(--spacing-6);
  }

  .auth__buttons {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
  }

  .auth__provider-form {
    width: 100%;
  }

  .auth__form-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
  }

  .auth__segment {
    display: flex;
    gap: 0;
    border-radius: var(--radius-md);
    background-color: var(--color-gray-3);
    padding: 2px;
  }

  .auth__segment-btn {
    flex: 1;
    padding: var(--spacing-2) var(--spacing-3);
    border: none;
    border-radius: var(--radius-sm);
    background: transparent;
    font-size: var(--text-sm);
    color: var(--color-gray-11);
    cursor: pointer;
  }

  .auth__segment-btn--active {
    background-color: var(--color-gray-1);
    color: var(--color-gray-12);
  }

  .auth__field {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-1);
  }

  .auth__label {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-gray-11);
  }

  .auth__input {
    padding: var(--spacing-2) var(--spacing-3);
    border: 1px solid var(--color-gray-6);
    border-radius: var(--radius-md);
    font-size: var(--text-base);
  }

  .auth__input:focus {
    outline: none;
    border-color: var(--color-cyan-8);
  }

  .auth__provider-button {
    width: 100%;
  }

  .auth__provider-button .auth__provider-btn-inner {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-2);
  }

  .auth__provider-button--github {
    background-color: var(--color-gray-3);
  }

  .auth__provider-button--github:hover {
    background-color: var(--color-gray-4);
  }

  .auth__provider-button--mail {
    background-color: var(--color-gray-2);
  }

  .auth__provider-button--mail:hover {
    background-color: var(--color-gray-3);
  }

  .auth__submit-button {
    width: 100%;
    margin-top: var(--spacing-2);
  }

  .auth__back {
    display: block;
    width: 100%;
    padding: var(--spacing-2);
    background: none;
    border: none;
    font-size: var(--text-sm);
    color: var(--color-gray-10);
    cursor: pointer;
    text-align: center;
  }

  .auth__back:hover {
    color: var(--color-gray-12);
  }
</style>

<script>
  const providers = document.getElementById('auth-providers')
  const emailForm = document.getElementById('auth-email-form')
  const showEmailBtn = document.getElementById('auth-show-email')
  const backBtn = document.getElementById('auth-back')

  showEmailBtn?.addEventListener('click', () => {
    providers?.setAttribute('hidden', '')
    emailForm?.removeAttribute('hidden')
  })

  backBtn?.addEventListener('click', () => {
    emailForm?.setAttribute('hidden', '')
    providers?.removeAttribute('hidden')
  })
</script>
