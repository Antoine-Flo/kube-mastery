---
import Layout from '../../../layouts/Layout.astro'

import Button from '../../../components/ui/Button.astro'
import { useTranslations, useLocalePath } from '../../../i18n/utils'
import { getSupabaseServer } from '../../../lib/supabase'
import '../../../styles/components/card.css'
import '../../../styles/components/page-halo.css'

const lang = (Astro.params.lang || 'en') as 'en' | 'fr'
const t = useTranslations(lang)
const localePath = useLocalePath(lang)

const rawRedirect = Astro.url.searchParams.get('redirect') ?? ''
const redirect =
  rawRedirect.startsWith('/') && !rawRedirect.includes('//') ? rawRedirect : ''

const authError = Astro.url.searchParams.get('auth_error') === '1'
const authErrorMessageKey = Astro.url.searchParams.get('message_key') ?? ''
const authErrorMessageRaw = Astro.url.searchParams.get('message') ?? ''
const authErrorMessage = authErrorMessageKey
  ? t(authErrorMessageKey)
  : authErrorMessageRaw

try {
  const supabase = getSupabaseServer(Astro.locals, Astro.request, Astro.cookies)
  const {
    data: { user }
  } = await supabase.auth.getUser()
  if (user) {
    return Astro.redirect(redirect || localePath('/courses'))
  }
} catch {
  // Missing Supabase env or other error → show login page
}
---

<Layout>
  <div class="page-halo">
    <div class="page-halo__bg" aria-hidden="true"></div>
    <div class="auth-page">
      <div class="auth card card--outline">
        <div class="card__header auth__header">
          <h1 class="card__title auth__title">{t('auth_loginTitle')}</h1>
        </div>

      <div class="card__body auth__card-body">
        {
          authError && authErrorMessage && (
            <div class="auth__error" role="alert">
              <strong>{t('auth_oauthErrorTitle')}</strong>
              <p>{authErrorMessage}</p>
            </div>
          )
        }

        <div id="auth-providers" class="auth__buttons">
          <form
            action="/api/auth/signin"
            method="post"
            class="auth__provider-form"
            data-astro-reload
          >
            <input type="hidden" name="provider" value="github" />
            <input type="hidden" name="lang" value={lang} />
            <input type="hidden" name="redirect" value={redirect} />
            <Button
              type="submit"
              variant="outline"
              size="lg"
              class="auth__provider-button auth__provider-button--github"
            >
              <span class="auth__provider-btn-inner">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  ><path
                    d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
                  ></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
                >
                {t('auth_continueWithGitHub')}
              </span>
            </Button>
          </form>

          <div class="auth__divider" aria-hidden="true">
            <span>{t('auth_or')}</span>
          </div>

          <div id="auth-show-email">
            <Button
              type="button"
              variant="outline"
              size="lg"
              class="auth__provider-button auth__provider-button--mail"
            >
              <span class="auth__provider-btn-inner">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  ><rect width="20" height="16" x="2" y="4" rx="2"></rect><path
                    d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
                >
                {t('auth_continueWithMail')}
              </span>
            </Button>
          </div>
        </div>

        <div id="auth-email-form" class="auth__form-wrapper" hidden>
          <form
            id="auth-form-magic"
            class="auth__form"
            action="/api/auth/signin"
            method="post"
            data-astro-reload
          >
            <input type="hidden" name="magic" value="1" />
            <input type="hidden" name="lang" value={lang} />
            <input type="hidden" name="redirect" value={redirect} />
            <div class="auth__field">
              <label for="auth-email-magic" class="auth__label"
                >{t('auth_email')}</label
              >
              <input
                type="email"
                id="auth-email-magic"
                name="email"
                placeholder="email@example.com"
                required
                class="auth__input"
              />
            </div>
            <p class="auth__hint">{t('auth_checkEmail')}</p>
            <Button
              type="submit"
              variant="solid"
              size="lg"
              class="auth__submit-button"
            >
              {t('auth_sendLoginLink')}
            </Button>
          </form>

          <button type="button" class="auth__back" id="auth-back">
            ← {t('auth_back')}
          </button>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .auth-page {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: clamp(2.5rem, 5vw, 5rem) 1.25rem;
  }

  .auth {
    max-width: 440px;
    width: 100%;
    margin: 0 auto;
    backdrop-filter: blur(8px);
  }

  .auth__title {
    font-size: clamp(1.55rem, 1.5rem + 0.35vw, 1.85rem);
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-12);
    text-align: center;
    margin: 0;
  }

  .auth__form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
  }

  .auth__error {
    padding: var(--spacing-3);
    margin-bottom: var(--spacing-5);
    border-radius: var(--radius-md);
    background-color: var(--color-ruby-3);
    color: var(--color-ruby-11);
    font-size: var(--text-sm);
    border: 1px solid color-mix(in srgb, var(--color-ruby-8) 35%, transparent);
  }

  .auth__error p {
    margin: 0.25rem 0 0;
  }

  .auth__card-body {
    gap: var(--spacing-5);
  }

  .auth__header {
    padding-bottom: var(--spacing-4);
  }

  .auth__buttons {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
  }

  .auth__provider-form {
    width: 100%;
  }

  .auth__divider {
    position: relative;
    text-align: center;
    color: var(--color-gray-10);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0.15rem 0;
  }

  .auth__divider::before {
    content: '';
    position: absolute;
    inset: 50% 0 auto 0;
    height: 1px;
    background: var(--color-border);
    z-index: 0;
  }

  .auth__divider span {
    position: relative;
    z-index: 1;
    background: var(--color-palette-gray-surface-bg);
    padding: 0 var(--spacing-2);
  }

  .auth__form-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
    padding: var(--spacing-4);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
  }

  .auth__field {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-1);
  }

  .auth__label {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-gray-11);
  }

  .auth__input {
    padding: var(--spacing-2) var(--spacing-3);
    border: 1px solid var(--color-gray-6);
    border-radius: var(--radius-md);
    font-size: var(--text-base);
    background-color: var(--color-palette-gray-surface-bg);
    transition: border-color 0.2s ease;
  }

  .auth__input:focus {
    outline: none;
    border-color: var(--color-cyan-8);
  }

  .auth__provider-button {
    width: 100%;
    min-height: 2.75rem;
  }

  .auth__provider-button .auth__provider-btn-inner {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-2);
  }

  .auth__provider-button--github {
    background-color: color-mix(
      in srgb,
      var(--color-palette-gray-subtle-bg) 90%,
      transparent
    );
  }

  .auth__provider-button--github:hover {
    background-color: color-mix(
      in srgb,
      var(--color-palette-gray-subtle-bg) 65%,
      var(--color-cyan-3)
    );
  }

  .auth__provider-button--mail {
    background-color: color-mix(
      in srgb,
      var(--color-cyan-3) 50%,
      var(--color-palette-gray-surface-bg)
    );
  }

  .auth__provider-button--mail:hover {
    background-color: color-mix(
      in srgb,
      var(--color-cyan-4) 60%,
      var(--color-palette-gray-surface-bg)
    );
  }

  .auth__hint {
    margin: 0;
    color: var(--color-gray-10);
    font-size: var(--text-sm);
    line-height: 1.45;
  }

  .auth__submit-button {
    width: 100%;
    margin-top: var(--spacing-1);
  }

  .auth__back {
    display: block;
    width: 100%;
    padding: var(--spacing-2);
    background: none;
    border: none;
    font-size: var(--text-sm);
    color: var(--color-gray-10);
    cursor: pointer;
    text-align: center;
  }

  .auth__back:hover {
    color: var(--color-gray-12);
  }

  @media (max-width: 520px) {
    .auth-page {
      padding-top: 1.75rem;
      padding-bottom: 2.5rem;
    }

    .auth__form-wrapper {
      padding: var(--spacing-3);
    }
  }
</style>

<script>
  const providers = document.getElementById('auth-providers')
  const emailForm = document.getElementById('auth-email-form')
  const showEmailBtn = document.getElementById('auth-show-email')
  const backBtn = document.getElementById('auth-back')

  showEmailBtn?.addEventListener('click', () => {
    providers?.setAttribute('hidden', '')
    emailForm?.removeAttribute('hidden')
  })

  backBtn?.addEventListener('click', () => {
    emailForm?.setAttribute('hidden', '')
    providers?.removeAttribute('hidden')
  })
</script>
