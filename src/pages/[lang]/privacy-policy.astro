---
import Layout from "../../layouts/Layout.astro";
import { useTranslations } from "../../i18n/utils";

const locale = Astro.params.lang as "en" | "fr";
const t = useTranslations(locale);
---

<Layout>
	<div class="doc">
		<h1>{t("privacyPolicy_title")}</h1>
		<p class="meta">{t("privacyPolicy_lastUpdated")}</p>
		<p class="lead">{t("privacyPolicy_intro")}</p>

		<section>
			<h2>{t("privacyPolicy_collection_title")}</h2>
			<p set:html={t("privacyPolicy_collection_content")} />
		</section>
		<section>
			<h2>{t("privacyPolicy_use_title")}</h2>
			<p set:html={t("privacyPolicy_use_content")} />
		</section>
		<section>
			<h2>{t("privacyPolicy_security_title")}</h2>
			<p set:html={t("privacyPolicy_security_content")} />
		</section>
		<section>
			<h2>{t("privacyPolicy_storage_title")}</h2>
			<p set:html={t("privacyPolicy_storage_content")} />
		</section>
		<section>
			<h2>{t("privacyPolicy_sharing_title")}</h2>
			<p set:html={t("privacyPolicy_sharing_content")} />
		</section>
		<section>
			<h2>{t("privacyPolicy_rights_title")}</h2>
			<p set:html={t("privacyPolicy_rights_content")} />
		</section>
		<section>
			<h2>{t("privacyPolicy_retention_title")}</h2>
			<p set:html={t("privacyPolicy_retention_content")} />
		</section>
		<section>
			<h2>{t("privacyPolicy_changes_title")}</h2>
			<p set:html={t("privacyPolicy_changes_content")} />
		</section>
		<section>
			<h2>{t("privacyPolicy_contact_title")}</h2>
			<p set:html={t("privacyPolicy_contact_content")} />
		</section>
	</div>
</Layout>

<style>
	.doc {
		max-width: 800px;
		margin: 0 auto;
		padding: 4rem 2rem;
	}
	.doc h1 {
		font-size: 1.875rem;
		font-weight: var(--font-weight-bold);
		color: var(--color-gray-12);
		margin-bottom: 2rem;
	}
	.meta {
		color: var(--color-gray-9);
		font-size: 0.875rem;
		margin-bottom: 1.5rem;
	}
	.lead {
		color: var(--color-gray-11);
		line-height: 1.6;
		margin-bottom: 2rem;
		font-size: 1.125rem;
	}
	.doc section {
		margin-bottom: 2.5rem;
	}
	.doc section h2 {
		font-size: 1.25rem;
		font-weight: var(--font-weight-semibold);
		color: var(--color-gray-12);
		margin-bottom: 1rem;
	}
	.doc section p {
		color: var(--color-gray-11);
		line-height: 1.7;
		margin-bottom: 0;
	}
</style>
