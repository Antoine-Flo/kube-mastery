---
import Layout from "../../layouts/Layout.astro";
import { useTranslations } from "../../i18n/utils.js";

export function getStaticPaths() {
	return [
		{ params: { lang: "en" } },
		{ params: { lang: "fr" } },
	];
}

const locale = Astro.params.lang as "en" | "fr";
const t = useTranslations(locale);
---
<Layout>
	<div class="doc">
		<h1>{t("termsOfService_title")}</h1>
		<p class="meta">{t("termsOfService_lastUpdated")}</p>
		<p class="lead">{t("termsOfService_intro")}</p>

		<section>
			<h2>{t("termsOfService_acceptance_title")}</h2>
			<p set:html={t("termsOfService_acceptance_content")} />
		</section>
		<section>
			<h2>{t("termsOfService_description_title")}</h2>
			<p set:html={t("termsOfService_description_content")} />
		</section>
		<section>
			<h2>{t("termsOfService_account_title")}</h2>
			<p set:html={t("termsOfService_account_content")} />
		</section>
		<section>
			<h2>{t("termsOfService_use_title")}</h2>
			<p set:html={t("termsOfService_use_content")} />
		</section>
		<section>
			<h2>{t("termsOfService_intellectual_title")}</h2>
			<p set:html={t("termsOfService_intellectual_content")} />
		</section>
		<section>
			<h2>{t("termsOfService_limitation_title")}</h2>
			<p set:html={t("termsOfService_limitation_content")} />
		</section>
		<section>
			<h2>{t("termsOfService_changes_title")}</h2>
			<p set:html={t("termsOfService_changes_content")} />
		</section>
		<section>
			<h2>{t("termsOfService_contact_title")}</h2>
			<p set:html={t("termsOfService_contact_content")} />
		</section>
	</div>
</Layout>

<style>
	.doc {
		max-width: 800px;
		margin: 0 auto;
		padding: 4rem 2rem;
	}
	.doc h1 {
		font-size: 1.875rem;
		font-weight: var(--font-weight-bold);
		color: var(--color-gray-12);
		margin-bottom: 2rem;
	}
	.meta {
		color: var(--color-gray-9);
		font-size: 0.875rem;
		margin-bottom: 1.5rem;
	}
	.lead {
		color: var(--color-gray-11);
		line-height: 1.6;
		margin-bottom: 2rem;
		font-size: 1.125rem;
	}
	.doc section {
		margin-bottom: 2.5rem;
	}
	.doc section h2 {
		font-size: 1.25rem;
		font-weight: var(--font-weight-semibold);
		color: var(--color-gray-12);
		margin-bottom: 1rem;
	}
	.doc section p {
		color: var(--color-gray-11);
		line-height: 1.7;
		margin-bottom: 0;
	}
</style>
