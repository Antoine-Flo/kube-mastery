---
import Layout from "../../layouts/Layout.astro";
import Button from "../../components/ui/Button.astro";
import { Zap, Shield, Euro, FileCheck, BookOpen, Code, CheckCircle2 } from "@lucide/astro";
import { useTranslations, useLocalePath } from "../../i18n/utils.js";

export function getStaticPaths() {
	return [
		{ params: { lang: "en" } },
		{ params: { lang: "fr" } },
	];
}

const locale = Astro.params.lang as "en" | "fr";
const t = useTranslations(locale);
const localePath = useLocalePath(locale);
---
<Layout>
	<main>
		<section class="hero">
			<div class="content">
				<div class="left">
					<h1>{t("home_title")}</h1>
					<p class="sub">{t("home_subtitle")}</p>
					<div class="cta">
						<Button href={localePath("/courses")} variant="solid" color="cyan" size="lg" sublabel={t("home_freeCourse")}>
							{t("home_startNow")}
						</Button>
					</div>
				</div>
			</div>
		</section>

		<div class="features">
			<div class="content">
				<h2 class="anim">{t("home_features_title")}</h2>
				<p class="anim">{t("home_features_subtitle")}</p>
				<div class="grid">
					<div class="card anim">
						<Zap size={32} class="icon a" />
						<h3>{t("home_features_speed_title")}</h3>
						<p>{t("home_features_speed_description")}</p>
					</div>
					<div class="card anim">
						<Shield size={32} class="icon c" />
						<h3>{t("home_features_stability_title")}</h3>
						<p>{t("home_features_stability_description")}</p>
					</div>
					<div class="card anim">
						<Euro size={32} class="icon p" />
						<h3>{t("home_features_price_title")}</h3>
						<p>{t("home_features_price_description")}</p>
					</div>
				</div>
			</div>
		</div>

		<div class="concerns">
			<div class="content">
				<h2 class="anim">{t("home_concerns_title")}</h2>
				<p class="anim">{t("home_concerns_subtitle")}</p>
				<div class="items">
					<div class="item anim">
						<FileCheck size={24} class="icon c" />
						<div>
							<h3>{t("home_concerns_openapi_title")}</h3>
							<p set:html={t("home_concerns_openapi_description")} />
						</div>
					</div>
					<div class="item anim">
						<BookOpen size={24} class="icon p" />
						<div>
							<h3>{t("home_concerns_doc_title")}</h3>
							<p set:html={t("home_concerns_doc_description")} />
						</div>
					</div>
					<div class="item anim">
						<Code size={24} class="icon a" />
						<div>
							<h3>{t("home_concerns_code_title")}</h3>
							<p set:html={t("home_concerns_code_description")} />
						</div>
					</div>
					<div class="item anim">
						<CheckCircle2 size={24} class="icon g" />
						<div>
							<h3>{t("home_concerns_comparison_title")}</h3>
							<p set:html={t("home_concerns_comparison_description")} />
						</div>
					</div>
				</div>
			</div>
		</div>

		<div class="stats">
			<h2 class="anim">{t("home_stats_title")}</h2>
			<p class="anim">{t("home_stats_subtitle")}</p>
			<div class="grid">
				<div class="card anim">
					<div class="val">{t("home_stats_adoption_value")}</div>
					<h3>{t("home_stats_adoption_label")}</h3>
					<p>{t("home_stats_adoption_description")}</p>
					<p class="src">{t("home_stats_adoption_source")}</p>
				</div>
				<div class="card anim">
					<div class="val">{t("home_stats_market_value")}</div>
					<h3>{t("home_stats_market_label")}</h3>
					<p>{t("home_stats_market_description")}</p>
					<p class="src">{t("home_stats_market_source")}</p>
				</div>
				<div class="card anim">
					<div class="val">{t("home_stats_companies_value")}</div>
					<h3>{t("home_stats_companies_label")}</h3>
					<p>{t("home_stats_companies_description")}</p>
					<p class="src">{t("home_stats_companies_source")}</p>
				</div>
			</div>
			<div class="cta">
				<Button href={localePath("/courses")} variant="solid" color="cyan" size="md">{t("home_startNow")}</Button>
			</div>
		</div>
	</main>
</Layout>

<style>
	@keyframes fadeInUp {
		from { opacity: 0; transform: translateY(20px); }
		to { opacity: 1; transform: translateY(0); }
	}
	.anim {
		opacity: 0;
		transform: translateY(30px);
		transition: opacity 0.6s ease-out, transform 0.6s ease-out;
	}
	.anim.visible {
		opacity: 1;
		transform: translateY(0);
	}
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
		justify-content: center;
		min-height: 80vh;
		position: relative;
		padding: 4rem 1rem;
		border-bottom: 1px solid var(--color-gray-6);
	}
	.hero .content {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
		width: 100%;
		max-width: 1500px;
	}
	@media (min-width: 1024px) {
		.hero .content { flex-direction: row; align-items: center; gap: 4rem; }
	}
	.left {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
		flex: 1;
	}
	@media (min-width: 1024px) {
		.left { align-items: flex-start; min-width: 0; flex-shrink: 1; }
	}
	.hero h1 {
		font-family: "Zalando Sans SemiExpanded", sans-serif;
		font-optical-sizing: auto;
		font-weight: var(--font-weight-bold);
		color: var(--color-gray-12);
		line-height: 1.2;
		text-align: center;
		flex: 1;
		min-width: 100%;
	}
	@media (min-width: 768px) {
		.hero h1 { font-size: 3.7rem; min-width: auto; }
	}
	@media (min-width: 1024px) {
		.hero h1 { text-align: left; }
	}
	.sub {
		font-size: var(--text-lg);
		color: var(--color-gray-12);
		line-height: 1.6;
		text-align: center;
		max-width: 700px;
		animation: fadeInUp 0.8s ease-out 0.2s both;
	}
	@media (min-width: 768px) {
		.sub { font-size: var(--text-xl); }
	}
	@media (min-width: 1024px) {
		.sub { text-align: left; }
	}
	.cta {
		margin-top: 1rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		position: relative;
		z-index: 1;
		animation: fadeInUp 0.8s ease-out 0.4s both;
	}
	.features {
		width: 100%;
		display: flex;
		flex-direction: column;
		padding: 8rem 0;
		border-top: 1px solid var(--color-gray-6);
		border-bottom: 1px solid var(--color-gray-6);
	}
	.features .content {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	@media (min-width: 768px) {
		.features .content { padding: 0 2rem; }
	}
	.features h2 {
		font-size: 1.5rem;
		font-weight: var(--font-weight-bold);
		color: var(--color-gray-12);
		text-align: center;
	}
	@media (min-width: 768px) {
		.features h2 { font-size: 1.875rem; }
	}
	.features .content > p {
		font-size: var(--text-base);
		color: var(--color-gray-11);
		line-height: 1.6;
		text-align: center;
		max-width: 900px;
		margin: 0 auto;
	}
	@media (min-width: 768px) {
		.features .content > p { font-size: var(--text-lg); }
	}
	.features .grid {
		display: grid;
		margin-top: 2rem;
		grid-template-columns: 1fr;
		gap: 2rem;
		width: 100%;
	}
	@media (min-width: 768px) {
		.features .grid { grid-template-columns: repeat(3, 1fr); }
	}
	.features .card {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.75rem;
		padding: 1.5rem;
		border-radius: var(--radius-lg);
		background-color: var(--color-gray-2);
		border: 1px solid var(--color-gray-6);
	}
	.features .card:nth-child(1) { transition-delay: 0.1s; }
	.features .card:nth-child(2) { transition-delay: 0.2s; }
	.features .card:nth-child(3) { transition-delay: 0.3s; }
	.icon { margin-bottom: 0.5rem; align-self: center; flex-shrink: 0; }
	.icon.a { color: var(--color-amber-9); }
	.icon.c { color: var(--color-cyan-9); }
	.icon.p { color: var(--color-ruby-9); }
	.icon.g { color: var(--color-green-9); }
	.features .card h3 {
		font-size: var(--text-xl);
		font-weight: var(--font-weight-semibold);
		color: var(--color-gray-12);
	}
	.features .card p {
		font-size: var(--text-sm);
		color: var(--color-gray-11);
		line-height: 1.6;
	}
	.concerns {
		width: 100%;
		display: flex;
		flex-direction: column;
		padding: 8rem 0;
		border-top: 1px solid var(--color-gray-6);
		border-bottom: 1px solid var(--color-gray-6);
	}
	.concerns .content {
		max-width: 1000px;
		margin: 0 auto;
		padding: 0 1rem;
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}
	@media (min-width: 768px) {
		.concerns .content { padding: 0 2rem; }
	}
	.concerns h2 {
		font-size: 1.5rem;
		font-weight: var(--font-weight-bold);
		color: var(--color-gray-12);
		text-align: center;
	}
	@media (min-width: 768px) {
		.concerns h2 { font-size: 1.875rem; }
	}
	.concerns .content > p {
		font-size: var(--text-base);
		color: var(--color-gray-11);
		line-height: 1.6;
		text-align: center;
		max-width: 800px;
		margin: 0 auto;
	}
	@media (min-width: 768px) {
		.concerns .content > p { font-size: var(--text-lg); }
	}
	.items {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}
	.item {
		display: flex;
		gap: 1.5rem;
		align-items: flex-start;
	}
	@media (min-width: 768px) {
		.item { gap: 2rem; }
	}
	.item .icon { margin-top: 0.25rem; }
	.item > div {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		flex: 1;
	}
	.item h3 {
		font-size: var(--text-lg);
		font-weight: var(--font-weight-semibold);
		color: var(--color-gray-12);
		line-height: 1.4;
	}
	@media (min-width: 768px) {
		.item h3 { font-size: var(--text-xl); }
	}
	.item p {
		font-size: var(--text-base);
		color: var(--color-gray-11);
		line-height: 1.7;
	}
	@media (min-width: 768px) {
		.item p { font-size: var(--text-lg); }
	}
	.item p :global(strong) {
		font-weight: var(--font-weight-semibold);
		color: var(--color-gray-12);
	}
	.stats {
		width: 100%;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding: 7rem 0;
		border-top: 1px solid var(--color-gray-6);
		border-bottom: 1px solid var(--color-gray-6);
	}
	@media (min-width: 768px) {
		.stats { padding: 8rem 2rem; }
	}
	.stats h2 {
		font-size: 1.5rem;
		font-weight: var(--font-weight-bold);
		color: var(--color-gray-12);
		text-align: center;
	}
	@media (min-width: 768px) {
		.stats h2 { font-size: 1.875rem; }
	}
	.stats > p {
		font-size: var(--text-base);
		color: var(--color-gray-11);
		line-height: 1.6;
		text-align: center;
		max-width: 800px;
		margin: 0 auto;
	}
	@media (min-width: 768px) {
		.stats > p { font-size: var(--text-lg); }
	}
	.stats .grid {
		display: grid;
		padding: 0 2rem;
		max-width: 1200px;
		margin: 2rem auto;
		grid-template-columns: 1fr;
		gap: 1.5rem;
		width: 100%;
	}
	@media (min-width: 768px) {
		.stats .grid { grid-template-columns: repeat(2, 1fr); }
	}
	@media (min-width: 1024px) {
		.stats .grid { grid-template-columns: repeat(3, 1fr); }
	}
	.stats .card {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.75rem;
		padding: 1.5rem;
		border-radius: var(--radius-lg);
		background-color: var(--color-gray-2);
		border: 1px solid var(--color-gray-6);
		text-align: center;
	}
	.stats .card:nth-child(1) { transition-delay: 0.1s; }
	.stats .card:nth-child(2) { transition-delay: 0.2s; }
	.stats .card:nth-child(3) { transition-delay: 0.3s; }
	.val {
		font-size: 2rem;
		font-weight: var(--font-weight-bold);
		color: var(--color-cyan-9);
		line-height: 1.2;
	}
	@media (min-width: 768px) {
		.val { font-size: 2.5rem; }
	}
	.stats .card h3 {
		font-size: var(--text-lg);
		font-weight: var(--font-weight-semibold);
		color: var(--color-gray-12);
	}
	.stats .card p {
		font-size: var(--text-sm);
		color: var(--color-gray-11);
		line-height: 1.6;
	}
	.src {
		font-size: var(--text-xs);
		color: var(--color-gray-9);
		line-height: 1.5;
		margin-top: 0.5rem;
		font-style: italic;
	}
</style>

<script>
	function setupScrollAnim() {
		document.querySelectorAll(".anim").forEach((el) => {
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add("visible");
						}
					});
				},
				{ threshold: 0.1, rootMargin: "0px 0px -50px 0px" }
			);
			observer.observe(el);
		});
	}
	setupScrollAnim();
	document.addEventListener("astro:page-load", setupScrollAnim);
</script>
