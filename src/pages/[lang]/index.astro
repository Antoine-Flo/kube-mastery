---
import Layout from '../../layouts/Layout.astro'
import Button from '../../components/ui/Button.astro'
import Terminal from '../../components/Terminal.astro'
import { Zap, Shield, Euro, CircleCheck, CircleX } from '@lucide/astro'
import { useTranslations, useLocalePath } from '../../i18n/utils'
import { getSupabaseServer } from '../../lib/supabase'
import { readAppEnv } from '../../lib/env'
import { getCourseOverview } from '../../content/overview/facade'
import demoVideo from '../../assets/demo.mp4'
import conformanceImage from '../../assets/conformance.png'
import openapiLogo from '../../assets/openapi_logo.svg'
const locale = Astro.params.lang as 'en' | 'fr'
const t = useTranslations(locale)
const localePath = useLocalePath(locale)
const isEarlyStage =
  (readAppEnv('EARLY_ACCESS', Astro.locals) ?? '').toLowerCase().trim() ===
  'true'
const homeCtaLabel = isEarlyStage
  ? t('home_cta_join_early')
  : t('home_cta_join')

const crashCourseOverview = getCourseOverview('crash-course', locale)
const firstCrashCourseLesson =
  crashCourseOverview?.content.sections
    .flatMap((s) =>
      s.modules.flatMap((m) =>
        m.lessons.filter((l) => !l.isPlaceholder).map((l) => l.id)
      )
    )
    .at(0) ?? null
const homeCtaHref = firstCrashCourseLesson
  ? localePath(`/courses/crash-course/${firstCrashCourseLesson}`)
  : localePath('/courses/crash-course')

try {
  const supabase = getSupabaseServer(Astro.locals, Astro.request, Astro.cookies)
  const {
    data: { user }
  } = await supabase.auth.getUser()
  if (user) {
    return Astro.redirect(localePath('/courses'))
  }
} catch {
  // not logged in, show landing
}
---

<Layout>
  <main class="landing">
    <div class="bg-halo" aria-hidden="true"></div>
    <section class="hero">
      <div class="content">
        <div class="left">
          <div class="hero-text">
            <div class="early-access-badge">
              <span class="badge-dot" aria-hidden="true"></span>
              Early Access
            </div>
            <h1>
              {t('home_title')}
              <span class="start-here">{t('home_title_cta')}</span>
            </h1>
            <p class="sub">{t('home_subtitle')}</p>
          </div>
          <div class="cta">
            <div class="cta-buttons">
              <div class="cta-primary-column">
                <Button
                  href={homeCtaHref}
                  variant="solid"
                  color="cyan"
                  size="xl"
                >
                  {homeCtaLabel}
                </Button>
                <span class="cta-hint">{t('home_cta_no_account')}</span>
              </div>
              <Button
                href={localePath('/pricing')}
                variant="outline"
                color="gray"
                size="xl"
              >
                {t('home_cta_explore')}
              </Button>
            </div>
          </div>
        </div>
        <div class="hero-terminal">
          <Terminal rows={20} lang={locale} />
        </div>
        {
          /* <div class="hero-media">
          <video
            src={demoVideo}
            autoplay
            loop
            muted
            playsinline
            class="hero-demo-video"
            data-playback-rate="1.5"
            aria-label={t('home_subtitle')}></video>
        </div> */
        }
      </div>
    </section>

    <div class="features">
      <div class="content">
        <h2 class="anim">{t('home_features_title')}</h2>
        <p class="anim">{t('home_features_subtitle')}</p>
        <div class="grid">
          <div class="card anim">
            <Zap size={32} class="icon a" />
            <h3>{t('home_features_speed_title')}</h3>
            <p>{t('home_features_speed_description')}</p>
          </div>
          <div class="card anim">
            <Shield size={32} class="icon c" />
            <h3>{t('home_features_stability_title')}</h3>
            <p>{t('home_features_stability_description')}</p>
          </div>
          <div class="card anim">
            <Euro size={32} class="icon p" />
            <h3>{t('home_features_price_title')}</h3>
            <p>{t('home_features_price_description')}</p>
          </div>
        </div>
      </div>
    </div>

    <div class="concerns">
      <div class="content">
        <div class="section-header anim">
          <h2>{t('home_concerns_title')}</h2>
          <p>{t('home_concerns_subtitle')}</p>
        </div>
        <div class="section-body">
          <div class="concern-rows">
            <div class="concern-row anim">
              <div class="text">
                <span class="eyebrow">{t('home_concerns_section1_label')}</span>
                <h3>{t('home_concerns_section1_title')}</h3>
                <p>{t('home_concerns_section1_intro')}</p>
                <ul class="concern-bullets">
                  <li class="concern-bullet">
                    <CircleCheck size={20} class="icon g" />
                    <span>{t('home_concerns_section1_point1')}</span>
                  </li>
                  <li class="concern-bullet">
                    <CircleCheck size={20} class="icon g" />
                    <span>{t('home_concerns_section1_point2')}</span>
                  </li>
                  <li class="concern-bullet">
                    <CircleCheck size={20} class="icon g" />
                    <span>{t('home_concerns_section1_point3')}</span>
                  </li>
                </ul>
              </div>
              <div class="media">
                {
                  /* <img
                  src={astronautTrainingGif.src}
                  alt={t('home_concerns_section1_image_alt')}
                  loading="lazy"
                /> */
                }
                <video
                  src={demoVideo}
                  autoplay
                  loop
                  muted
                  playsinline
                  data-playback-rate="1.5"
                  aria-label={t('home_concerns_section1_image_alt')}></video>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="fit">
      <div class="content">
        <h2 class="fit-title anim">{t('home_fit_title')}</h2>
        <div class="fit-columns anim">
          <div class="fit-col fit-no">
            <div class="fit-col-header">
              <span>{t('home_fit_no_title')}</span>
            </div>
            <ul class="fit-list">
              <li>
                <CircleX size={18} /><span
                  >{t('home_fit_no_1')} (<a
                    href="https://labs.iximiuz.com/tutorials?category=kubernetes"
                    target="_blank"
                    rel="noopener">{t('home_fit_no_1_link')}</a
                  >)</span
                >
              </li>
              <li>
                <CircleX size={18} /><span
                  >{t('home_fit_no_2')} (<a
                    href="https://killer.sh/"
                    target="_blank"
                    rel="noopener">{t('home_fit_no_2_link')}</a
                  >)</span
                >
              </li>
              <li>
                <CircleX size={18} /><span
                  >{t('home_fit_no_3')} (<a
                    href="https://kind.sigs.k8s.io/"
                    target="_blank"
                    rel="noopener">{t('home_fit_no_3_link')}</a
                  >, {t('home_fit_no_3_extra')})</span
                >
              </li>
              <li>
                <CircleX size={18} /><span
                  >{t('home_fit_no_4')} (<a
                    href="https://kodekloud.com/"
                    target="_blank"
                    rel="noopener">{t('home_fit_no_4_link')}</a
                  >)</span
                >
              </li>
            </ul>
          </div>
          <div class="fit-col fit-yes">
            <div class="fit-col-header">
              <span>{t('home_fit_yes_title')}</span>
            </div>
            <ul class="fit-list">
              <li>
                <CircleCheck size={18} /><span>{t('home_fit_yes_1')}</span>
              </li>
              <li>
                <CircleCheck size={18} /><span>{t('home_fit_yes_2')}</span>
              </li>
              <li>
                <CircleCheck size={18} /><span>{t('home_fit_yes_4')}</span>
              </li>
              <li>
                <CircleCheck size={18} />
                <span
                  >{t('home_fit_yes_5')}
                  <!-- <span class="fit-extra">({t('home_fit_yes_5_extra')})</span> "we have special pricing for students and job seekers" -->
                </span>
              </li>
            </ul>
            <div class="cta cta--centered">
              <Button href={homeCtaHref} variant="solid" color="cyan" size="xl">
                {homeCtaLabel}
              </Button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="platform-features">
      <div class="content">
        <div class="section-header anim">
          <h2>{t('home_reliability_title')}</h2>
          <p>{t('home_reliability_subtitle')}</p>
        </div>
        <div class="section-body">
          <div class="feature-rows">
            <div class="feature-row anim">
              <div class="text">
                <h3>{t('home_reliability_conformance_title')}</h3>
                <p>{t('home_reliability_conformance_description')}</p>
              </div>
              <div class="media media-conformance">
                <img
                  src={conformanceImage.src}
                  alt={t('home_reliability_conformance_alt')}
                  loading="lazy"
                />
              </div>
            </div>
            <div class="feature-row reverse anim">
              <div class="text">
                <h3>{t('home_reliability_openapi_title')}</h3>
                <p>{t('home_reliability_openapi_description')}</p>
              </div>
              <div class="media media-openapi">
                <img
                  src={openapiLogo.src}
                  alt={t('home_reliability_openapi_alt')}
                  loading="lazy"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="reliability-cta-wrap">
        <div class="content">
          <div class="reliability-cta anim">
            <div class="cta reliability-cta-actions">
              <div class="cta-stack">
                <p class="reliability-cta-intro">
                  {t('home_reliability_cta_intro')}
                </p>
                <Button
                  href={localePath('/pricing')}
                  variant="solid"
                  color="cyan"
                  size="xl"
                >
                  {t('home_cta_explore')}
                </Button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .landing {
    position: relative;
    overflow: hidden;
  }

  .landing > *:not(.bg-halo) {
    position: relative;
    z-index: 1;
  }

  .bg-halo {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(
          ellipse 34% 48% at 76% 16%,
          hsl(192, 74%, 10%) 0%,
          hsl(192, 74%, 10%) 24%,
          var(--color-gray-1) 100%
        )
        50% 0% / 100% 28% no-repeat,
      radial-gradient(
          ellipse 32% 46% at 26% 50%,
          hsl(192, 74%, 10%) 0%,
          hsl(192, 74%, 10%) 22%,
          var(--color-gray-1) 100%
        )
        50% 50% / 100% 24% no-repeat,
      radial-gradient(
          ellipse 36% 50% at 74% 84%,
          hsl(192, 74%, 10%) 0%,
          hsl(192, 74%, 10%) 24%,
          var(--color-gray-1) 100%
        )
        50% 100% / 100% 24% no-repeat,
      var(--color-gray-1);
  }

  :global([data-theme='light']) .bg-halo {
    background:
      radial-gradient(
          ellipse 34% 48% at 76% 16%,
          hsl(194, 55%, 87%) 0%,
          hsl(194, 55%, 87%) 24%,
          var(--color-gray-1) 100%
        )
        50% 0% / 100% 28% no-repeat,
      radial-gradient(
          ellipse 32% 46% at 26% 50%,
          hsl(194, 55%, 87%) 0%,
          hsl(194, 55%, 87%) 22%,
          var(--color-gray-1) 100%
        )
        50% 50% / 100% 24% no-repeat,
      radial-gradient(
          ellipse 36% 50% at 74% 84%,
          hsl(194, 55%, 87%) 0%,
          hsl(194, 55%, 87%) 24%,
          var(--color-gray-1) 100%
        )
        50% 100% / 100% 24% no-repeat,
      var(--color-gray-1);
  }

  @media (max-width: 768px) {
    .bg-halo {
      background:
        radial-gradient(
          ellipse 58% 24% at 72% 11%,
          hsl(192, 74%, 10%) 0%,
          hsl(192, 74%, 10%) 20%,
          var(--color-gray-1) 100%
        ),
        radial-gradient(
          ellipse 60% 24% at 28% 50%,
          hsl(192, 74%, 10%) 0%,
          hsl(192, 74%, 10%) 19%,
          var(--color-gray-1) 100%
        ),
        radial-gradient(
          ellipse 62% 24% at 70% 89%,
          hsl(192, 74%, 10%) 0%,
          hsl(192, 74%, 10%) 20%,
          var(--color-gray-1) 100%
        ),
        var(--color-gray-1);
    }

    :global([data-theme='light']) .bg-halo {
      background:
        radial-gradient(
          ellipse 58% 24% at 72% 11%,
          hsl(194, 55%, 87%) 0%,
          hsl(194, 55%, 87%) 20%,
          var(--color-gray-1) 100%
        ),
        radial-gradient(
          ellipse 60% 24% at 28% 50%,
          hsl(194, 55%, 87%) 0%,
          hsl(194, 55%, 87%) 19%,
          var(--color-gray-1) 100%
        ),
        radial-gradient(
          ellipse 62% 24% at 70% 89%,
          hsl(194, 55%, 87%) 0%,
          hsl(194, 55%, 87%) 20%,
          var(--color-gray-1) 100%
        ),
        var(--color-gray-1);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .anim {
    opacity: 0;
    transform: translateY(30px);
    transition:
      opacity 0.6s ease-out,
      transform 0.6s ease-out;
  }

  .anim.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    justify-content: center;
    min-height: 830px;
    position: relative;
    padding-block: 3rem;
    padding-inline: 2rem;
  }

  .early-access-badge {
    align-self: center;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35em 0.85em;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--color-cyan-9) 45%, transparent);
    background: color-mix(in srgb, var(--color-cyan-9) 12%, transparent);
    color: var(--color-cyan-11);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.03em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .badge-dot {
    flex-shrink: 0;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-cyan-9);
    box-shadow: 0 0 8px color-mix(in srgb, var(--color-cyan-9) 55%, transparent);
  }

  @media (min-width: 1024px) {
    .early-access-badge {
      align-self: flex-start;
    }
  }

  .hero .content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    width: 100%;
    max-width: var(--content-max-width);
  }
  @media (min-width: 1024px) {
    .hero .content {
      flex-direction: row;
      align-items: center;
      gap: 3rem;
    }
  }

  .left {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    width: 100%;
  }
  @media (min-width: 1024px) {
    .left {
      align-items: flex-start;
      flex: 0 0 auto;
      width: 44%;
    }
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    align-self: stretch;
    width: 100%;
    animation: fadeInUp 0.8s ease-out 0s both;
  }

  .hero h1 {
    font-family: 'Zalando Sans SemiExpanded', sans-serif;
    font-optical-sizing: auto;
    font-size: clamp(2.25rem, 5.5vw, 4.25rem);
    font-weight: var(--font-weight-bold);
    line-height: 1.15;
    text-align: center;
  }
  @media (min-width: 1024px) {
    .hero h1 {
      text-align: left;
    }
  }

  .sub {
    font-size: var(--text-lg);
    color: var(--color-gray-11);
    line-height: 1.6;
    text-align: center;
    animation: fadeInUp 0.8s ease-out 0.2s both;
  }
  @media (min-width: 768px) {
    .sub {
      font-size: var(--text-xl);
    }
  }
  @media (min-width: 1024px) {
    .sub {
      text-align: left;
    }
  }

  .hero h1 {
    color: var(--color-gray-12);
  }

  .start-here {
    color: var(--color-cyan-9);
  }

  .hero-terminal {
    flex: 1;
    min-width: 0;
    width: 100%;
    animation: fadeInUp 0.5s ease-out 0.3s both;
    background-color: var(--color-gray-1);
    border: 1px solid var(--color-gray-6);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .cta {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
    position: relative;
    z-index: 1;
    animation: fadeInUp 0.8s ease-out 0.4s both;
  }

  .cta-buttons {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .cta-primary-column {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .cta-stack {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .cta--centered {
    align-items: center;
  }

  .cta-hint {
    font-size: var(--text-sm);
    color: var(--color-gray-10);
    text-align: center;
  }

  .cta :global(.btn[data-color='cyan'][data-variant='solid']) {
    background: linear-gradient(
      135deg,
      var(--color-cyan-9) 0%,
      var(--color-cyan-7) 100%
    );
  }
  .cta
    :global(.btn[data-color='cyan'][data-variant='solid']):hover:not(
      :disabled
    ) {
    background: linear-gradient(
      135deg,
      var(--color-cyan-10) 0%,
      var(--color-cyan-8) 100%
    );
  }

  .features {
    width: 100%;
    display: flex;
    flex-direction: column;
    padding: 7rem 0;
    border-top: 1px solid var(--color-gray-6);
    border-bottom: 1px solid var(--color-gray-6);
  }

  .features .content {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  @media (min-width: 768px) {
    .features .content {
      padding: 0 2rem;
    }
  }

  .features h2 {
    font-size: 1.5rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-12);
    text-align: center;
  }
  @media (min-width: 768px) {
    .features h2 {
      font-size: 1.875rem;
    }
  }

  .features .content > p {
    font-size: var(--text-base);
    color: var(--color-gray-11);
    line-height: 1.6;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }
  @media (min-width: 768px) {
    .features .content > p {
      font-size: var(--text-lg);
    }
  }

  .features .grid {
    display: grid;
    margin-top: 2rem;
    grid-template-columns: 1fr;
    gap: 2rem;
    width: 100%;
  }
  @media (min-width: 768px) {
    .features .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .features .card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    background-color: var(--color-gray-2);
    border: 1px solid var(--color-gray-6);
  }

  .features .card:nth-child(1) {
    transition-delay: 0.1s;
  }

  .features .card:nth-child(2) {
    transition-delay: 0.2s;
  }

  .features .card:nth-child(3) {
    transition-delay: 0.3s;
  }

  .icon {
    margin-bottom: 0.5rem;
    align-self: center;
    flex-shrink: 0;
  }

  .icon.a {
    color: var(--color-amber-9);
  }

  .icon.c {
    color: var(--color-cyan-9);
  }

  .icon.p {
    color: var(--color-ruby-9);
  }

  .icon.g {
    color: var(--color-green-9);
  }

  .features .card h3 {
    font-size: var(--text-xl);
    font-weight: var(--font-weight-semibold);
    color: var(--color-gray-12);
  }

  .features .card p {
    font-size: var(--text-sm);
    color: var(--color-gray-11);
    line-height: 1.6;
  }

  /* Try it section (replaces guarantee) */
  .try-it {
    width: 100%;
    display: flex;
    flex-direction: column;
    padding: 7rem 0;
    border-top: 1px solid var(--color-gray-6);
    border-bottom: 1px solid var(--color-gray-6);
  }

  .try-it .content {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .try-it .content {
      padding: 0 2rem;
    }
  }

  .try-it-title {
    font-size: 1.5rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-12);
    text-align: center;
    margin: 0;
  }
  @media (min-width: 768px) {
    .try-it-title {
      font-size: 1.875rem;
    }
  }

  .try-it-terminal {
    flex: 1;
    width: 100%;
    max-width: 620px;
    min-width: 0;
    animation: fadeInUp 0.5s ease-out 0.3s both;
    background-color: var(--color-gray-1);
    border: 1px solid var(--color-gray-6);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  @media (max-width: 768px) {
    .try-it-terminal {
      margin-top: 1.25rem;
    }
  }
  @media (min-width: 1024px) {
    .try-it-terminal {
      flex: 0 0 auto;
      width: 100%;
      max-width: 1000px;
      min-width: min(1000px, 90vw);
    }
  }

  .concerns {
    width: 100%;
