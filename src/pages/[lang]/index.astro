---
import Layout from '../../layouts/Layout.astro'
import Button from '../../components/ui/Button.astro'
import Terminal from '../../components/Terminal.astro'
import { Zap, Shield, Euro, CircleCheck } from '@lucide/astro'
import { useTranslations, useLocalePath } from '../../i18n/utils'
import { getSupabaseServer } from '../../lib/supabase'
import landingPlaceholder from '../../assets/landing-placeholder.svg'
import guaranteeBadge from '../../assets/guarantee-badge.svg'

const locale = Astro.params.lang as 'en' | 'fr'
const t = useTranslations(locale)
const localePath = useLocalePath(locale)

try {
  const supabase = getSupabaseServer(Astro.locals, Astro.request, Astro.cookies)
  const {
    data: { user }
  } = await supabase.auth.getUser()
  if (user) {
    return Astro.redirect(localePath('/courses'))
  }
} catch {
  // not logged in, show landing
}
---

<Layout>
  <main class="landing">
    <div class="bg-halo" aria-hidden="true"></div>
    <section class="hero">
      <div class="content">
        <div class="left">
          <h1>{t('home_title')}</h1>
          <p class="sub">
            {t('home_subtitle')}
            <br />
            <span class="sub-tagline">{t('home_subtitle_tagline')}</span>
          </p>
          <div class="cta">
            <Button href={localePath('/courses')} variant="solid" color="cyan" size="xl">
              {t('home_viewCourses')}
            </Button>
          </div>
        </div>
        <div class="hero-media">
          <Terminal rows={20} lang={locale} />
        </div>
      </div>
    </section>

    <div class="features">
      <div class="content">
        <h2 class="anim">{t('home_features_title')}</h2>
        <p class="anim">{t('home_features_subtitle')}</p>
        <div class="grid">
          <div class="card anim">
            <Zap size={32} class="icon a" />
            <h3>{t('home_features_speed_title')}</h3>
            <p>{t('home_features_speed_description')}</p>
          </div>
          <div class="card anim">
            <Shield size={32} class="icon c" />
            <h3>{t('home_features_stability_title')}</h3>
            <p>{t('home_features_stability_description')}</p>
          </div>
          <div class="card anim">
            <Euro size={32} class="icon p" />
            <h3>{t('home_features_price_title')}</h3>
            <p>{t('home_features_price_description')}</p>
          </div>
        </div>
      </div>
    </div>

    <div class="concerns">
      <div class="content">
        <div class="section-header anim">
          <h2>{t('home_concerns_title')}</h2>
          <p>{t('home_concerns_subtitle')}</p>
        </div>
        <div class="section-body">
          <div class="concern-rows">
            <div class="concern-row anim">
              <div class="text">
                <span class="eyebrow">{t('home_concerns_section1_label')}</span>
                <h3>{t('home_concerns_section1_title')}</h3>
                <p>{t('home_concerns_section1_intro')}</p>
                <ul class="concern-bullets">
                  <li class="concern-bullet">
                    <CircleCheck size={20} class="icon g" />
                    <span>{t('home_concerns_section1_point1')}</span>
                  </li>
                  <li class="concern-bullet">
                    <CircleCheck size={20} class="icon g" />
                    <span>{t('home_concerns_section1_point2')}</span>
                  </li>
                  <li class="concern-bullet">
                    <CircleCheck size={20} class="icon g" />
                    <span>{t('home_concerns_section1_point3')}</span>
                  </li>
                </ul>
              </div>
              <div class="media">
                <img
                  src="/src/assets/astronaut-training.gif"
                  alt={t('home_concerns_section1_image_alt')}
                  loading="lazy"
                />
              </div>
            </div>
            <div class="concern-row reverse anim">
              <div class="text">
                <span class="eyebrow">{t('home_concerns_section3_label')}</span>
                <h3>{t('home_concerns_section3_title')}</h3>
                <p>{t('home_concerns_section3_intro')}</p>
                <ul class="concern-bullets">
                  <li class="concern-bullet">
                    <CircleCheck size={20} class="icon g" />
                    <span>{t('home_concerns_section3_point1')}</span>
                  </li>
                  <li class="concern-bullet">
                    <CircleCheck size={20} class="icon g" />
                    <span>{t('home_concerns_section3_point2')}</span>
                  </li>
                  <li class="concern-bullet">
                    <CircleCheck size={20} class="icon g" />
                    <span>{t('home_concerns_section3_point3')}</span>
                  </li>
                </ul>
              </div>
              <div class="media">
                <img src="/src/assets/network.jpg" alt={t('home_concerns_section1_image_alt')} loading="lazy" />

                <!-- <img src={landingPlaceholder.src} alt={t('home_concerns_section3_image_alt')} loading="lazy" /> -->
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="guarantee">
      <div class="content">
        <div class="guarantee-row">
          <div class="guarantee-badge anim">
            <img src={guaranteeBadge.src} alt={t('home_guarantee_image_alt')} loading="lazy" />
          </div>
          <div class="guarantee-text anim">
            <h2>{t('home_guarantee_title')}</h2>
            <p>{t('home_guarantee_subtitle')}</p>
            <ul class="guarantee-bullets">
              <li>{t('home_guarantee_point1')}</li>
              <li>{t('home_guarantee_point2')}</li>
            </ul>
            <div class="cta">
              <Button href={localePath('/auth')} variant="solid" color="cyan" size="xl">
                {t('home_guarantee_cta')}
              </Button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="platform-features">
      <div class="content">
        <div class="section-header anim">
          <h2>{t('home_platform_features_title')}</h2>
          <p>{t('home_platform_features_subtitle')}</p>
        </div>
        <div class="section-body">
          <div class="feature-rows">
            <div class="feature-row anim">
              <div class="text">
                <h3>{t('home_platform_features_path_title')}</h3>
                <p>{t('home_platform_features_path_description')}</p>
              </div>
              <div class="media mermaid-media">
                <div class="mermaid-stack">
                  <pre
                    class="mermaid">
                    {`mindmap
  root((Kubernetes))
    Pods
    Deployments
    Services
    Ingress
    ConfigMaps
    Secrets
    Volumes
    RBAC`}
                  </pre>
                </div>
              </div>
            </div>
            <div class="feature-row reverse anim">
              <div class="text">
                <h3>{t('home_platform_features_terminal_title')}</h3>
                <p>{t('home_platform_features_terminal_description')}</p>
              </div>
              <div class="media">
                <video
                  src="/src/assets/video-demo.mp4"
                  autoplay
                  muted
                  loop
                  playsinline
                  class="media-video"
                  data-playback-rate="1.5"
                  aria-label={t('home_platform_features_terminal_alt')}></video>
              </div>
            </div>
            <div class="feature-row anim">
              <div class="text">
                <h3>{t('home_platform_features_visual_title')}</h3>
                <p>{t('home_platform_features_visual_description')}</p>
              </div>
              <div class="media">
                <img src={landingPlaceholder.src} alt={t('home_platform_features_visual_alt')} loading="lazy" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="stats">
      <h2 class="anim">{t('home_stats_title')}</h2>
      <p class="anim">{t('home_stats_subtitle')}</p>
      <div class="grid">
        <div class="card anim">
          <div class="val">{t('home_stats_adoption_value')}</div>
          <h3>{t('home_stats_adoption_label')}</h3>
          <p>{t('home_stats_adoption_description')}</p>
          <p class="src">{t('home_stats_adoption_source')}</p>
        </div>
        <div class="card anim">
          <div class="val">{t('home_stats_market_value')}</div>
          <h3>{t('home_stats_market_label')}</h3>
          <p>{t('home_stats_market_description')}</p>
          <p class="src">{t('home_stats_market_source')}</p>
        </div>
        <div class="card anim">
          <div class="val">{t('home_stats_companies_value')}</div>
          <h3>{t('home_stats_companies_label')}</h3>
          <p>{t('home_stats_companies_description')}</p>
          <p class="src">{t('home_stats_companies_source')}</p>
        </div>
      </div>
      <div class="cta">
        <Button href={localePath('/courses')} variant="solid" color="cyan" size="xl">{t('home_viewCourses')}</Button>
      </div>
    </div>
  </main>
</Layout>

<style>
  .landing {
    position: relative;
    overflow: hidden;
  }

  .landing > *:not(.bg-halo) {
    position: relative;
    z-index: 1;
  }

  .bg-halo {
    position: absolute;
    inset: -10%;
    z-index: 0;
    pointer-events: none;
    /* Une tache, nombreuses étapes = transition très douce */
    background: radial-gradient(ellipse 45% 20% at 75% 15%, hsl(192, 74%, 10%) 0%, var(--color-gray-1) 75%);
  }

  :global([data-theme='light']) .bg-halo {
    background: radial-gradient(ellipse 45% 40% at 75% 15%, hsl(194, 55%, 87%) 0%, var(--color-gray-1) 65%);
  }

  @media (max-width: 768px) {
    .bg-halo {
      background: radial-gradient(ellipse 65% 20% at 70% 10%, hsl(192, 74%, 10%) 0%, var(--color-gray-1) 65%);
    }
    :global([data-theme='light']) .bg-halo {
      background: radial-gradient(ellipse 65% 30% at 70% 10%, hsl(194, 55%, 87%) 0%, var(--color-gray-1) 65%);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .anim {
    opacity: 0;
    transform: translateY(30px);
    transition:
      opacity 0.6s ease-out,
      transform 0.6s ease-out;
  }

  .anim.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    justify-content: center;
    min-height: 80vh;
    position: relative;
    padding: 4rem 1rem;
    border-bottom: 1px solid var(--color-gray-6);
  }

  .hero .content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    width: 100%;
    max-width: var(--content-max-width);
  }
  @media (min-width: 1024px) {
    .hero .content {
      flex-direction: row;
      align-items: center;
      gap: 4rem;
    }
  }

  .left {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    flex: 1;
  }
  @media (min-width: 1024px) {
    .left {
      align-items: flex-start;
      min-width: 0;
      flex-shrink: 1;
    }
  }

  .hero h1 {
    font-family: 'Zalando Sans SemiExpanded', sans-serif;
    font-optical-sizing: auto;
    font-size: 4rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-12);
    line-height: 1.2;
    text-align: center;
    flex: 1;
    min-width: 100%;
  }

  @media (min-width: 1024px) {
    .hero h1 {
      text-align: left;
    }
  }

  .sub {
    font-size: var(--text-lg);
    color: var(--color-gray-12);
    line-height: 1.6;
    text-align: center;
    max-width: 700px;
    animation: fadeInUp 0.8s ease-out 0.2s both;
  }
  @media (min-width: 768px) {
    .sub {
      font-size: var(--text-xl);
    }
  }
  @media (min-width: 1024px) {
    .sub {
      text-align: left;
    }
  }

  .sub-tagline {
    display: block;
    margin-top: 0.35em;
    font-style: italic;
    color: var(--color-cyan-9);
  }

  .cta {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    z-index: 1;
    animation: fadeInUp 0.8s ease-out 0.4s both;
  }

  .features {
    width: 100%;
    display: flex;
    flex-direction: column;
    padding: 8rem 0;
    border-top: 1px solid var(--color-gray-6);
    border-bottom: 1px solid var(--color-gray-6);
  }

  .features .content {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  @media (min-width: 768px) {
    .features .content {
      padding: 0 2rem;
    }
  }

  .features h2 {
    font-size: 1.5rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-12);
    text-align: center;
  }
  @media (min-width: 768px) {
    .features h2 {
      font-size: 1.875rem;
    }
  }

  .features .content > p {
    font-size: var(--text-base);
    color: var(--color-gray-11);
    line-height: 1.6;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }
  @media (min-width: 768px) {
    .features .content > p {
      font-size: var(--text-lg);
    }
  }

  .features .grid {
    display: grid;
    margin-top: 2rem;
    grid-template-columns: 1fr;
    gap: 2rem;
    width: 100%;
  }
  @media (min-width: 768px) {
    .features .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .features .card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    background-color: var(--color-gray-2);
    border: 1px solid var(--color-gray-6);
  }

  .features .card:nth-child(1) {
    transition-delay: 0.1s;
  }

  .features .card:nth-child(2) {
    transition-delay: 0.2s;
  }

  .features .card:nth-child(3) {
    transition-delay: 0.3s;
  }

  .icon {
    margin-bottom: 0.5rem;
    align-self: center;
    flex-shrink: 0;
  }

  .icon.a {
    color: var(--color-amber-9);
  }

  .icon.c {
    color: var(--color-cyan-9);
  }

  .icon.p {
    color: var(--color-ruby-9);
  }

  .icon.g {
    color: var(--color-green-9);
  }

  .features .card h3 {
    font-size: var(--text-xl);
    font-weight: var(--font-weight-semibold);
    color: var(--color-gray-12);
  }

  .features .card p {
    font-size: var(--text-sm);
    color: var(--color-gray-11);
    line-height: 1.6;
  }

  .concerns {
    width: 100%;
    display: flex;
    flex-direction: column;
    padding: 8rem 0;
    border-top: 1px solid var(--color-gray-6);
    border-bottom: 1px solid var(--color-gray-6);
  }

  .concerns .content {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  @media (min-width: 768px) {
    .concerns .content {
      padding: 0 2rem;
    }
  }

  .concerns .section-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-align: center;
    align-items: center;
  }
  .concerns h2 {
    font-size: 1.5rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-12);
    text-align: center;
  }
  @media (min-width: 768px) {
    .concerns h2 {
      font-size: 1.875rem;
    }
  }

  .concerns .section-header > p {
    font-size: var(--text-base);
    color: var(--color-gray-11);
    line-height: 1.6;
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }
  @media (min-width: 768px) {
    .concerns .section-header > p {
      font-size: var(--text-lg);
    }
  }
  .concerns .section-body {
    margin-top: 2.5rem;
  }
  .guarantee {
    width: 100%;
    display: flex;
    flex-direction: column;
    padding: 8rem 0;
    border-top: 1px solid var(--color-gray-6);
    border-bottom: 1px solid var(--color-gray-6);
  }
  .guarantee .content {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 1rem;
    display: flex;
    flex-direction: column;
  }
  @media (min-width: 768px) {
    .guarantee .content {
      padding: 0 2rem;
    }
  }
  .guarantee-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
  }
  @media (min-width: 1024px) {
    .guarantee-row {
      flex-direction: row;
      align-items: center;
      gap: 4rem;
    }
  }
  .guarantee-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
  }
  .guarantee-badge img {
    width: min(240px, 70vw);
    height: auto;
    filter: drop-shadow(0 12px 24px rgba(0, 0, 0, 0.25));
  }
  .guarantee-text {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-align: center;
  }
  @media (min-width: 1024px) {
    .guarantee-text {
      text-align: left;
      align-items: flex-start;
    }
  }
  .guarantee h2 {
    font-size: 1.5rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-12);
  }
  @media (min-width: 768px) {
    .guarantee h2 {
      font-size: 1.875rem;
    }
  }
  .guarantee p {
    font-size: var(--text-base);
    color: var(--color-gray-11);
    line-height: 1.6;
    max-width: 800px;
    margin: 0;
  }
  @media (min-width: 768px) {
    .guarantee p {
      font-size: var(--text-lg);
    }
  }
  .guarantee-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    font-size: var(--text-base);
    color: var(--color-gray-11);
    text-align: left;
  }
  @media (min-width: 768px) {
    .guarantee-bullets {
      font-size: var(--text-lg);
    }
  }

  .concern-rows {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-28);
  }

  .concern-row {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .concern-row {
      flex-direction: row;
      align-items: center;
      gap: 3rem;
    }
    .concern-row.reverse {
      flex-direction: row-reverse;
    }
  }

  .concern-row .text {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    flex: 1;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--text-sm);
    color: var(--color-cyan-9);
    font-weight: var(--font-weight-semibold);
  }

  .concern-row h3 {
    font-size: var(--text-xl);
    font-weight: var(--font-weight-semibold);
    color: var(--color-gray-12);
    line-height: 1.3;
  }

  .concern-row p {
    font-size: var(--text-base);
    color: var(--color-gray-11);
    line-height: 1.7;
  }
  @media (min-width: 768px) {
    .concern-row h3 {
      font-size: 1.6rem;
    }
    .concern-row p {
      font-size: var(--text-lg);
    }
  }

  .concern-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .concern-bullet {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: var(--text-base);
    color: var(--color-gray-11);
    line-height: 1.6;
  }
  @media (min-width: 768px) {
    .concern-bullet {
      font-size: var(--text-lg);
    }
  }

  .concern-bullet .icon {
    margin-top: 0.15rem;
    flex-shrink: 0;
  }

  .media {
    width: 100%;
    flex: 1;
  }

  .media img,
  .media video {
    width: 100%;
    height: 320px;
    object-fit: cover;
    object-position: center;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-gray-6);
    background: var(--color-gray-2);
  }

  .mermaid-media .mermaid {
    margin: 0;
    padding: 1rem;
    background: var(--color-gray-2);
    border: 1px solid var(--color-gray-6);
    border-radius: var(--radius-lg);
  }
  .mermaid-stack {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .mermaid-media .mermaid svg {
    width: 100%;
    height: auto;
    display: block;
  }
  .media .media-video {
    height: auto;
    object-fit: contain;
  }
  @media (min-width: 768px) {
    .media img,
    .media video {
      height: 360px;
    }
  }

  .platform-features {
    width: 100%;
    display: flex;
    flex-direction: column;
    padding: 8rem 0;
    border-top: 1px solid var(--color-gray-6);
    border-bottom: 1px solid var(--color-gray-6);
  }
  .platform-features .content {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  @media (min-width: 768px) {
    .platform-features .content {
      padding: 0 2rem;
    }
  }
  .platform-features .section-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
