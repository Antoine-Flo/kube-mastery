---
import Layout from '../../layouts/Layout.astro'
import Button from '../../components/ui/Button.astro'
import Terminal from '../../components/Terminal.astro'
import { Zap, Shield, Euro, CircleCheck } from '@lucide/astro'
import { useTranslations, useLocalePath } from '../../i18n/utils'
import { getSupabaseServer } from '../../lib/supabase'
import astronautTrainingGif from '../../assets/astronaut-training.gif'
import networkImg from '../../assets/network.jpg'
import demoVideo from '../../assets/demo.mp4'
import conformanceImage from '../../assets/conformance.png'
import openapiLogo from '../../assets/openapi_logo.svg'
const locale = Astro.params.lang as 'en' | 'fr'
const t = useTranslations(locale)
const localePath = useLocalePath(locale)

try {
  const supabase = getSupabaseServer(Astro.locals, Astro.request, Astro.cookies)
  const {
    data: { user }
  } = await supabase.auth.getUser()
  if (user) {
    return Astro.redirect(localePath('/courses'))
  }
} catch {
  // not logged in, show landing
}
---

<Layout>
  <main class="landing">
    <div class="bg-halo" aria-hidden="true"></div>
    <section class="hero">
      <div class="content">
        <div class="left">
          <h1>{t('home_title')}</h1>
          <p class="sub">
            {t('home_subtitle')}
            <br />
          </p>
          <div class="cta">
            <Button
              href={localePath('/pricing')}
              variant="solid"
              color="cyan"
              size="xl"
            >
              {t('home_cta_join')}
            </Button>
          </div>
        </div>
        <div class="hero-media">
          <video
            src={demoVideo}
            autoplay
            loop
            muted
            playsinline
            class="hero-demo-video"
            data-playback-rate="1.5"
            aria-label={t('home_subtitle')}></video>
        </div>
      </div>
    </section>

    <div class="features">
      <div class="content">
        <h2 class="anim">{t('home_features_title')}</h2>
        <p class="anim">{t('home_features_subtitle')}</p>
        <div class="grid">
          <div class="card anim">
            <Zap size={32} class="icon a" />
            <h3>{t('home_features_speed_title')}</h3>
            <p>{t('home_features_speed_description')}</p>
          </div>
          <div class="card anim">
            <Shield size={32} class="icon c" />
            <h3>{t('home_features_stability_title')}</h3>
            <p>{t('home_features_stability_description')}</p>
          </div>
          <div class="card anim">
            <Euro size={32} class="icon p" />
            <h3>{t('home_features_price_title')}</h3>
            <p>{t('home_features_price_description')}</p>
          </div>
        </div>
      </div>
    </div>

    <div class="try-it">
      <div class="content">
        <h2 class="try-it-title anim">{t('home_try_title')}</h2>
        <div class="try-it-terminal anim">
          <Terminal rows={20} lang={locale} />
        </div>
      </div>
    </div>
    <div class="concerns">
      <div class="content">
        <div class="section-header anim">
          <h2>{t('home_concerns_title')}</h2>
          <p>{t('home_concerns_subtitle')}</p>
          <div class="cta">
            <Button
              href={localePath('/courses')}
              variant="solid"
              color="cyan"
              size="xl">{t('home_cta_explore')}</Button
            >
          </div>
        </div>
        <div class="section-body">
          <div class="concern-rows">
            <div class="concern-row anim">
              <div class="text">
                <span class="eyebrow">{t('home_concerns_section1_label')}</span>
                <h3>{t('home_concerns_section1_title')}</h3>
                <p>{t('home_concerns_section1_intro')}</p>
                <ul class="concern-bullets">
                  <li class="concern-bullet">
                    <CircleCheck size={20} class="icon g" />
                    <span>{t('home_concerns_section1_point1')}</span>
                  </li>
                  <li class="concern-bullet">
                    <CircleCheck size={20} class="icon g" />
                    <span>{t('home_concerns_section1_point2')}</span>
                  </li>
                  <li class="concern-bullet">
                    <CircleCheck size={20} class="icon g" />
                    <span>{t('home_concerns_section1_point3')}</span>
                  </li>
                </ul>
              </div>
              <div class="media">
                <img
                  src={astronautTrainingGif.src}
                  alt={t('home_concerns_section1_image_alt')}
                  loading="lazy"
                />
              </div>
            </div>
            <div class="concern-row reverse anim">
              <div class="text">
                <span class="eyebrow">{t('home_concerns_section3_label')}</span>
                <h3>{t('home_concerns_section3_title')}</h3>
                <p>{t('home_concerns_section3_intro')}</p>
                <ul class="concern-bullets">
                  <li class="concern-bullet">
                    <CircleCheck size={20} class="icon g" />
                    <span>{t('home_concerns_section3_point1')}</span>
                  </li>
                  <li class="concern-bullet">
                    <CircleCheck size={20} class="icon g" />
                    <span>{t('home_concerns_section3_point2')}</span>
                  </li>
                  <li class="concern-bullet">
                    <CircleCheck size={20} class="icon g" />
                    <span>{t('home_concerns_section3_point3')}</span>
                  </li>
                </ul>
              </div>
              <div class="media">
                <img
                  src={networkImg.src}
                  alt={t('home_concerns_section1_image_alt')}
                  loading="lazy"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="platform-features">
      <div class="content">
        <div class="section-header anim">
          <h2>{t('home_reliability_title')}</h2>
          <p>{t('home_reliability_subtitle')}</p>
        </div>
        <div class="section-body">
          <div class="feature-rows">
            <div class="feature-row anim">
              <div class="text">
                <h3>{t('home_reliability_conformance_title')}</h3>
                <p>{t('home_reliability_conformance_description')}</p>
              </div>
              <div class="media media-conformance">
                <img
                  src={conformanceImage.src}
                  alt={t('home_reliability_conformance_alt')}
                  loading="lazy"
                />
              </div>
            </div>
            <div class="feature-row reverse anim">
              <div class="text">
                <h3>{t('home_reliability_openapi_title')}</h3>
                <p>{t('home_reliability_openapi_description')}</p>
              </div>
              <div class="media media-openapi">
                <img
                  src={openapiLogo.src}
                  alt={t('home_reliability_openapi_alt')}
                  loading="lazy"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="reliability-cta-wrap">
        <div class="content">
          <div class="reliability-cta anim">
            <p>{t('home_reliability_cta_intro')}</p>
            <div class="cta">
              <Button
                href={localePath('/pricing')}
                variant="solid"
                color="cyan"
                size="xl"
              >
                {t('home_cta_join')}
              </Button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>
<button id="error-button" type="button">Throw test error</button>


<style>
  .landing {
    position: relative;
    overflow: hidden;
  }

  .landing > *:not(.bg-halo) {
    position: relative;
    z-index: 1;
  }

  .bg-halo {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(
          ellipse 34% 48% at 76% 16%,
          hsl(192, 74%, 10%) 0%,
          hsl(192, 74%, 10%) 24%,
          var(--color-gray-1) 100%
        )
        50% 0% / 100% 28% no-repeat,
      radial-gradient(
          ellipse 32% 46% at 26% 50%,
          hsl(192, 74%, 10%) 0%,
          hsl(192, 74%, 10%) 22%,
          var(--color-gray-1) 100%
        )
        50% 50% / 100% 24% no-repeat,
      radial-gradient(
          ellipse 36% 50% at 74% 84%,
          hsl(192, 74%, 10%) 0%,
          hsl(192, 74%, 10%) 24%,
          var(--color-gray-1) 100%
        )
        50% 100% / 100% 24% no-repeat,
      var(--color-gray-1);
  }

  :global([data-theme='light']) .bg-halo {
    background:
      radial-gradient(
          ellipse 34% 48% at 76% 16%,
          hsl(194, 55%, 87%) 0%,
          hsl(194, 55%, 87%) 24%,
          var(--color-gray-1) 100%
        )
        50% 0% / 100% 28% no-repeat,
      radial-gradient(
          ellipse 32% 46% at 26% 50%,
          hsl(194, 55%, 87%) 0%,
          hsl(194, 55%, 87%) 22%,
          var(--color-gray-1) 100%
        )
        50% 50% / 100% 24% no-repeat,
      radial-gradient(
          ellipse 36% 50% at 74% 84%,
          hsl(194, 55%, 87%) 0%,
          hsl(194, 55%, 87%) 24%,
          var(--color-gray-1) 100%
        )
        50% 100% / 100% 24% no-repeat,
      var(--color-gray-1);
  }

  @media (max-width: 768px) {
    .bg-halo {
      background:
        radial-gradient(
            ellipse 90% 86% at 72% 10%,
            hsl(192, 74%, 10%) 0%,
            hsl(192, 74%, 10%) 34%,
            var(--color-gray-1) 100%
          )
          50% 0% / 100% 36% no-repeat,
        radial-gradient(
            ellipse 92% 86% at 28% 50%,
            hsl(192, 74%, 10%) 0%,
            hsl(192, 74%, 10%) 32%,
            var(--color-gray-1) 100%
          )
          50% 50% / 100% 36% no-repeat,
        radial-gradient(
            ellipse 94% 90% at 70% 86%,
            hsl(192, 74%, 10%) 0%,
            hsl(192, 74%, 10%) 34%,
            var(--color-gray-1) 100%
          )
          50% 100% / 100% 36% no-repeat,
        var(--color-gray-1);
    }

    [data-theme='light'] .bg-halo {
      background:
        radial-gradient(
            ellipse 90% 86% at 72% 10%,
            hsl(194, 55%, 87%) 0%,
            hsl(194, 55%, 87%) 34%,
            var(--color-gray-1) 100%
          )
          50% 0% / 100% 36% no-repeat,
        radial-gradient(
            ellipse 92% 86% at 28% 50%,
            hsl(194, 55%, 87%) 0%,
            hsl(194, 55%, 87%) 32%,
            var(--color-gray-1) 100%
          )
          50% 50% / 100% 36% no-repeat,
        radial-gradient(
            ellipse 94% 90% at 70% 86%,
            hsl(194, 55%, 87%) 0%,
            hsl(194, 55%, 87%) 34%,
            var(--color-gray-1) 100%
          )
          50% 100% / 100% 36% no-repeat,
        var(--color-gray-1);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .anim {
    opacity: 0;
    transform: translateY(30px);
    transition:
      opacity 0.6s ease-out,
      transform 0.6s ease-out;
  }

  .anim.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    justify-content: center;
    min-height: 80vh;
    position: relative;
    padding: 4rem 1rem;
  }

  .hero .content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    width: 100%;
    max-width: var(--content-max-width);
  }

  .left {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    width: 100%;
  }

  .hero h1 {
    font-family: 'Zalando Sans SemiExpanded', sans-serif;
    font-optical-sizing: auto;
    font-size: 4rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-12);
    line-height: 1.2;
    text-align: center;
    flex: 1;
    min-width: 100%;
  }

  .sub {
    font-size: var(--text-lg);
    color: var(--color-gray-12);
    font-style: italic;
    line-height: 1.6;
    text-align: center;
    max-width: 700px;
    animation: fadeInUp 0.8s ease-out 0.2s both;
  }
  @media (min-width: 768px) {
    .sub {
      font-size: var(--text-xl);
    }
  }

  .sub-tagline {
    display: block;
    margin-top: 0.35em;
    font-style: italic;
    color: var(--color-cyan-9);
  }

  .cta {
    margin-top: 1rem;
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    position: relative;
    z-index: 1;
    animation: fadeInUp 0.8s ease-out 0.4s both;
  }

  .cta :global(.btn[data-color='cyan'][data-variant='solid']) {
    background: linear-gradient(
      135deg,
      var(--color-cyan-9) 0%,
      var(--color-cyan-7) 100%
    );
  }
  .cta
    :global(.btn[data-color='cyan'][data-variant='solid']):hover:not(
      :disabled
    ) {
    background: linear-gradient(
      135deg,
      var(--color-cyan-10) 0%,
      var(--color-cyan-8) 100%
    );
  }

  .features {
    width: 100%;
    display: flex;
    flex-direction: column;
    padding: 8rem 0;
    border-top: 1px solid var(--color-gray-6);
    border-bottom: 1px solid var(--color-gray-6);
  }

  .features .content {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  @media (min-width: 768px) {
    .features .content {
      padding: 0 2rem;
    }
  }

  .features h2 {
    font-size: 1.5rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-12);
    text-align: center;
  }
  @media (min-width: 768px) {
    .features h2 {
      font-size: 1.875rem;
    }
  }

  .features .content > p {
    font-size: var(--text-base);
    color: var(--color-gray-11);
    line-height: 1.6;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }
  @media (min-width: 768px) {
    .features .content > p {
      font-size: var(--text-lg);
    }
  }

  .features .grid {
    display: grid;
    margin-top: 2rem;
    grid-template-columns: 1fr;
    gap: 2rem;
    width: 100%;
  }
  @media (min-width: 768px) {
    .features .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .features .card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    background-color: var(--color-gray-2);
    border: 1px solid var(--color-gray-6);
  }

  .features .card:nth-child(1) {
    transition-delay: 0.1s;
  }

  .features .card:nth-child(2) {
    transition-delay: 0.2s;
  }

  .features .card:nth-child(3) {
    transition-delay: 0.3s;
  }

  .icon {
    margin-bottom: 0.5rem;
    align-self: center;
    flex-shrink: 0;
  }

  .icon.a {
    color: var(--color-amber-9);
  }

  .icon.c {
    color: var(--color-cyan-9);
  }

  .icon.p {
    color: var(--color-ruby-9);
  }

  .icon.g {
    color: var(--color-green-9);
  }

  .features .card h3 {
    font-size: var(--text-xl);
    font-weight: var(--font-weight-semibold);
    color: var(--color-gray-12);
  }

  .features .card p {
    font-size: var(--text-sm);
    color: var(--color-gray-11);
    line-height: 1.6;
  }

  /* Try it section (replaces guarantee) */
  .try-it {
    width: 100%;
    display: flex;
    flex-direction: column;
    padding: 8rem 0;
    border-top: 1px solid var(--color-gray-6);
    border-bottom: 1px solid var(--color-gray-6);
  }

  .try-it .content {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .try-it .content {
      padding: 0 2rem;
    }
  }

  .try-it-title {
    font-size: 1.5rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-12);
    text-align: center;
    margin: 0;
  }
  @media (min-width: 768px) {
    .try-it-title {
      font-size: 1.875rem;
    }
  }

  .try-it-terminal {
    flex: 1;
    width: 100%;
    max-width: 620px;
    min-width: 0;
    animation: fadeInUp 0.5s ease-out 0.3s both;
    background-color: var(--color-gray-1);
    border: 1px solid var(--color-gray-6);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  @media (max-width: 768px) {
    .try-it-terminal {
      margin-top: 1.25rem;
    }
  }
  @media (min-width: 1024px) {
    .try-it-terminal {
      flex: 0 0 auto;
      width: 100%;
      max-width: 1000px;
      min-width: min(1000px, 90vw);
    }
  }

  .concerns {
    width: 100%;
    display: flex;
    flex-direction: column;
    padding: 8rem 0;
    border-top: 1px solid var(--color-gray-6);
    border-bottom: 1px solid var(--color-gray-6);
  }

  .concerns .content {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  @media (min-width: 768px) {
    .concerns .content {
      padding: 0 2rem;
    }
  }

  .concerns .section-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-align: center;
    align-items: center;
  }
  .concerns h2 {
    font-size: 1.5rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-12);
    text-align: center;
  }
  @media (min-width: 768px) {
    .concerns h2 {
      font-size: 1.875rem;
    }
  }

  .concerns .section-header > p {
    font-size: var(--text-base);
    color: var(--color-gray-11);
    line-height: 1.6;
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }
  @media (min-width: 768px) {
    .concerns .section-header > p {
      font-size: var(--text-lg);
    }
  }
  .concerns .section-body {
    margin-top: 2.5rem;
  }

  .concern-rows {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-36);
  }

  .concern-row {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .concern-row {
      flex-direction: row;
      align-items: center;
      gap: 3rem;
    }
    .concern-row.reverse {
      flex-direction: row-reverse;
    }
  }

  .concern-row .text {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    flex: 1;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--text-sm);
    color: var(--color-cyan-9);
    font-weight: var(--font-weight-semibold);
  }

  .concern-row h3 {
    font-size: var(--text-xl);
    font-weight: var(--font-weight-semibold);
    color: var(--color-gray-12);
    line-height: 1.3;
  }

  .concern-row p {
    font-size: var(--text-base);
    color: var(--color-gray-11);
    line-height: 1.7;
  }
  @media (min-width: 768px) {
    .concern-row h3 {
      font-size: 1.6rem;
    }
    .concern-row p {
      font-size: var(--text-lg);
    }
  }

  .concern-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .concern-bullet {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: var(--text-base);
    color: var(--color-gray-11);
    line-height: 1.6;
  }
  @media (min-width: 768px) {
    .concern-bullet {
      font-size: var(--text-lg);
    }
  }

  .concern-bullet .icon {
    margin-top: 0.15rem;
    flex-shrink: 0;
  }

  .media {
    width: 100%;
    flex: 1;
  }

  .media img,
  .media video {
    width: 100%;
    height: 320px;
    object-fit: cover;
    object-position: center;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-gray-6);
    background: var(--color-gray-2);
  }

  .media-conformance img {
    height: auto;
    max-height: none;
    object-fit: contain;
  }

  .media-openapi img {
    aspect-ratio: 594 / 279;
    height: auto;
    object-fit: contain;
    padding: 2.5rem;
    background: var(--color-gray-2);
  }

  @media (min-width: 768px) {
    .media img,
    .media video {
      height: 360px;
    }
    .media-conformance img,
    .media-openapi img {
      height: auto;
    }
  }

  .platform-features {
    width: 100%;
    display: flex;
    flex-direction: column;
    padding: 8rem 0;
    border-top: 1px solid var(--color-gray-6);
    border-bottom: 1px solid var(--color-gray-6);
  }
  .platform-features .content {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  @media (min-width: 768px) {
    .platform-features .content {
      padding: 0 2rem;
    }
  }
  .platform-features .section-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-align: center;
    align-items: center;
  }
