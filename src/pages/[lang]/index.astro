<script>
  function setupScrollAnim() {
    document.querySelectorAll('.anim').forEach((el) => {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible')
            }
          })
        },
        { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
      )
      observer.observe(el)
    })
  }
  function setupMediaPlayback() {
    document.querySelectorAll('video[data-playback-rate]').forEach((video) => {
      const element = video as HTMLVideoElement
      const rate = Number(element.getAttribute('data-playback-rate'))
      if (!Number.isNaN(rate) && rate > 0) {
        element.playbackRate = rate
      }
      if (element.dataset.autoplay === 'true') {
        element.play().catch(() => {})
      }
    })
  }
  setupScrollAnim()
  setupMediaPlayback()
  document.addEventListener('astro:page-load', setupScrollAnim)
  document.addEventListener('astro:page-load', setupMediaPlayback)
</script>
