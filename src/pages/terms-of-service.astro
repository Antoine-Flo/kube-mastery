---
import Layout from "../layouts/Layout.astro";
import * as m from "../paraglide/messages.js";
---
<Layout>
	<div class="doc">
		<h1>{m.termsOfService_title()}</h1>
		<p class="meta">{m.termsOfService_lastUpdated()}</p>
		<p class="lead">{m.termsOfService_intro()}</p>

		<section>
			<h2>{m.termsOfService_acceptance_title()}</h2>
			<p set:html={m.termsOfService_acceptance_content()} />
		</section>
		<section>
			<h2>{m.termsOfService_description_title()}</h2>
			<p set:html={m.termsOfService_description_content()} />
		</section>
		<section>
			<h2>{m.termsOfService_account_title()}</h2>
			<p set:html={m.termsOfService_account_content()} />
		</section>
		<section>
			<h2>{m.termsOfService_use_title()}</h2>
			<p set:html={m.termsOfService_use_content()} />
		</section>
		<section>
			<h2>{m.termsOfService_intellectual_title()}</h2>
			<p set:html={m.termsOfService_intellectual_content()} />
		</section>
		<section>
			<h2>{m.termsOfService_limitation_title()}</h2>
			<p set:html={m.termsOfService_limitation_content()} />
		</section>
		<section>
			<h2>{m.termsOfService_changes_title()}</h2>
			<p set:html={m.termsOfService_changes_content()} />
		</section>
		<section>
			<h2>{m.termsOfService_contact_title()}</h2>
			<p set:html={m.termsOfService_contact_content()} />
		</section>
	</div>
</Layout>

<style>
	.doc {
		max-width: 800px;
		margin: 0 auto;
		padding: 4rem 2rem;
	}
	.doc h1 {
		font-size: 1.875rem;
		font-weight: var(--font-weight-bold);
		color: var(--color-gray-12);
		margin-bottom: 2rem;
	}
	.meta {
		color: var(--color-gray-9);
		font-size: 0.875rem;
		margin-bottom: 1.5rem;
	}
	.lead {
		color: var(--color-gray-11);
		line-height: 1.6;
		margin-bottom: 2rem;
		font-size: 1.125rem;
	}
	.doc section {
		margin-bottom: 2.5rem;
	}
	.doc section h2 {
		font-size: 1.25rem;
		font-weight: var(--font-weight-semibold);
		color: var(--color-gray-12);
		margin-bottom: 1rem;
	}
	.doc section p {
		color: var(--color-gray-11);
		line-height: 1.7;
		margin-bottom: 0;
	}
</style>
