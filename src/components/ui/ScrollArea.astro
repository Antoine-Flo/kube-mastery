---
interface Props {
  class?: string
}

const { class: className = '' } = Astro.props
---

<div class={`sa ${className}`.trim()}>
  <div class="sa-vp">
    <slot />
  </div>
</div>

<style>
  .sa {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
    overflow: hidden;
    --sa-m: 0px;
    --sa-t: 0.5rem;
    --sa-s: calc(var(--sa-t) + calc(var(--sa-m) * 2));
  }

  .sa-vp {
    flex: 1;
    min-height: 0;
    width: 100%;
    overflow: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--color-gray-a6) transparent;
  }

  .sa-vp::-webkit-scrollbar {
    width: var(--sa-s);
    height: var(--sa-s);
  }

  .sa-vp::-webkit-scrollbar-track {
    background: transparent;
  }

  .sa-vp::-webkit-scrollbar-thumb {
    background-color: var(--color-gray-a6);
    border-radius: 9999px;
    border: 2px solid transparent;
    background-clip: padding-box;
    transition: background-color var(--duration-normal);
  }

  .sa-vp::-webkit-scrollbar-thumb:hover {
    background-color: var(--color-gray-a8);
  }
</style>
