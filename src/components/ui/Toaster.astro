---
import "../../styles/components/toast.css";
---

<div id="toaster" class="toaster toaster--placement-bottom-end" aria-live="polite">
	<div class="toaster__stack"></div>
</div>

<script>
	const TOAST_DURATION_MS = 4000;
	const TOAST_OUT_ANIMATION_MS = 150;

	type ToastType = "success" | "error" | "warning" | "info" | "loading";

	interface ToastDetail {
		title: string;
		description?: string;
		type?: ToastType;
		duration?: number;
	}

	function getIndicatorHtml(type: ToastType): string {
		const icons: Record<ToastType, string> = {
			success:
				'<span class="toast__indicator" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>',
			error:
				'<span class="toast__indicator" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg></span>',
			warning:
				'<span class="toast__indicator" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></span>',
			info:
				'<span class="toast__indicator" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg></span>',
			loading:
				'<span class="toast__indicator" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"/><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"/><line x1="2" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="22" y2="12"/><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"/><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"/></svg></span>',
		};
		return icons[type] ?? icons.info;
	}

	function showToast(detail: ToastDetail) {
		const toaster = document.getElementById("toaster");
		const stack = toaster?.querySelector(".toaster__stack");
		if (!stack) {
			return;
		}
		const type = detail.type ?? "info";
		const duration = detail.duration ?? TOAST_DURATION_MS;

		const toast = document.createElement("div");
		toast.className = "toast";
		toast.setAttribute("data-type", type);
		toast.setAttribute("data-state", "open");
		toast.setAttribute("role", "status");
		toast.setAttribute("aria-live", "polite");

		toast.innerHTML =
			getIndicatorHtml(type) +
			'<div class="toast__content">' +
			`<p class="toast__title">${escapeHtml(detail.title)}</p>` +
			(detail.description
				? `<p class="toast__description">${escapeHtml(detail.description)}</p>`
				: "") +
			"</div>";

		stack.appendChild(toast);

		const close = () => {
			toast.setAttribute("data-state", "closed");
			setTimeout(() => {
				toast.remove();
			}, TOAST_OUT_ANIMATION_MS);
		};

		if (duration > 0) {
			setTimeout(close, duration);
		}
	}

	function escapeHtml(text: string): string {
		const div = document.createElement("div");
		div.textContent = text;
		return div.innerHTML;
	}

	document.addEventListener("toast-show", ((e: CustomEvent<ToastDetail>) => {
		showToast(e.detail ?? { title: "" });
	}) as EventListener);
</script>
