  /* variants */
  .btn[data-variant='solid'] {
    background: var(--btn-solid-bg);
    color: var(--btn-solid-fg);
  }
  .btn[data-variant='solid']:hover:not(:disabled) {
    background: var(--btn-solid-bg-hover);
  }
  .btn[data-variant='solid']:active:not(:disabled) {
    background: var(--btn-solid-bg-active);
  }

  .btn[data-variant='surface'] {
    background: var(--btn-surface-bg);
    border: 1px solid var(--btn-surface-border);
    color: var(--btn-surface-fg);
  }
  .btn[data-variant='surface']:hover:not(:disabled) {
    background: var(--btn-surface-bg-hover);
    border-color: var(--btn-surface-border-hover);
  }
  .btn[data-variant='surface']:active:not(:disabled) {
    background: var(--btn-surface-bg-active);
  }

  .btn[data-variant='subtle'] {
    background: var(--btn-subtle-bg);
    color: var(--btn-subtle-fg);
  }
  .btn[data-variant='subtle']:hover:not(:disabled) {
    background: var(--btn-subtle-bg-hover);
  }
  .btn[data-variant='subtle']:active:not(:disabled) {
    background: var(--btn-subtle-bg-active);
  }

  .btn[data-variant='outline'] {
    background: transparent;
    border: 1px solid var(--btn-outline-border);
    color: var(--btn-outline-fg);
  }
  .btn[data-variant='outline']:hover:not(:disabled) {
    background: var(--btn-outline-bg-hover);
  }
  .btn[data-variant='outline']:active:not(:disabled) {
    background: var(--btn-outline-bg-active);
  }

  .btn[data-variant='plain'] {
    background: transparent;
    color: var(--btn-plain-fg);
  }
  .btn[data-variant='plain']:hover:not(:disabled) {
    background: var(--btn-plain-bg-hover);
  }
  .btn[data-variant='plain']:active:not(:disabled) {
    background: var(--btn-plain-bg-active);
  }

  /* size */
  .btn[data-size='2xs'] {
    --btn-height: var(--spacing-7);
    --btn-padding-inline: var(--spacing-2);
    --btn-padding-block: calc(var(--spacing-1) / 2);
