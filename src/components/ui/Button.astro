---
export interface Props {
  href?: string
  variant?: 'solid' | 'surface' | 'subtle' | 'outline' | 'plain'
  size?: '2xs' | 'xs' | 'sm' | 'md' | 'lg' | 'xl' | '2xl'
  color?: 'gray' | 'cyan' | 'ruby' | 'green' | 'amber'
  type?: 'button' | 'submit'
  disabled?: boolean
  /** HTML `hidden` on the root `a` / `button` (e.g. toggled client-side). */
  hidden?: boolean
  class?: string
  title?: string
  /** Optional secondary line below main label (e.g. "No sign-up required") */
  sublabel?: string
  /** When "span", render a span (same look, for use inside a parent link) */
  as?: 'a' | 'button' | 'span'
}

const {
  href,
  variant = 'solid',
  size = 'md',
  color = 'gray',
  type = 'button',
  disabled = false,
  class: className = '',
  sublabel,
  as: asProp,
  ...rest
} = Astro.props as Props

const El = asProp ?? (href ? 'a' : 'button')
const base = 'btn'
const attrs =
  El === 'a'
    ? { href, class: `${base} ${className}`.trim(), ...rest }
    : {
        type: El === 'button' ? type : undefined,
        disabled: El === 'button' ? disabled : undefined,
        class: `${base} ${className}`.trim(),
        ...rest
      }
---

<El
  {...attrs}
  data-variant={variant}
  data-size={size}
  data-color={color}
  data-has-sublabel={sublabel ? '' : undefined}
>
  {
    sublabel ? (
      <span class="btn-inner">
        <span class="btn-label">
          <slot />
        </span>
        <span class="btn-sublabel">{sublabel}</span>
      </span>
    ) : (
      <slot />
    )
  }
</El>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-2);
    border-radius: var(--radius-l2);
    font-weight: var(--font-weight-semibold);
    cursor: pointer;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    transition:
      background-color 0.2s,
      border-color 0.2s,
      color 0.2s,
      transform var(--press-duration-transform) var(--press-ease-transform),
      box-shadow var(--press-duration-shadow) ease;
    text-decoration: none;
    border: none;
    appearance: none;
    --btn-height: 2.5rem;
    --btn-min-width: auto;
    --btn-padding-inline: var(--spacing-3-5);
    --btn-padding-block: var(--spacing-1);
    --btn-font-size: var(--text-sm);
    --btn-line-height: var(--line-height-sm);
    height: var(--btn-height);
    min-width: var(--btn-min-width);
    padding-inline: var(--btn-padding-inline);
    padding-block: var(--btn-padding-block);
    font-size: var(--btn-font-size);
    line-height: var(--btn-line-height);
  }
  .btn-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }
  .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .btn:focus-visible {
    outline: 2px solid var(--color-palette-cyan-solid-bg);
    outline-offset: 2px;
  }

  /* palette variables (default: gray) */
  .btn {
    --btn-solid-bg: var(--color-palette-gray-solid-bg);
    --btn-solid-bg-hover: var(--color-palette-gray-solid-bg-hover);
    --btn-solid-bg-active: var(
      --color-palette-gray-solid-bg-active,
      var(--color-palette-gray-solid-bg-hover)
    );
    --btn-solid-fg: var(--color-palette-gray-solid-fg);

    --btn-surface-bg: var(--color-palette-gray-surface-bg);
    --btn-surface-bg-hover: var(--color-palette-gray-surface-bg-hover);
    --btn-surface-bg-active: var(--color-palette-gray-surface-bg-active);
