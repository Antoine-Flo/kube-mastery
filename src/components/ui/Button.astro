    --btn-surface-border-hover: var(--color-palette-gray-surface-border-hover);
    --btn-surface-fg: var(--color-palette-gray-surface-fg);

    --btn-subtle-bg: var(--color-palette-gray-subtle-bg);
    --btn-subtle-bg-hover: var(--color-palette-gray-subtle-bg-hover);
    --btn-subtle-bg-active: var(--color-palette-gray-subtle-bg-active);
    --btn-subtle-fg: var(--color-palette-gray-subtle-fg);

    --btn-outline-border: var(--color-palette-gray-outline-border);
    --btn-outline-bg-hover: var(--color-palette-gray-outline-bg-hover);
    --btn-outline-bg-active: var(--color-palette-gray-outline-bg-active);
    --btn-outline-fg: var(--color-palette-gray-outline-fg);

    --btn-plain-fg: var(--color-palette-gray-plain-fg);
    --btn-plain-bg-hover: var(--color-palette-gray-plain-bg-hover);
    --btn-plain-bg-active: var(--color-palette-gray-plain-bg-active);
  }

  .btn[data-color='cyan'] {
