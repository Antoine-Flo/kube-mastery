    --btn-surface-border-hover: var(--color-palette-green-surface-border-hover);
    --btn-surface-fg: var(--color-palette-green-surface-fg);

    --btn-subtle-bg: var(--color-palette-green-subtle-bg);
    --btn-subtle-bg-hover: var(--color-palette-green-subtle-bg-hover);
    --btn-subtle-bg-active: var(--color-palette-green-subtle-bg-active);
