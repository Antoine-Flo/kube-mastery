---
interface Props {
  class?: string
  lang?: 'en' | 'fr'
}

import TerminalWindow from './TerminalWindow.astro'
import { useTranslations } from '../i18n/utils'

const { class: className = '', lang = 'en' } = Astro.props
const t = useTranslations(lang)
---

<TerminalWindow
  class={className}
  lang={lang}
  topPrompt={t('terminal_topPrompt')}
  commandLimit={6}
  commandLimitMessage={t('home_terminal_limit_message')}
/>
