---
import { getLangFromUrl, getPathWithoutLocale, useTranslations, useTranslatedPath, useLocalePath } from "../i18n/utils.js";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const localePath = useLocalePath(lang);
const currentPath = getPathWithoutLocale(Astro.url);
---
<footer>
	<nav>
		<a href={localePath("/terms-of-service")}>{t("footer_termsOfService")}</a>
		<a href={localePath("/privacy-policy")}>{t("footer_privacyPolicy")}</a>
		<a href={localePath("/contact")}>{t("footer_contact")}</a>
	</nav>
	<div class="lang">
		<a href={translatePath(currentPath, "en")}>EN</a>
		<span aria-hidden="true"> · </span>
		<a href={translatePath(currentPath, "fr")}>FR</a>
	</div>
</footer>

<style>
	footer {
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: center;
		gap: 1.5rem;
		padding: 0.7rem;
		border-top: 1px solid var(--color-gray-6);
		background-color: var(--color-gray-1);
	}
	nav {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 1.5rem;
	}
	footer a {
		color: var(--color-gray-11);
		font-size: var(--text-sm);
		text-decoration: none;
		transition: color 0.2s;
	}
	footer a:hover {
		color: var(--color-gray-12);
	}
	.lang {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}
	.lang :global(.select) {
		width: auto;
	}
</style>
