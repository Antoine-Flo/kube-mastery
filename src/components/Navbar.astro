---
import { Moon, Sun } from '@lucide/astro'
import Logo from './Logo.astro'
import Button from './ui/Button.astro'
import NavbarUserMenu from './NavbarUserMenu.astro'
import { getLangFromUrl, useTranslations, useLocalePath } from '../i18n/utils'

interface NavbarUser {
  id: string
  email?: string
  user_metadata?: { full_name?: string }
}

interface Props {
  /** Auth state from Layout (centralized to avoid cookies set in component). */
  isLoggedIn?: boolean
  user?: NavbarUser | null
  hasPaidSubscription?: boolean
  /** When true, navbar inner is full width (e.g. landing page). */
  fullWidth?: boolean
}

const {
  isLoggedIn = false,
  user = null,
  hasPaidSubscription = false,
  fullWidth = false
} = Astro.props
const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const localePath = useLocalePath(lang)
const userDisplayName = user?.user_metadata?.full_name ?? ''
const userEmail = user?.email ?? ''
---

<header
  class:list={{
    'navbar--logged-in': isLoggedIn,
    'navbar--full-width': fullWidth
  }}
>
  <div class="navbar-inner">
    <a
      href={isLoggedIn ? localePath('/courses') : localePath('/')}
      class="logo"
    >
      <Logo size={27} class="logo-icon" />
      {!isLoggedIn && <span class="logo-name">{t('nav_appName')}</span>}
    </a>

    <div class="right">
      <nav>
        <a href={localePath('/courses')}>{t('nav_courses')}</a>
        <a href={localePath('/supported')}>{t('nav_supported')}</a>
        {!isLoggedIn && <a href={localePath('/pricing')}>{t('nav_pricing')}</a>}
        {
          isLoggedIn && !hasPaidSubscription && (
            <a href={localePath('/pricing')}>{t('nav_upgrade')}</a>
          )
        }
        {
          isLoggedIn ? (
            <NavbarUserMenu
              userDisplayName={userDisplayName}
              userEmail={userEmail}
              profileHref={localePath('/profile')}
              signoutHref={`/api/auth/signout?lang=${lang}`}
              lang={lang}
            />
          ) : (
            <>
              <Button
                href={localePath('/auth')}
                variant="solid"
                color="cyan"
                size="sm"
              >
                {t('nav_login')}
              </Button>
              <div class="acts">
                <Button
                  type="button"
                  variant="plain"
                  size="sm"
                  class="theme-toggle-btn"
                  data-theme-toggle
                  aria-label={t('nav_toggleTheme')}
                >
                  <Moon size={18} class="moon" />
                  <Sun size={18} class="sun" />
                </Button>
              </div>
            </>
          )
        }
      </nav>
    </div>
  </div>
</header>

<style>
  header {
    border-color: var(--color-gray-6);
    background-color: var(--color-gray-1);
    border-bottom: 1px solid var(--color-gray-6);
    padding: 0.7rem 1rem;
    display: flex;
    justify-content: center;
  }

  .navbar-inner {
    width: 100%;
    max-width: var(--content-max-width);
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  header.navbar--logged-in .navbar-inner,
  header.navbar--full-width .navbar-inner {
    max-width: none;
  }

  .right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-left: auto;
    flex-shrink: 0;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: var(--text-lg);
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-12);
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-icon {
    flex-shrink: 0;
  }

  .logo-name {
    position: relative;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  nav a {
    color: var(--color-gray-11);
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
  }
  nav a:hover {
    color: var(--color-gray-12);
  }

  .acts {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .theme-toggle-btn :global(.moon) {
    display: block;
  }

  .theme-toggle-btn :global(.sun) {
    display: none;
  }
  :global([data-theme='dark']) .theme-toggle-btn :global(.moon) {
    display: none;
  }
  :global([data-theme='dark']) .theme-toggle-btn :global(.sun) {
    display: block;
  }

  @media (max-width: 768px) {
    header {
      padding: 0.6rem 0.5rem;
    }
    .navbar-inner {
      padding: 0 0.5rem;
    }
    .logo {
      font-size: var(--text-md);
    }
    .right {
      gap: 0.5rem;
    }
    nav {
      gap: 0.75rem 1rem;
    }
    nav a {
      font-size: var(--text-sm);
    }
  }

  @media (max-width: 480px) {
    header {
      padding: 0.5rem 0.25rem;
    }
    .navbar-inner {
      padding: 0 0.25rem;
    }
    nav {
      gap: 0.5rem 0.75rem;
    }
    .right {
      gap: 0.1rem;
    }
  }
</style>

<script>
  import { initTheme, toggleTheme } from '../lib/theme-client'

  function handleDocumentClick(e: Event) {
    const target = (e.target as HTMLElement).closest?.('[data-theme-toggle]')
    if (target) {
      e.preventDefault()
      e.stopPropagation()
      toggleTheme()
    }
  }

  function setupThemeToggle() {
    initTheme()
    document.removeEventListener('click', handleDocumentClick, true)
    document.addEventListener('click', handleDocumentClick, true)
  }

  setupThemeToggle()
  document.addEventListener('astro:page-load', setupThemeToggle)
</script>
