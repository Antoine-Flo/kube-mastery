---
interface Props {
  class?: string
  lang?: 'en' | 'fr'
  /** Seed name for lesson page; omitted = home (demo). */
  seedName?: string
  /** Full height layout (lesson page). */
  fullHeight?: boolean
  /** Persist id for view transitions (lesson page). */
  persistId?: string
  /** Optional text written at top when terminal loads (e.g. home banner). Omitted = none. */
  topPrompt?: string
  /** Lesson page: use shared env from page script (no persist). */
  lessonTerminal?: boolean
  /** Show min/max/close controls (home only; hidden on lesson). */
  showControls?: boolean
  /** Optional command limit for demo terminals. */
  commandLimit?: number
  /** Message shown when command limit is reached. */
  commandLimitMessage?: string
}

import { Minus, Square, X } from '@lucide/astro'
import 'jquery.terminal/css/jquery.terminal.css'

const {
  class: className = '',
  lang = 'en',
  seedName,
  fullHeight = false,
  persistId,
  topPrompt,
  lessonTerminal = false,
  showControls = true,
  commandLimit,
  commandLimitMessage
} = Astro.props
const rootClass = ['t-win', fullHeight && 't-win--full', className]
  .filter(Boolean)
  .join(' ')
---

<div
  class={rootClass}
  id={persistId ?? undefined}
  transition:persist={persistId ?? undefined}
  data-terminal-window
  data-lang={lang}
  data-seed-name={seedName ?? undefined}
  data-persist-id={persistId ?? undefined}
  data-top-prompt={topPrompt != null ? JSON.stringify(topPrompt) : undefined}
  data-lesson-terminal={lessonTerminal ? 'true' : undefined}
  data-command-limit={commandLimit ?? undefined}
  data-command-limit-message={commandLimitMessage ?? undefined}
>
  {
    showControls && (
      <div class="t-ctrl" aria-hidden="true">
        <span class="t-btn t-btn--min">
          <Minus size={14} />
        </span>
        <span class="t-btn t-btn--max">
          <Square size={14} />
        </span>
        <span class="t-btn t-btn--close">
          <X size={14} />
        </span>
      </div>
    )
  }
  <div class="t-load">
    <span class="t-load-txt">Loading terminal…</span>
  </div>
  <div
    class="t-editor-overlay"
    tabindex="-1"
    role="dialog"
    aria-modal="true"
    aria-label="Nano editor"
    data-loading="false"
    hidden
  >
    <div class="t-editor-header" aria-hidden="true">
      <span class="t-editor-header-left">GNU nano</span>
      <span class="t-editor-header-center"></span>
      <span class="t-editor-header-right"></span>
    </div>
    <div class="t-editor-box"></div>
    <div class="t-editor-footer">
      <span class="t-editor-shortcuts" aria-live="polite"></span>
    </div>
  </div>
  <div class="t-wrap" style="display: none;">
    <div class="t-box"></div>
  </div>
</div>

<script>
  import type { CodeMirrorEditor } from '../core/editor/CodeMirrorEditor'
  import type { EditorModal } from '../core/shell/commands'
  import {
    focusTerminal,
    lockTerminalInput,
    resumeTerminalInteraction,
    suspendTerminalInteraction,
    unlockTerminalInput
  } from '../core/terminal/TerminalManager'
  import { mountTerminal } from './terminal-mount'

  type EditorModalWithLifecycle = EditorModal & {
    close(): void
    updateThemeIfOpen?(): void
  }

  const cleanups = new Map<Element, () => void>()
  const persistIdByRoot = new Map<Element, string>()
  const editorModalByRoot = new Map<Element, EditorModalWithLifecycle>()
  /** Évite d'enregistrer deux listeners "lesson-env-ready" pour le même root (init + astro:page-load). */
  const lessonPending = new WeakSet<Element>()

  const CODE_MIRROR_LOAD_DELAY_MS = 750
  let codeMirrorEditorModulePromise: Promise<
    typeof import('../core/editor/CodeMirrorEditor')
  > | null = null

  function scheduleCodeMirrorEditorPrefetch() {
    if (codeMirrorEditorModulePromise) {
      return
    }
    codeMirrorEditorModulePromise = new Promise((resolve, reject) => {
      setTimeout(() => {
        import('../core/editor/CodeMirrorEditor').then(resolve, reject)
      }, CODE_MIRROR_LOAD_DELAY_MS)
    })
  }

  const themeObserver = new MutationObserver(() => {
    editorModalByRoot.forEach((modal) => modal.updateThemeIfOpen?.())
  })
  themeObserver.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-theme']
  })

  function getTheme(): 'dark' | 'light' {
    return document.documentElement.getAttribute('data-theme') === 'light'
      ? 'light'
      : 'dark'
  }

  function createEditorModal(
    overlayEl: HTMLElement,
    editorBoxEl: HTMLElement
  ): EditorModalWithLifecycle {
    const DEFAULT_STATUS = '^X Exit ^O Write Out'
    const WRITE_OUT_STATUS = 'Write Out, press Enter to confirm, Esc to cancel'
    const EXIT_CONFIRM_STATUS = 'Save modified buffer? Y Yes, N No, ^C Cancel'
    let currentEditor: CodeMirrorEditor | null = null
    let currentOnSave: ((content: string) => boolean | void) | null = null
    let currentOnCancel: (() => void) | null = null
    let currentFilename = ''
    let initialContent = ''
    let isWriteOutPending = false
    let isExitConfirmPending = false
    let isDirty = false
    let isClosing = false
    const statusEl = overlayEl.querySelector('.t-editor-shortcuts')
    const headerFilenameEl = overlayEl.querySelector('.t-editor-header-center')
    const headerModifiedEl = overlayEl.querySelector('.t-editor-header-right')

    const setStatus = (value: string) => {
      if (statusEl) {
        statusEl.textContent = value
      }
    }

    const setHeaderFilename = (value: string) => {
      if (headerFilenameEl) {
        headerFilenameEl.textContent = value
      }
    }

    const setHeaderModified = (modified: boolean) => {
      if (headerModifiedEl) {
        headerModifiedEl.textContent = modified ? 'Modified' : ''
      }
    }

    const resetTransientState = () => {
      isWriteOutPending = false
      isExitConfirmPending = false
    }

    const saveCurrentBuffer = (): boolean => {
      if (currentEditor == null || currentOnSave == null) {
        return false
      }
      const shouldClose = currentOnSave(currentEditor.getValue())
      if (shouldClose === false) {
        setStatus(`Error writing ${currentFilename}`)
        return false
      }
      close('save')
      return true
    }

    const handleKeydown = (e: KeyboardEvent) => {
      const key = e.key.toLowerCase()
      if ((e.metaKey || e.ctrlKey) && key === 's') {
        e.preventDefault()
        e.stopPropagation()
        return
      }

      if (isExitConfirmPending) {
        if (!e.metaKey && !e.ctrlKey && !e.altKey && key === 'y') {
          e.preventDefault()
          e.stopPropagation()
          isExitConfirmPending = false
          saveCurrentBuffer()
          return
        }
        if (!e.metaKey && !e.ctrlKey && !e.altKey && key === 'n') {
          e.preventDefault()
          e.stopPropagation()
          close()
          return
        }
        if (e.key === 'Escape' || (e.ctrlKey && key === 'c')) {
          e.preventDefault()
          e.stopPropagation()
          isExitConfirmPending = false
          setStatus(DEFAULT_STATUS)
          return
        }
        e.preventDefault()
        e.stopPropagation()
        return
      }

      if (isWriteOutPending) {
        if (e.key === 'Enter') {
          e.preventDefault()
          e.stopPropagation()
          saveCurrentBuffer()
          return
        }
        if (e.key === 'Escape' || (e.ctrlKey && key === 'c')) {
          e.preventDefault()
          e.stopPropagation()
          isWriteOutPending = false
          setStatus(DEFAULT_STATUS)
          return
        }
        e.preventDefault()
        e.stopPropagation()
        return
      }

      if (e.key === 'Escape') {
        e.preventDefault()
        e.stopPropagation()
        close()
      }
    }

    const close = (reason: 'save' | 'cancel' = 'cancel') => {
      if (isClosing || overlayEl.hidden) {
        return
      }
      isClosing = true
      overlayEl.removeEventListener('keydown', handleKeydown, true)
      overlayEl.dataset.loading = 'false'
      if (reason === 'cancel') {
        currentOnCancel?.()
      }
      if (currentEditor) {
        currentEditor.destroy()
        currentEditor = null
      }
      currentOnSave = null
      currentOnCancel = null
      currentFilename = ''
      initialContent = ''
      isDirty = false
      resetTransientState()
      setHeaderFilename('')
      setHeaderModified(false)
      setStatus('')
      overlayEl.hidden = true
      resumeTerminalInteraction()
      unlockTerminalInput()
      focusTerminal()
      isClosing = false
    }

    const updateThemeIfOpen = () => {
      if (!overlayEl.hidden && currentEditor) {
        currentEditor.updateTheme(getTheme())
      }
    }

    const open: EditorModal['open'] = (filename, content, onSave, onCancel) => {
      if (!overlayEl.hidden) {
        close()
      }
      if (currentEditor) {
        currentEditor.destroy()
        currentEditor = null
      }
      currentOnSave = onSave
      currentOnCancel = onCancel ?? null
      currentFilename = filename
      initialContent = content
      isDirty = false
      resetTransientState()
      setHeaderFilename(filename)
      setHeaderModified(false)
      setStatus('[ Loading editor... ]')
      overlayEl.dataset.loading = 'true'
      overlayEl.hidden = false
      overlayEl.addEventListener('keydown', handleKeydown, true)
      suspendTerminalInteraction()
      lockTerminalInput()
      overlayEl.focus({ preventScroll: true })
      queueMicrotask(() => {
        if (overlayEl.hidden) {
          return
        }
        lockTerminalInput()
        overlayEl.focus({ preventScroll: true })
      })

      scheduleCodeMirrorEditorPrefetch()

      void (async () => {
        try {
          const { createCodeMirrorEditor } =
            await codeMirrorEditorModulePromise!
          if (overlayEl.hidden || !currentOnSave) {
            return
          }
          const theme = getTheme()
          const editor = createCodeMirrorEditor({
            theme,
            filename,
            onRequestWriteOut: () => {
              isWriteOutPending = true
              isExitConfirmPending = false
              setStatus(WRITE_OUT_STATUS)
            },
            onRequestExit: () => {
              if (!isDirty) {
                close()
                return
              }
              isWriteOutPending = false
              isExitConfirmPending = true
              setStatus(EXIT_CONFIRM_STATUS)
            }
          })
          currentEditor = editor
          editor.mount(editorBoxEl)
          editor.setValue(content)
          editor.onChange((value) => {
            isDirty = value !== initialContent
            isExitConfirmPending = false
            setHeaderModified(isDirty)
            if (!isWriteOutPending) {
              setStatus(DEFAULT_STATUS)
            }
          })
          overlayEl.dataset.loading = 'false'
          setStatus(DEFAULT_STATUS)
          const focusEditor = () => {
            lockTerminalInput()
            editor.focus()
          }
          const hasEditorFocus = () => {
            const activeElement = document.activeElement
            if (activeElement == null) {
              return false
            }
            return editorBoxEl.contains(activeElement)
          }
          const ensureEditorFocus = (attemptsLeft: number) => {
            if (overlayEl.hidden) {
              return
            }
            focusEditor()
            if (hasEditorFocus()) {
              return
            }
            if (attemptsLeft <= 0) {
              return
            }
            setTimeout(() => {
              ensureEditorFocus(attemptsLeft - 1)
            }, 40)
          }
          ensureEditorFocus(8)
        } catch (err) {
          console.error('[TerminalWindow] CodeMirror load failed:', err)
          close()
        }
      })()
    }

    return { open, close, updateThemeIfOpen }
  }

  function init() {
    scheduleCodeMirrorEditorPrefetch()
    document.querySelectorAll('[data-terminal-window]').forEach((root) => {
      const el = root as HTMLElement
      const box = el.querySelector('.t-box') as HTMLElement
      const loader = el.querySelector('.t-load') as HTMLElement
      const wrapper = el.querySelector('.t-wrap') as HTMLElement
      const overlayEl = el.querySelector('.t-editor-overlay') as HTMLElement
      const editorBoxEl = el.querySelector('.t-editor-box') as HTMLElement
      if (!box || !loader || !wrapper || !overlayEl || !editorBoxEl) {
        return
      }

      const isLesson =
        el.dataset.lessonTerminal === 'true' || el.closest('.lp-root') != null
      const lessonLayoutRoot = el.closest('.lesson-layout-root')
      const isMobileTerminalClosedAtBoot =
        isLesson &&
        lessonLayoutRoot instanceof HTMLElement &&
        window.matchMedia('(max-width: 1024px)').matches &&
        lessonLayoutRoot.getAttribute('data-terminal-open') !== 'true'
      // Déjà monté (évite double terminal après astro:page-load / view transitions)
      if (box.querySelector('.terminal')) {
        loader.style.display = 'none'
        wrapper.style.display = 'flex'
        return
      }

      const pid = el.dataset.persistId
      if (cleanups.has(root)) {
        return
      }

      const lang = (el.dataset.lang === 'fr' ? 'fr' : 'en') as 'en' | 'fr'
      const seedName = el.dataset.seedName
      const topPromptRaw = el.dataset.topPrompt
      const topPrompt = topPromptRaw
        ? (JSON.parse(topPromptRaw) as string)
        : undefined
      const commandLimit = el.dataset.commandLimit
        ? Number(el.dataset.commandLimit)
        : undefined
      const commandLimitMessage = el.dataset.commandLimitMessage

      const editorModal = createEditorModal(overlayEl, editorBoxEl)
      editorModalByRoot.set(root, editorModal)

      const doMount = (
        opts: NonNullable<Parameters<typeof mountTerminal>[1]>
      ) => {
        try {
          const cleanup = mountTerminal(box, {
            ...opts,
            editorModal
          })
          cleanups.set(root, () => {
            editorModalByRoot.delete(root)
            lessonPending.delete(root)
            cleanup()
          })
          if (pid) persistIdByRoot.set(root, pid)
          loader.style.display = 'none'
          wrapper.style.display = 'flex'
        } catch (err) {
          lessonPending.delete(root)
          console.error('[TerminalWindow] Mount failed:', err)
          loader.textContent = 'Terminal unavailable.'
        }
      }

      if (!isLesson) {
        doMount({
          lang,
          ...(seedName && { seedName }),
          ...(topPrompt !== undefined && { topPrompt }),
          ...(commandLimit !== undefined &&
            !Number.isNaN(commandLimit) && { commandLimit }),
          ...(commandLimitMessage && { commandLimitMessage })
        })
        return
      }
      if (isMobileTerminalClosedAtBoot) {
        return
      }
      if (lessonPending.has(root)) {
        return
      }
      lessonPending.add(root)
      const g = globalThis as unknown as {
        __lessonEnv?: import('../core/emulatedEnvironment/EmulatedEnvironment').EmulatedEnvironment
      }
      const withEnv = (env: typeof g.__lessonEnv) => {
        if (env) {
          doMount({ env, lang })
        }
      }
      if (g.__lessonEnv) {
        withEnv(g.__lessonEnv)
        return
      }
      const onLessonEnvReady = (ev: Event) => {
        const env = (ev as CustomEvent).detail?.env
        if (!env) {
          lessonPending.delete(root)
          return
        }
        withEnv(env)
      }
      document.addEventListener('lesson-env-ready', onLessonEnvReady, {
        once: true
      })
      document.addEventListener('cluster-env-ready', onLessonEnvReady, {
        once: true
      })
    })
  }

  init()
  document.addEventListener('astro:page-load', init)

  document.addEventListener('lesson-terminal-reload', () => {
    const lessonRoots: Element[] = []
    cleanups.forEach((_, root) => {
      const el = root as HTMLElement
      if (el.dataset.lessonTerminal === 'true') {
        lessonRoots.push(root)
      }
    })
    lessonRoots.forEach((root) => {
      const cleanup = cleanups.get(root)
      if (cleanup) {
        cleanup()
        cleanups.delete(root)
        lessonPending.delete(root)
        const pid = persistIdByRoot.get(root)
        if (pid) {
          persistIdByRoot.delete(root)
        }
      }
    })
    // Defer remount so lesson env reset listeners run first.
    setTimeout(() => {
      init()
    }, 0)
  })

  document.addEventListener('lesson-terminal-open', () => {
    init()
  })

  document.addEventListener('astro:before-swap', (ev: Event) => {
    const newDoc = (ev as { newDocument?: Document }).newDocument
    cleanups.forEach((cleanup, root) => {
      const pid = persistIdByRoot.get(root)
      if (newDoc) {
        if (pid && newDoc.getElementById(pid)) {
          return
        }
      }
      cleanup()
      cleanups.delete(root)
      lessonPending.delete(root)
      if (pid) persistIdByRoot.delete(root)
    })
  })
</script>

<style>
  .t-win {
    padding: var(--spacing-4);
    position: relative;
    /* background-color: var(--color-gray-1); */
  }
  .t-win:not(.t-win--full) {
    height: 490px;
  }
  .t-win--full {
    height: 100%;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }
  .t-ctrl {
    position: absolute;
    top: var(--spacing-2);
    right: var(--spacing-2);
    display: flex;
    gap: var(--spacing-2);
    z-index: 20;
  }
  .t-btn {
    flex-shrink: 0;
    opacity: 0.6;
    transition: opacity var(--duration-fast);
  }
  .t-btn:hover {
    opacity: 1;
  }
  .t-btn--close {
    color: var(--color-ruby-11);
  }
  .t-btn--max {
    color: var(--color-green-11);
  }
  .t-btn--min {
    color: var(--color-amber-11);
  }
  .t-load {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
  }
  .t-win:not(.t-win--full) .t-load {
    height: 450px;
  }
  .t-win--full .t-load {
    flex: 1;
    min-height: 0;
  }
  .t-load-txt {
    color: var(--color-gray-11);
  }
  .t-wrap {
    position: relative;
    width: 100%;
    height: 100%;
  }
  .t-win--full .t-wrap {
    flex: 1;
    min-height: 0;
  }
  .t-box {
    width: 100%;
    min-height: 200px;
    background-color: var(--color-gray-1);
    text-align: left;
    overflow: hidden;
  }
  .t-win:not(.t-win--full) .t-box {
    height: 450px;
  }
  .t-win--full .t-box {
    height: 100%;
  }
  .t-editor-overlay {
    position: absolute;
    inset: 0;
    z-index: 10;
    display: grid;
    grid-template-rows: auto 1fr auto;
    height: 100%;
    min-height: 0;
    background-color: var(--color-gray-1);
    outline: none;
  }
  .t-editor-overlay[hidden] {
    display: none;
  }
  .t-editor-box {
    min-height: 0;
    overflow: hidden;
    border-radius: var(--radius-xs);
    display: flex;
    flex-direction: column;
  }
  .t-editor-header {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--spacing-2);
    padding: 2px var(--spacing-2);
    background: #d6d6d6;
    color: #1a1a1a;
    font-family: var(--font-mono);
    font-size: var(--font-size-1);
    line-height: 1.2;
    white-space: nowrap;
  }
  .t-editor-header-left {
    justify-self: start;
  }
  .t-editor-header-center {
    justify-self: center;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }
  .t-editor-header-right {
    justify-self: end;
  }
  .t-editor-box .cm-editor {
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }
  .t-editor-box .cm-scroller {
    overflow: auto;
    min-height: 0;
  }
  .t-editor-footer {
    display: block;
    padding: var(--spacing-2) var(--spacing-3);
    background: var(--color-gray-1);
    font-family: var(--font-mono);
  }
  .t-editor-shortcuts {
    display: block;
    font-size: var(--font-size-1);
    color: var(--color-gray-10);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .t-editor-overlay[data-loading='true'] .t-editor-box {
    opacity: 0.7;
  }
</style>
