---
import { BookOpen, Compass, Code, Shield, Gem } from '@lucide/astro'

interface Props {
  title: string
  description: string | null
  href: string
  totalLessons: number
  lessonsLabel: string
  comingSoon?: boolean
  inProgress?: boolean
  startHere?: boolean
  level?: string | null
  freeLabel?: string
  comingSoonLabel?: string
  inProgressLabel?: string
  startHereLabel?: string
  isFree?: boolean
  visualVariant?: 'fundamentals' | 'developer' | 'operator' | 'crash'
}

const {
  title,
  description,
  href,
  totalLessons,
  lessonsLabel,
  comingSoon = false,
  inProgress = false,
  startHere = false,
  level,
  freeLabel = 'Free',
  comingSoonLabel = 'Coming soon',
  inProgressLabel = 'In progress',
  startHereLabel = 'Start here',
  isFree = false,
  visualVariant
} = Astro.props

const descriptionText = description ?? ''

const hasBadgeRow = startHere || inProgress || comingSoon || isFree
---

<article
  class:list={[
    'course-card',
    !comingSoon && 'course-card--interactive',
    startHere && 'course-card--start-here',
    comingSoon && 'course-card--coming-soon'
  ]}
>
  <a href={comingSoon ? '#' : href} class="course-card__link">
    <header class="course-card__header">
      <div
        class:list={[
          'course-card__icon',
          visualVariant && `course-card__icon--${visualVariant}`
        ]}
      >
        {
          visualVariant === 'fundamentals' && (
            <Compass size={16} aria-hidden="true" />
          )
        }
        {visualVariant === 'developer' && <Code size={16} aria-hidden="true" />}
        {
          visualVariant === 'operator' && (
            <Shield size={16} aria-hidden="true" />
          )
        }
        {visualVariant === 'crash' && <Gem size={16} aria-hidden="true" />}
      </div>
      <h3 class="course-card__title">{title}</h3>
    </header>

    {
      hasBadgeRow && (
        <div class="course-card__badges">
          {startHere && (
            <span class="badge badge--start">{startHereLabel}</span>
          )}
          {inProgress && (
            <span class="badge badge--progress">{inProgressLabel}</span>
          )}
          {comingSoon && (
            <span class="badge badge--soon">{comingSoonLabel}</span>
          )}
          {isFree && <span class="badge badge--free">{freeLabel}</span>}
        </div>
      )
    }

    <div class="course-card__desc-wrap">
      {
        descriptionText && (
          <p class="course-card__description">{descriptionText}</p>
        )
      }
    </div>

    <footer class="course-card__meta">
      {
        totalLessons > 0 && (
          <span class="course-card__lessons">
            <BookOpen size={14} aria-hidden="true" />
            {lessonsLabel}
          </span>
        )
      }
      {level && <span class="course-card__level">{level}</span>}
    </footer>
  </a>
</article>

<style>
  .course-card {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    height: 12.5rem;
    flex-shrink: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-l3);
    background-color: var(--color-palette-gray-surface-bg);
    overflow: hidden;
  }

  .course-card--interactive {
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    transition:
      border-color 0.15s,
      background-color 0.15s;
  }

  .course-card--interactive:hover {
    border-color: var(--color-cyan-7);
    background-color: var(--color-cyan-2);
  }

  .course-card--interactive:active {
    background-color: var(--color-gray-2);
  }

  :global([data-theme='dark']) .course-card--interactive:active {
    background-color: var(--color-gray-3);
  }

  .course-card--interactive:hover:active {
    background-color: var(--color-cyan-1);
  }

  :global([data-theme='dark']) .course-card--interactive:hover:active {
    background-color: var(--color-cyan-4);
  }

  .course-card--start-here {
    border-color: var(--color-green-6);
  }

  .course-card--coming-soon {
    opacity: 0.8;
    pointer-events: none;
  }

  .course-card__link {
    box-sizing: border-box;
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    min-height: 0;
    height: 100%;
    gap: 0.7rem;
    padding: 0.9rem;
    text-decoration: none;
    color: inherit;
  }

  .course-card__header {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    flex-shrink: 0;
  }

  .course-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 9999px;
    background-color: var(--color-gray-4);
    color: var(--color-gray-11);
    flex-shrink: 0;
  }

  .course-card__icon--fundamentals {
    background-color: var(--color-green-3);
    color: var(--color-green-11);
  }

  .course-card__icon--developer {
    background-color: var(--color-amber-3);
    color: var(--color-amber-11);
  }

  .course-card__icon--operator {
    background-color: var(--color-ruby-3);
    color: var(--color-ruby-11);
  }

  .course-card__icon--crash {
    background-color: var(--color-cyan-3);
    color: var(--color-cyan-11);
  }

  .course-card__title {
    margin: 0;
    font-size: clamp(1.1rem, 0.95rem + 0.45vw, 1.35rem);
    line-height: 1.25;
    font-weight: var(--font-weight-semibold);
    color: var(--color-gray-12);
  }

  .course-card__badges {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  .course-card__desc-wrap {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .badge {
    font-size: var(--text-xs);
    line-height: 1.25;
    border-radius: 9999px;
    padding: 0.24rem 0.56rem;
    border: 1px solid transparent;
  }

  .badge--start {
    color: var(--color-green-11);
    border-color: var(--color-green-5);
    background-color: var(--color-green-2);
  }

  .badge--progress {
    color: var(--color-cyan-11);
    border-color: var(--color-cyan-5);
    background-color: var(--color-cyan-2);
  }

  .badge--soon {
    color: var(--color-amber-11);
    border-color: var(--color-amber-5);
    background-color: var(--color-amber-2);
  }

  .badge--free {
    color: var(--color-violet-11);
    border-color: var(--color-violet-5);
    background-color: var(--color-violet-2);
  }

  .course-card__description {
    margin: 0;
    color: var(--color-fg-muted);
    font-size: var(--text-sm);
    line-height: 1.5;
  }

  .course-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
    flex-shrink: 0;
  }

  .course-card__lessons {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: var(--text-xs);
    color: var(--color-gray-11);
  }

  .course-card__level {
    font-size: var(--text-xs);
    color: var(--color-fg-muted);
  }
</style>
