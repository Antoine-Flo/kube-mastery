---
interface Props {
  title: string;
  description: string | null;
  totalLessons: number;
  href: string;
  isFree?: boolean;
  comingSoon?: boolean;
  level?: string | null;
  lessonsLabel: string;
  freeBadgeLabel?: string;
  comingSoonLabel?: string;
}

const { title, description, totalLessons, href, isFree = false, comingSoon = false, level = null, lessonsLabel, freeBadgeLabel = "Free", comingSoonLabel = "Coming soon" } = Astro.props;
const descriptionText = description ?? "";
---

<a
  href={comingSoon ? "#" : href}
  class:list={[
    "card",
    "card--outline",
    "courses__card--clickable",
    isFree && "courses__card--free",
    comingSoon && "courses__card--coming-soon",
  ]}
>
  {isFree && (
    <div class="courses__card-free-banner">
      {freeBadgeLabel}
    </div>
  )}
  <div class="card__header">
    <h3 class="card__title courses__card-title">{title}</h3>
    {level && <span class="course-card__level">{level}</span>}
  </div>
  <div class="card__body">
    {descriptionText && <p class="card__description">{descriptionText}</p>}
    <div class="courses__card-features">
      <span class="courses__card-feature-item">
        <span class="courses__card-feature-text">{lessonsLabel}</span>
      </span>
    </div>
  </div>
  {comingSoon && (
    <div class="course-card__coming-soon">{comingSoonLabel}</div>
  )}
</a>

<style>
  .course-card__level {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-fg-muted);
    margin-top: 0.25rem;
  }
  .course-card__coming-soon {
    padding: 0.375rem 0.75rem;
    font-size: var(--text-xs);
    font-weight: var(--font-weight-medium);
    color: var(--color-gray-11);
    background-color: var(--color-gray-2);
    text-align: center;
    margin: 0 var(--spacing-6) var(--spacing-6);
    border-radius: var(--radius-sm);
  }
</style>
