---
interface Props {
	size?: number;
	class?: string;
}

const { size = 40, class: className } = Astro.props;
---
<svg
	viewBox="-41 -41 82 82"
	width={size}
	height={size}
	xmlns="http://www.w3.org/2000/svg"
	class={className}
	aria-hidden="true"
>
	<defs>
		<linearGradient id="logoBlueGrad" x1="0%" y1="0%" x2="100%" y2="100%">
			<stop offset="0%" style="stop-color:#326CE5;stop-opacity:1" />
			<stop offset="100%" style="stop-color:#4A90E2;stop-opacity:1" />
		</linearGradient>
	</defs>
	<g>
		<polygon
			points="0,-40 34.64,-20 34.64,20 0,40 -34.64,20 -34.64,-20"
			fill="url(#logoBlueGrad)"
			stroke="#2557C5"
			stroke-width="2"
		/>
		<circle cx="0" cy="0" r="8" fill="white" />
		<line x1="0" y1="-8" x2="0" y2="-25" stroke="white" stroke-width="3" stroke-linecap="round" />
		<line x1="7" y1="-4" x2="20" y2="-12" stroke="white" stroke-width="3" stroke-linecap="round" />
		<line x1="7" y1="4" x2="20" y2="12" stroke="white" stroke-width="3" stroke-linecap="round" />
		<line x1="0" y1="8" x2="0" y2="25" stroke="white" stroke-width="3" stroke-linecap="round" />
		<line x1="-7" y1="4" x2="-20" y2="12" stroke="white" stroke-width="3" stroke-linecap="round" />
		<line x1="-7" y1="-4" x2="-20" y2="-12" stroke="white" stroke-width="3" stroke-linecap="round" />
	</g>
</svg>
