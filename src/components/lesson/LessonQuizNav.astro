---
import Button from '../ui/Button.astro'
import type { Quiz, MultipleChoiceQuestion } from '../../types/quiz'

interface Props {
  quiz: Quiz | null
  prevHref: string
  nextHref: string
  isFirst: boolean
  isLast: boolean
  labels: {
    quizTitle: string
    questionInfo: string
    hint: string
    previous: string
    nextLesson: string
    courseComplete: string
    nextQuestion: string
  }
  /** Current lesson id: sent via sendBeacon when navigating to the next lesson. */
  lessonId?: string
}

const { quiz, prevHref, nextHref, isFirst, isLast, labels, lessonId } =
  Astro.props

// Filter to only multiple-choice questions
const mcQuestions = (quiz?.questions ?? []).filter(
  (q): q is MultipleChoiceQuestion => q.type === 'multiple-choice'
)

const hasQuiz = mcQuestions.length > 0
---

<div
  class="lesson-quiz-nav"
  data-lesson-id={lessonId}
  data-has-quiz={hasQuiz ? 'true' : 'false'}
  data-question-count={mcQuestions.length}
  data-current-index="0"
  data-quiz-completed="false"
  data-is-last={isLast ? 'true' : 'false'}
>
  {
    hasQuiz && (
      <section class="quiz" aria-labelledby="quiz-title">
        <header class="quiz__header">
          <h2 id="quiz-title" class="quiz__title">
            {labels.quizTitle}
          </h2>
          <div class="quiz__info" data-quiz-info>
            {labels.questionInfo
              .replace('{current}', '1')
              .replace('{total}', String(mcQuestions.length))}
          </div>
        </header>

        <div class="quiz__questions">
          {mcQuestions.map((q, qIndex) => (
            <article
              class="quiz__question"
              data-question-index={qIndex}
              data-question-id={q.id}
              data-correct-answer={q.correctAnswer}
              data-answered="false"
              data-result=""
              aria-hidden={qIndex !== 0 ? 'true' : 'false'}
            >
              <h3 class="quiz__question-title">{q.question}</h3>
              <div class="quiz__options" role="group" aria-label="Options">
                {q.options.map((option, optIndex) => (
                  <button
                    type="button"
                    class="quiz__option"
                    data-option-index={optIndex}
                  >
                    {option}
                  </button>
                ))}
              </div>
              {q.hint && (
                <div class="quiz__hint-container" data-hint-revealed="false">
                  <button type="button" class="quiz__hint-btn" data-hint-toggle>
                    {labels.hint}
                  </button>
                  <p class="quiz__hint-text">{q.hint}</p>
                </div>
              )}
            </article>
          ))}
        </div>
      </section>
    )
  }

  <nav class="lesson-nav">
    {
      isFirst ? (
        <span class="lesson-nav__placeholder">{labels.previous}</span>
      ) : (
        <Button href={prevHref} variant="outline" size="sm">
          {labels.previous}
        </Button>
      )
    }

    <div class="lesson-nav__next" data-nav-next>
      {/* No quiz: next lesson link; progress via sendBeacon */}
      {
        !hasQuiz && !isLast && (
          <Button
            href={nextHref}
            variant="solid"
            color="cyan"
            size="sm"
            data-nav-next-lesson
          >
            {labels.nextLesson}
          </Button>
        )
      }
      {
        !hasQuiz && isLast && (
          <span class="lesson-nav__complete">{labels.courseComplete}</span>
        )
      }
      {/* Quiz: button controlled by JS; link shown when quiz done */}
      {
        hasQuiz && (
          <>
            <Button
              variant="solid"
              color="cyan"
              size="sm"
              disabled
              class="lesson-nav__btn-question"
              data-nav-next-question
            >
              {labels.nextQuestion}
            </Button>
            <a
              href={nextHref}
              class="btn lesson-nav__btn-lesson"
              data-variant="solid"
              data-size="sm"
              data-color="cyan"
              data-nav-next-lesson
              hidden
            >
              {isLast ? labels.courseComplete : labels.nextLesson}
            </a>
          </>
        )
      }
    </div>
  </nav>
</div>

<script>
  import { sendProgressCompleteBeacon } from '../../lib/progress/sendProgressBeacon'

  function initLessonProgressBeacon(container: HTMLElement) {
    const lessonId = container.dataset.lessonId
    if (!lessonId || container.dataset.progressBeaconBound === 'true') {
      return
    }
    container.dataset.progressBeaconBound = 'true'

    container.addEventListener(
      'click',
      (e) => {
        const el = (e.target as HTMLElement).closest<HTMLElement>(
          '[data-nav-next-lesson]'
        )
        if (!el || el.getAttribute('data-disabled') === 'true') {
          return
        }
        sendProgressCompleteBeacon({ lessonId })
      },
      true
    )
  }

  function initQuizNav(container: HTMLElement) {
    const hasQuiz = container.dataset.hasQuiz === 'true'
    if (!hasQuiz) {
      return
    }

    const questionCount = parseInt(container.dataset.questionCount ?? '0', 10)
    const questions = container.querySelectorAll<HTMLElement>(
      '[data-question-index]'
    )
    const infoEl = container.querySelector<HTMLElement>('[data-quiz-info]')
    const nextQuestionBtn = container.querySelector<HTMLButtonElement>(
      '[data-nav-next-question]'
    )
    const nextLessonLink = container.querySelector<HTMLAnchorElement>(
      '[data-nav-next-lesson]'
    )

    let currentIndex = 0

    function updateInfo() {
      if (infoEl) {
        const template = infoEl.textContent ?? ''
        // Keep original template pattern for re-use
        const newText = template
          .replace(/\d+ of/, `${currentIndex + 1} of`)
          .replace(/\d+ sur/, `${currentIndex + 1} sur`)
        infoEl.textContent = newText
      }
    }

    function showQuestion(index: number) {
      questions.forEach((q, i) => {
        const isCurrent = i === index
        q.setAttribute('aria-hidden', isCurrent ? 'false' : 'true')
      })
      currentIndex = index
      container.dataset.currentIndex = String(index)
      updateInfo()
      updateNextButton()
    }

    function getCurrentQuestion(): HTMLElement | null {
      return container.querySelector(`[data-question-index="${currentIndex}"]`)
    }

    function isQuizCompleted(): boolean {
      return container.dataset.quizCompleted === 'true'
    }

    function allQuestionsCorrect(): boolean {
      return Array.from(questions).every((q) => q.dataset.result === 'correct')
    }

    function updateNextButton() {
      if (!nextQuestionBtn || !nextLessonLink) {
        return
      }

      const currentAnswered = getCurrentQuestion()?.dataset.answered === 'true'
      const isLastQuestion = currentIndex >= questionCount - 1

      // On last question: always show "Next lesson" (triggered when we arrive here via "Next question")
      // Greyed/disabled until answered, then clickable.
      if (isLastQuestion || isQuizCompleted() || allQuestionsCorrect()) {
        nextQuestionBtn.setAttribute('hidden', '')
        nextLessonLink.removeAttribute('hidden')
        if (isLastQuestion && !currentAnswered) {
          nextLessonLink.setAttribute('data-disabled', 'true')
          nextLessonLink.setAttribute('aria-disabled', 'true')
        } else {
          nextLessonLink.removeAttribute('data-disabled')
          nextLessonLink.removeAttribute('aria-disabled')
        }
      } else {
        nextLessonLink.setAttribute('hidden', '')
        nextQuestionBtn.removeAttribute('hidden')
        nextQuestionBtn.disabled = !currentAnswered
      }
    }

    function handleOptionClick(event: Event) {
      const btn = event.target as HTMLButtonElement
      if (!btn.matches('.quiz__option')) return

      const question = btn.closest<HTMLElement>('[data-question-index]')
      if (!question || question.dataset.answered === 'true') {
        return
      }

      const correctAnswer = parseInt(question.dataset.correctAnswer ?? '0', 10)
      const selectedIndex = parseInt(btn.dataset.optionIndex ?? '-1', 10)
      const isCorrect = selectedIndex === correctAnswer

      question.dataset.answered = 'true'
      question.dataset.result = isCorrect ? 'correct' : 'incorrect'
      btn.dataset.selected = 'true'
      btn.dataset.result = isCorrect ? 'correct' : 'incorrect'

      // Mark correct answer if wrong
      if (!isCorrect) {
        const correctBtn = question.querySelector<HTMLButtonElement>(
          `[data-option-index="${correctAnswer}"]`
        )
        if (correctBtn) {
          correctBtn.dataset.result = 'correct'
        }
      }

      // Disable all options so only "Next question" / "Next lesson" is clickable
      question
        .querySelectorAll<HTMLButtonElement>('.quiz__option')
        .forEach((b) => {
          b.disabled = true
        })

      if (
        parseInt(question.getAttribute('data-question-index') ?? '-1', 10) >=
        questionCount - 1
      ) {
        container.dataset.quizCompleted = 'true'
      }

      updateNextButton()
    }

    function handleHintToggle(event: Event) {
      const btn = event.target as HTMLButtonElement
      if (!btn.matches('[data-hint-toggle]')) return

      const hintContainer = btn.closest<HTMLElement>('.quiz__hint-container')
      if (hintContainer) {
        hintContainer.dataset.hintRevealed = 'true'
      }
    }

    function handleNextQuestion() {
      const question = getCurrentQuestion()
      if (!question || question.dataset.answered !== 'true') {
        return
      }
      if (currentIndex >= questionCount - 1) {
        container.dataset.quizCompleted = 'true'
        updateNextButton()
      } else {
        showQuestion(currentIndex + 1)
      }
    }

    // Event listeners
    container.addEventListener('click', (e) => {
      handleOptionClick(e)
      handleHintToggle(e)
      // Prevent "Next lesson" link from navigating when still disabled (last Q not answered)
      const target = e.target as HTMLElement
      if (
        nextLessonLink &&
        (nextLessonLink === target || nextLessonLink.contains(target)) &&
        nextLessonLink.getAttribute('data-disabled') === 'true'
      ) {
        e.preventDefault()
      }
    })

    nextQuestionBtn?.addEventListener('click', handleNextQuestion)

    // Initial state
    updateNextButton()
  }

  function init() {
    const container = document.querySelector<HTMLElement>('.lesson-quiz-nav')
    if (container) {
      initLessonProgressBeacon(container)
      initQuizNav(container)
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init)
  } else {
    init()
  }

  document.addEventListener('astro:page-load', init)
</script>

<style>
  .lesson-quiz-nav {
    margin-top: var(--spacing-8);
    padding: var(--spacing-4);
  }

  /* Quiz */
  .quiz {
    border: 1px solid var(--color-palette-gray-surface-border);
    border-radius: var(--radius-l3);
    padding: var(--spacing-4);
    margin-bottom: var(--spacing-6);
  }

  .quiz__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--spacing-4);
  }

  .quiz__title {
    font-size: var(--text-lg);
    font-weight: var(--font-weight-semibold);
    margin: 0;
  }

  .quiz__info {
    font-size: var(--text-sm);
    color: var(--color-palette-gray-fg-muted);
  }

  /* Questions - only show current */
  .quiz__question[aria-hidden='true'] {
    display: none;
  }

  .quiz__question-title {
    font-size: var(--text-md);
    font-weight: var(--font-weight-medium);
    margin: 0 0 var(--spacing-4);
  }

  .quiz__options {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  .quiz__option {
    display: block;
    width: 100%;
    text-align: left;
    padding: var(--spacing-3) var(--spacing-4);
    border: 1px solid var(--color-palette-gray-surface-border);
    border-radius: var(--radius-l2);
    background: var(--color-bg);
    color: var(--color-fg);
    font-size: var(--text-sm);
    cursor: pointer;
    transition:
      border-color 0.15s,
      background-color 0.15s;
  }

  .quiz__option:hover:not([data-selected]):not(:disabled) {
    border-color: var(--color-palette-cyan-surface-border);
    background: var(--color-palette-gray-surface-bg-hover);
  }

  .quiz__option:disabled {
    cursor: default;
  }

  .quiz__option[data-result='correct'] {
    border-color: var(--color-palette-green-solid-bg);
    background: color-mix(
      in srgb,
      var(--color-palette-green-solid-bg) 15%,
      transparent
    );
  }

  .quiz__option[data-result='incorrect'][data-selected='true'] {
    border-color: var(--color-palette-ruby-solid-bg);
    background: color-mix(
      in srgb,
      var(--color-palette-ruby-solid-bg) 15%,
      transparent
    );
  }

  /* Hint */
  .quiz__hint-container {
    margin-top: var(--spacing-4);
  }

  .quiz__hint-container[data-hint-revealed='false'] .quiz__hint-text {
    display: none;
  }

  .quiz__hint-container[data-hint-revealed='true'] .quiz__hint-btn {
    display: none;
  }

  .quiz__hint-btn {
    padding: var(--spacing-2) var(--spacing-3);
    border: 1px solid var(--color-palette-gray-surface-border);
    border-radius: var(--radius-l2);
    background: transparent;
    color: var(--color-palette-gray-fg-muted);
    font-size: var(--text-sm);
    cursor: pointer;
  }

  .quiz__hint-btn:hover {
    background: var(--color-palette-gray-surface-bg-hover);
  }

  .quiz__hint-text {
    padding: var(--spacing-3);
    border-radius: var(--radius-l2);
    background: var(--color-palette-gray-surface-bg-hover);
    color: var(--color-palette-gray-fg-muted);
    font-size: var(--text-sm);
    font-style: italic;
    margin: 0;
  }

  /* Navigation */
  .lesson-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--spacing-4);
    padding-block: var(--spacing-6);
  }

  .lesson-nav__placeholder {
    display: inline-flex;
    align-items: center;
    height: 2.25rem;
    padding-inline: var(--spacing-3);
    font-size: var(--text-sm);
    color: var(--color-palette-gray-fg-muted);
    opacity: 0.5;
  }

  .lesson-nav__complete {
    display: inline-flex;
    align-items: center;
    height: 2.25rem;
    padding-inline: var(--spacing-3);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-palette-cyan-fg);
  }

  .lesson-nav__next [hidden] {
    display: none;
  }

  /* Button styles for the link (mirroring Button component) */
  .lesson-nav__btn-lesson {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    border-radius: var(--radius-l2);
    font-weight: var(--font-weight-semibold);
    cursor: pointer;
    transition: background-color 0.2s;
    text-decoration: none;
    border: none;
    height: 2.25rem;
    padding-inline: var(--spacing-3);
    font-size: var(--text-sm);
    background: var(--color-palette-cyan-solid-bg);
    color: var(--color-palette-cyan-solid-fg);
  }

  .lesson-nav__btn-lesson:hover {
    background: var(--color-palette-cyan-solid-bg-hover);
  }

  .lesson-nav__btn-lesson[data-disabled='true'] {
    opacity: 0.6;
    cursor: not-allowed;
    pointer-events: none;
  }
</style>
