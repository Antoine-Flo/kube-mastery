---
import Dialog from '../ui/Dialog.astro'
import Button from '../ui/Button.astro'
import { Github } from 'simple-icons-astro'
import '../../styles/routes/lesson.css'

const CONTACT_SUPPORT_DIALOG_ID = 'contact-support-dialog'

interface Props {
  title: string
  placeholder: string
  submitLabel: string
  cancelLabel: string
  successToastTitle: string
  githubIssueLabel: string
  githubIssueUrl?: string
  lessonId: string
}
const {
  title,
  placeholder,
  submitLabel,
  cancelLabel,
  successToastTitle,
  githubIssueLabel,
  githubIssueUrl = '',
  lessonId
} = Astro.props
---

<Dialog id={CONTACT_SUPPORT_DIALOG_ID} title={title} size="lg">
  <form
    id="contact-support-form"
    class="contact-support-form contact-support-form--in-dialog"
    data-lesson-id={lessonId}
    method="post"
    action="#"
  >
    <textarea
      name="message"
      class="lesson__suggest-textarea contact-support-form__message"
      placeholder={placeholder}
      rows={5}
      required></textarea>
    <p
      id="contact-support-error"
      class="lesson__suggest-error contact-support-form__error"
      aria-live="polite"
      hidden
    >
    </p>
    <footer
      class="dialog__footer lesson-dialog__footer contact-support-form__footer"
    >
      {
        githubIssueUrl && (
          <div class="contact-support-form__footer-start">
            <Button
              href={githubIssueUrl}
              variant="outline"
              color="gray"
              class="contact-support-form__github-footer-button"
              target="_blank"
              rel="noopener noreferrer"
            >
              <Github size={14} />
              {githubIssueLabel}
            </Button>
          </div>
        )
      }
      <Button type="button" variant="subtle" color="gray" data-dialog-close>
        {cancelLabel}
      </Button>
      <Button type="submit" variant="solid" color="gray">
        {submitLabel}
      </Button>
    </footer>
  </form>
</Dialog>

<script
  is:inline
  define:vars={{ dialogId: CONTACT_SUPPORT_DIALOG_ID, successToastTitle }}
>
  function openContactDialog(id) {
    const dialog = document.getElementById(id)
    if (!dialog || typeof dialog.showModal !== 'function') {
      return
    }
    dialog.showModal()
    const errorEl = document.getElementById('contact-support-error')
    if (errorEl) {
      errorEl.setAttribute('hidden', '')
      errorEl.textContent = ''
    }
    const textarea = dialog.querySelector("textarea[name='message']")
    if (textarea) {
      textarea.value = ''
    }
  }

  function getFormPayload(formEl) {
    const messageEl = formEl.querySelector("textarea[name='message']")
    const message = (
      messageEl && 'value' in messageEl ? messageEl.value : ''
    ).trim()
    const lessonId = formEl.getAttribute('data-lesson-id') ?? ''
    return { type: 'suggestion', message, lessonId: lessonId || undefined }
  }

  async function sendContactMessage(payload) {
    const res = await fetch('/api/contact', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    })
    if (!res.ok) {
      const data = await res.json().catch(() => ({}))
      throw new Error(data.error ?? res.statusText)
    }
    return res
  }

  function hideError(errorEl) {
    errorEl.setAttribute('hidden', '')
    errorEl.textContent = ''
  }

  function showError(errorEl, text) {
    errorEl.textContent = text
    errorEl.removeAttribute('hidden')
  }

  function closeContactDialog(id) {
    const dialog = document.getElementById(id)
    if (dialog && typeof dialog.close === 'function') {
      dialog.close()
    }
  }

  function showSuccessToast(title) {
    document.dispatchEvent(
      new CustomEvent('toast-show', {
        detail: { title, type: 'success' }
      })
    )
  }

  async function handleContactSubmit(e, id, toastTitle) {
    e.preventDefault()
    const formEl = e.target
    if (!(formEl instanceof HTMLFormElement)) {
      return
    }
    const errorEl = document.getElementById('contact-support-error')
    if (!errorEl) {
      return
    }
    hideError(errorEl)
    const payload = getFormPayload(formEl)
    try {
      await sendContactMessage(payload)
      closeContactDialog(id)
      showSuccessToast(toastTitle)
    } catch (err) {
      showError(errorEl, err instanceof Error ? err.message : 'Erreur')
    }
  }

  document.addEventListener('contact-support-open', () => {
    openContactDialog(dialogId)
  })

  // Delegation + capture: intercept submit before anything else so form never does a native GET
  document.addEventListener(
    'submit',
    (e) => {
      const form = e.target
      if (
        !(form instanceof HTMLFormElement) ||
        form.id !== 'contact-support-form'
      ) {
        return
      }
      e.preventDefault()
      e.stopImmediatePropagation()
      handleContactSubmit(e, dialogId, successToastTitle)
    },
    true
  )
</script>

<style>
  .contact-support-form {
    width: 100%;
    box-sizing: border-box;
  }
  .contact-support-form--in-dialog {
    min-width: 0;
  }
  .contact-support-form__message {
    display: block;
    width: 100%;
    box-sizing: border-box;
    margin-bottom: var(--spacing-2);
  }
  .contact-support-form__error {
    margin-bottom: var(--spacing-2);
  }
  .contact-support-form__footer {
    border-top: none;
    padding-top: 0;
  }
  .contact-support-form__footer-start {
    margin-right: auto;
  }
  :global(.contact-support-form__github-footer-button) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-2);
  }
  :global(#contact-support-dialog .dialog__content) {
    min-height: 28rem;
  }
</style>
