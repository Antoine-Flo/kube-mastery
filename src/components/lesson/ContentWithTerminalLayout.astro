---
import LessonTerminal from '../LessonTerminal.astro'
import LessonContentBar from './LessonContentBar.astro'
import LessonClusterPanel from './LessonClusterPanel.astro'
import ContactSupportModal from './ContactSupportModal.astro'
import ScrollArea from '../ui/ScrollArea.astro'
import Button from '../ui/Button.astro'
import { useTranslations } from '../../i18n/utils'
import { ArrowLeftToLine, ArrowRightToLine } from '@lucide/astro'

interface Props {
  seedName: string
  lang: 'en' | 'fr'
  showSidebar?: boolean
  labels: {
    labelVisualizer: string
    labelCourse: string
    labelShowTerminal: string
    labelHideTerminal: string
    labelContactSupport: string
    labelReloadTerminal: string
  }
  supportContextId?: string
  /** When false, terminal is a locked placeholder (no cluster simulation). */
  terminalInteractive?: boolean
  terminalLockTitle?: string
  terminalLockBody?: string
  terminalLockTryFreeLabel?: string
  terminalLockTryFreeHref?: string
  terminalLockSecondaryLabel?: string
  terminalLockSecondaryHref?: string
}

const {
  seedName,
  lang,
  showSidebar = false,
  labels,
  supportContextId,
  terminalInteractive = true,
  terminalLockTitle = '',
  terminalLockBody = '',
  terminalLockTryFreeLabel = '',
  terminalLockTryFreeHref = '',
  terminalLockSecondaryLabel = '',
  terminalLockSecondaryHref = ''
} = Astro.props
const t = useTranslations(lang)
const showTerminalActions = terminalInteractive
---

<div class="lesson-layout-page">
  <div
    class="lesson-layout-root"
    data-seed-name={seedName}
    data-lang={lang}
    data-terminal-open="true"
    data-terminal-interactive={terminalInteractive ? 'true' : 'false'}
  >
    <div class="lesson-layout">
      {
        showSidebar && (
          <aside
            id="lesson-sidebar"
            class="lesson-layout__sidebar"
            aria-label="Plan du cours"
          >
            <div class="lesson-layout__sidebar-content">
              <ScrollArea>
                <slot name="sidebar" />
              </ScrollArea>
            </div>
            <div class="lesson-layout__sidebar-footer">
              <button
                id="lesson-sidebar-toggle"
                type="button"
                class="lesson-layout__sidebar-toggle"
                aria-label="Réduire le plan du cours"
                aria-expanded="true"
              >
                <span
                  class="lesson-layout__sidebar-icon lesson-layout__sidebar-icon--expand"
                  aria-hidden="true"
                >
                  <ArrowRightToLine size={18} />
                </span>
                <span
                  class="lesson-layout__sidebar-icon lesson-layout__sidebar-icon--collapse"
                  aria-hidden="true"
                >
                  <ArrowLeftToLine size={18} />
                </span>
              </button>
            </div>
          </aside>
        )
      }
      <div class="lesson-layout__body">
        <div class="lesson-layout__content">
          <div class="lesson-layout__content-body">
            <ScrollArea>
              <main class="lesson-layout__main">
                <slot />
              </main>
            </ScrollArea>
            <LessonClusterPanel />
          </div>
          <div
            class="lesson-layout__show-terminal"
            data-lesson-show-term
            aria-hidden="true"
          >
            <LessonContentBar
              labelVisualizer={labels.labelVisualizer}
              labelCourse={labels.labelCourse}
              labelShowTerminal={labels.labelShowTerminal}
              labelHideTerminal={labels.labelHideTerminal}
              labelContactSupport={labels.labelContactSupport}
              labelReloadTerminal={labels.labelReloadTerminal}
              terminalAction="show"
              showTerminalActions={showTerminalActions}
            />
          </div>
        </div>
        <div
          class="lesson-layout__resizer"
          data-lesson-resizer
          role="separator"
          aria-label="Redimensionner le contenu et le terminal"
          aria-orientation="vertical"
        >
        </div>
        <div class="lesson-layout__terminal-wrap" data-lesson-term-wrap>
          <div
            class:list={[
              'lesson-layout__terminal',
              !terminalInteractive && 'lesson-layout__terminal--locked'
            ]}
          >
            {
              terminalInteractive ? (
                <LessonTerminal seedName={seedName} lang={lang} />
              ) : (
                <div class="lesson-terminal-lock">
                  <div class="lesson-terminal-lock__blur" aria-hidden="true">
                    <div class="lesson-terminal-lock__fake-chrome" />
                    <div class="lesson-terminal-lock__fake-body">
                      <span class="lesson-terminal-lock__fake-line" />
                      <span class="lesson-terminal-lock__fake-line lesson-terminal-lock__fake-line--dim" />
                      <span class="lesson-terminal-lock__fake-line lesson-terminal-lock__fake-line--short" />
                    </div>
                  </div>
                  <div class="lesson-terminal-lock__card">
                    <h2 class="lesson-terminal-lock__title">
                      {terminalLockTitle}
                    </h2>
                    <p class="lesson-terminal-lock__body">{terminalLockBody}</p>
                    <div class="lesson-terminal-lock__ctas">
                      <Button
                        href={terminalLockTryFreeHref}
                        variant="solid"
                        color="cyan"
                        size="sm"
                      >
                        {terminalLockTryFreeLabel}
                      </Button>
                      <Button
                        href={terminalLockSecondaryHref}
                        variant="outline"
                        color="gray"
                        size="sm"
                      >
                        {terminalLockSecondaryLabel}
                      </Button>
                    </div>
                  </div>
                </div>
              )
            }
          </div>
          <LessonContentBar
            labelVisualizer={labels.labelVisualizer}
            labelCourse={labels.labelCourse}
            labelShowTerminal={labels.labelShowTerminal}
            labelHideTerminal={labels.labelHideTerminal}
            labelContactSupport={labels.labelContactSupport}
            labelReloadTerminal={labels.labelReloadTerminal}
            terminalAction="hide"
            showTerminalActions={showTerminalActions}
          />
        </div>
      </div>
    </div>
  </div>
  {
    supportContextId && (
      <ContactSupportModal
        title={t('lesson_contactSupport')}
        placeholder={t('courseLesson_suggestPlaceholder')}
        submitLabel={t('courseLesson_suggestSubmit')}
        cancelLabel={t('courseLesson_suggestCancel')}
        successToastTitle={t('toast_sendSuccess')}
        typeSupport={t('lesson_contactTypeSupport')}
        typeSuggestion={t('lesson_contactTypeSuggestion')}
        typeOther={t('lesson_contactTypeOther')}
        lessonId={supportContextId}
      />
    )
  }
</div>

<script>
  import {
    createEmulatedEnvironment,
    destroyEmulatedEnvironment
  } from '../../core/emulatedEnvironment/EmulatedEnvironmentManager'
  import { getSeed } from '../../courses/seeds/getSeed'
  import { createFilesystemFromConfig } from '../../core/filesystem/debianFileSystem'

  const STORAGE_KEY = 'lesson-sidebar-collapsed'
  const PANEL_RESIZE_STORAGE_KEY = 'lesson-terminal-width'
  const DESKTOP_BREAKPOINT = '(min-width: 1025px)'
  const MIN_TERMINAL_WIDTH = 320
  const MIN_CONTENT_WIDTH = 420
  let lessonEnv:
    | import('../../core/emulatedEnvironment/EmulatedEnvironment').EmulatedEnvironment
    | null = null

  function teardownGlobalLessonEnv() {
    const globalState = globalThis as {
      __lessonEnv?: import('../../core/emulatedEnvironment/EmulatedEnvironment').EmulatedEnvironment
      __lessonEnvSeed?: string
    }
    if (globalState.__lessonEnv) {
      destroyEmulatedEnvironment(globalState.__lessonEnv)
      delete globalState.__lessonEnv
      delete globalState.__lessonEnvSeed
    }
    lessonEnv = null
  }

  function isTerminalInteractiveFromDom(): boolean {
    const root = document.querySelector('.lesson-layout-root')
    if (!root) {
      return true
    }
    return root.getAttribute('data-terminal-interactive') !== 'false'
  }

  let panelResizeBound = false
  let panelResizeState: {
    body: HTMLElement
    content: HTMLElement
    terminalWrap: HTMLElement
    resizer: HTMLElement
  } | null = null

  function setupLessonEnv() {
    const root = document.querySelector('.lesson-layout-root')
    if (!root) {
      return
    }
    const seedName = root.getAttribute('data-seed-name') ?? 'minimal'
    const globalState = globalThis as {
      __lessonEnv?: import('../../core/emulatedEnvironment/EmulatedEnvironment').EmulatedEnvironment
      __lessonEnvSeed?: string
    }

    if (globalState.__lessonEnv && globalState.__lessonEnvSeed === seedName) {
      lessonEnv = globalState.__lessonEnv
    } else {
      if (globalState.__lessonEnv) {
        destroyEmulatedEnvironment(globalState.__lessonEnv)
      }
      const seed = getSeed(seedName)
      lessonEnv = createEmulatedEnvironment({
        filesystemState: createFilesystemFromConfig(seed.fsConfig ?? {})
      })
      globalState.__lessonEnv = lessonEnv
      globalState.__lessonEnvSeed = seedName
    }

    if (!lessonEnv) {
      return
    }

    document.dispatchEvent(
      new CustomEvent('cluster-env-ready', {
        detail: { env: lessonEnv }
      })
    )
    document.dispatchEvent(
      new CustomEvent('lesson-env-ready', {
        detail: { env: lessonEnv }
      })
    )
  }

  function cleanupLessonEnv() {
    teardownGlobalLessonEnv()
  }

  function setupSidebarToggle() {
    const sidebar = document.getElementById('lesson-sidebar')
    const toggle = document.getElementById('lesson-sidebar-toggle')
    if (!sidebar || !toggle) {
      return
    }

    const updateUi = () => {
      const collapsed = sidebar.classList.contains(
        'lesson-layout__sidebar--collapsed'
      )
      toggle.setAttribute(
        'aria-label',
        collapsed ? 'Afficher le plan du cours' : 'Réduire le plan du cours'
      )
      toggle.setAttribute('aria-expanded', String(!collapsed))
    }

    const init = () => {
      const collapsed = localStorage.getItem(STORAGE_KEY) === 'true'
      sidebar.classList.toggle('lesson-layout__sidebar--collapsed', collapsed)
      updateUi()
    }

    init()
    toggle.onclick = () => {
      const collapsed = !sidebar.classList.contains(
        'lesson-layout__sidebar--collapsed'
      )
      sidebar.classList.toggle('lesson-layout__sidebar--collapsed', collapsed)
      localStorage.setItem(STORAGE_KEY, String(collapsed))
      updateUi()
    }
  }

  let terminalToggleBound = false
  let mermaidZoomBound = false
  let mermaidObserver: MutationObserver | null = null

  function ensureMermaidZoomModal() {
    const existing = document.querySelector(
      '.mermaid-zoom-modal'
    ) as HTMLElement | null
    if (existing) {
      return existing
    }

    const modal = document.createElement('div')
    modal.className = 'mermaid-zoom-modal'
    modal.setAttribute('aria-hidden', 'true')
    modal.innerHTML = `
      <div class="mermaid-zoom-modal__backdrop" data-mermaid-zoom-close></div>
      <div class="mermaid-zoom-modal__panel" role="dialog" aria-modal="true" aria-label="Diagram zoom">
        <button
          type="button"
          class="mermaid-zoom-modal__close"
          aria-label="Close zoom"
          data-mermaid-zoom-close
        >
          ×
        </button>
        <div class="mermaid-zoom-modal__content"></div>
      </div>
    `
    document.body.appendChild(modal)
    return modal
  }

  function closeMermaidZoomModal() {
    const modal = document.querySelector(
      '.mermaid-zoom-modal'
    ) as HTMLElement | null
    if (!modal) {
      return
    }

    modal.classList.remove('mermaid-zoom-modal--open')
    modal.setAttribute('aria-hidden', 'true')
    const content = modal.querySelector(
      '.mermaid-zoom-modal__content'
    ) as HTMLElement | null
    if (content) {
      content.innerHTML = ''
    }
    document.body.classList.remove('mermaid-zoom-open')
  }

  function openMermaidZoomModal(sourceContainer: Element) {
    const sourceSvg = sourceContainer.querySelector('svg')
    if (!(sourceSvg instanceof SVGElement)) {
      return
    }

    const modal = ensureMermaidZoomModal()
    const content = modal.querySelector(
      '.mermaid-zoom-modal__content'
    ) as HTMLElement | null
    if (!content) {
      return
    }

    const clonedSvg = sourceSvg.cloneNode(true)
    if (!(clonedSvg instanceof SVGElement)) {
      return
    }

    const sourceWidth = Math.round(sourceSvg.getBoundingClientRect().width)
    const viewportWidth = Math.max(window.innerWidth, 1024)
    const targetWidth = Math.max(
      sourceWidth * 2.4,
      Math.floor(viewportWidth * 0.97)
    )
    clonedSvg.style.maxWidth = 'none'
    clonedSvg.style.width = `${targetWidth}px`
    clonedSvg.style.height = 'auto'

    content.innerHTML = ''
    content.appendChild(clonedSvg)

    modal.classList.add('mermaid-zoom-modal--open')
    modal.setAttribute('aria-hidden', 'false')
    document.body.classList.add('mermaid-zoom-open')
  }

  function enhanceMermaidBlocks() {
    const blocks = document.querySelectorAll('.lesson-content pre.mermaid')
    blocks.forEach((block) => {
      if (!(block instanceof HTMLElement)) {
        return
      }
      const existingButton = block.querySelector(
        '[data-mermaid-zoom-btn]'
      ) as HTMLElement | null
      if (existingButton) {
        return
      }

      const button = document.createElement('button')
      button.type = 'button'
      button.className = 'mermaid-zoom-btn'
      button.setAttribute('aria-label', 'Zoom diagram')
      button.setAttribute('data-mermaid-zoom-btn', 'true')
      const icon = document.createElementNS('http://www.w3.org/2000/svg', 'svg')
      icon.setAttribute('viewBox', '0 0 24 24')
      icon.setAttribute('aria-hidden', 'true')
      const iconPath = document.createElementNS(
        'http://www.w3.org/2000/svg',
        'path'
      )
      iconPath.setAttribute(
        'd',
        'M10 4a6 6 0 1 0 3.87 10.59l4.77 4.77 1.41-1.41-4.77-4.77A6 6 0 0 0 10 4Zm0 2a4 4 0 1 1 0 8 4 4 0 0 1 0-8Zm-1 1v2H7v2h2v2h2v-2h2V9h-2V7H9Z'
      )
      icon.appendChild(iconPath)
      button.appendChild(icon)
      block.appendChild(button)
    })
  }

  function setupMermaidZoom() {
    enhanceMermaidBlocks()

    if (!mermaidObserver) {
      const observeTarget = document.body
      if (!observeTarget) {
        return
      }
      mermaidObserver = new MutationObserver(() => {
        enhanceMermaidBlocks()
      })
      mermaidObserver.observe(observeTarget, {
        childList: true,
        subtree: true
      })
    }

    if (mermaidZoomBound) {
      return
    }
    mermaidZoomBound = true

    document.addEventListener('click', (event) => {
      if (!(event.target instanceof Element)) {
        return
      }

      const closeTrigger = event.target.closest('[data-mermaid-zoom-close]')
      if (closeTrigger) {
        closeMermaidZoomModal()
        return
      }

      const zoomButton = event.target.closest('[data-mermaid-zoom-btn]')
      if (!zoomButton) {
        return
      }

      const sourceContainer = zoomButton.closest('.lesson-content pre.mermaid')
      if (!sourceContainer) {
        return
      }
      openMermaidZoomModal(sourceContainer)
    })

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeMermaidZoomModal()
      }
    })
  }

  function initTerminalStateForMobile() {
    const root = document.querySelector('.lesson-layout-root')
    const termWrap = document.querySelector('[data-lesson-term-wrap]')
    const showTerm = document.querySelector('[data-lesson-show-term]')
    if (!root || !termWrap || !showTerm) {
      return
    }
    if (!window.matchMedia('(max-width: 768px)').matches) {
      return
    }
    root.setAttribute('data-terminal-open', 'false')
    termWrap.classList.add('lesson-layout__terminal-wrap--hidden')
    showTerm.setAttribute('aria-hidden', 'false')
  }

  function setupTerminalToggle() {
    initTerminalStateForMobile()
    if (terminalToggleBound) {
      return
    }
    terminalToggleBound = true

    document.addEventListener('lesson-terminal-toggle', () => {
      const root = document.querySelector('.lesson-layout-root')
      const termWrap = document.querySelector('[data-lesson-term-wrap]')
      const showTerm = document.querySelector('[data-lesson-show-term]')
      if (!root || !termWrap || !showTerm) {
        return
      }
      const open = root.getAttribute('data-terminal-open') !== 'false'
      root.setAttribute('data-terminal-open', !open ? 'true' : 'false')
      termWrap.classList.toggle('lesson-layout__terminal-wrap--hidden', open)
      showTerm.setAttribute('aria-hidden', !open ? 'true' : 'false')
    })

    document.addEventListener('lesson-terminal-reload', () => {
      if (!isTerminalInteractiveFromDom()) {
        return
      }
      cleanupLessonEnv()
      setupLessonEnv()
    })

    document.addEventListener('click', (e) => {
      if (!(e.target as Element).closest('[data-lesson-show-term-btn]')) {
        return
      }
      const root = document.querySelector('.lesson-layout-root')
      const termWrap = document.querySelector('[data-lesson-term-wrap]')
      const showTerm = document.querySelector('[data-lesson-show-term]')
      if (!root || !termWrap || !showTerm) {
        return
      }
      root.setAttribute('data-terminal-open', 'true')
      termWrap.classList.remove('lesson-layout__terminal-wrap--hidden')
      showTerm.setAttribute('aria-hidden', 'true')
    })
  }

  function getPanelElements() {
    const body = document.querySelector('.lesson-layout__body')
    const content = document.querySelector('.lesson-layout__content')
    const terminalWrap = document.querySelector(
      '[data-lesson-term-wrap]'
    ) as HTMLElement | null
    const resizer = document.querySelector(
      '[data-lesson-resizer]'
    ) as HTMLElement | null

    if (
      !(body instanceof HTMLElement) ||
      !(content instanceof HTMLElement) ||
      !(terminalWrap instanceof HTMLElement) ||
      !(resizer instanceof HTMLElement)
    ) {
      return null
    }

    return {
      body,
      content,
      terminalWrap,
      resizer
    }
  }

  function clampTerminalWidth(layoutWidth: number, desiredWidth: number) {
    const maxTerminalWidth = Math.max(
      MIN_TERMINAL_WIDTH,
      layoutWidth - MIN_CONTENT_WIDTH
    )
    return Math.min(
      Math.max(desiredWidth, MIN_TERMINAL_WIDTH),
      maxTerminalWidth
    )
  }

  function applyTerminalWidth(desiredWidth: number) {
    const desktopQuery = window.matchMedia(DESKTOP_BREAKPOINT)
    const panelElements = getPanelElements()
    if (!panelElements) {
      return
    }

    const { body, content, terminalWrap } = panelElements

    if (!desktopQuery.matches) {
      terminalWrap.style.removeProperty('flex')
      content.style.removeProperty('flex')
      return
    }

    const clampedWidth = clampTerminalWidth(body.clientWidth, desiredWidth)
    terminalWrap.style.flex = `0 0 ${clampedWidth}px`
    content.style.flex = '1 1 auto'
  }

  function setupPanelResize() {
    const desktopQuery = window.matchMedia(DESKTOP_BREAKPOINT)
    const panelElements = getPanelElements()
    if (!panelElements) {
      return
    }

    const { body } = panelElements

    const storedWidth = Number(localStorage.getItem(PANEL_RESIZE_STORAGE_KEY))
    if (Number.isFinite(storedWidth) && storedWidth > 0) {
      applyTerminalWidth(storedWidth)
    } else {
      applyTerminalWidth(Math.round(body.clientWidth * 0.5))
    }

    if (panelResizeBound) {
      return
    }
    panelResizeBound = true

    const stopResize = () => {
      if (!panelResizeState) {
        return
      }
      panelResizeState.resizer.classList.remove(
        'lesson-layout__resizer--dragging'
      )
      document.body.classList.remove('lesson-layout--resizing')
      panelResizeState = null
    }

    document.addEventListener('pointerdown', (event) => {
      if (!(event.target instanceof Element)) {
        return
      }
      const resizer = event.target.closest('[data-lesson-resizer]')
      if (!(resizer instanceof HTMLElement)) {
        return
      }
      if (!desktopQuery.matches) {
        return
      }

      const currentPanelElements = getPanelElements()
      if (!currentPanelElements) {
        return
      }

      event.preventDefault()
      panelResizeState = {
        body: currentPanelElements.body,
        content: currentPanelElements.content,
        terminalWrap: currentPanelElements.terminalWrap,
        resizer
      }
      panelResizeState.resizer.classList.add('lesson-layout__resizer--dragging')
      document.body.classList.add('lesson-layout--resizing')
    })

    document.addEventListener('pointermove', (event) => {
      if (!panelResizeState) {
        return
      }

      const { body, terminalWrap, content } = panelResizeState
      const bodyRect = body.getBoundingClientRect()
      const rawTerminalWidth = bodyRect.right - event.clientX
      const nextTerminalWidth = clampTerminalWidth(
        bodyRect.width,
        rawTerminalWidth
      )

      terminalWrap.style.flex = `0 0 ${nextTerminalWidth}px`
      content.style.flex = '1 1 auto'
      localStorage.setItem(
        PANEL_RESIZE_STORAGE_KEY,
        String(Math.round(nextTerminalWidth))
      )
    })

    document.addEventListener('pointerup', () => {
      stopResize()
    })

    document.addEventListener('pointercancel', () => {
      stopResize()
    })

    window.addEventListener('resize', () => {
      const currentPanelElements = getPanelElements()
      if (!currentPanelElements) {
        return
      }
      const currentWidth = Number.parseFloat(
        currentPanelElements.terminalWrap.style.flexBasis
      )
      if (Number.isFinite(currentWidth) && currentWidth > 0) {
        applyTerminalWidth(currentWidth)
      }
    })
  }

  function initLessonEmulation() {
    if (!isTerminalInteractiveFromDom()) {
      teardownGlobalLessonEnv()
      return
    }
    setupLessonEnv()
  }

  setupSidebarToggle()
  setupTerminalToggle()
  setupPanelResize()
  setupMermaidZoom()
  requestAnimationFrame(initLessonEmulation)
  document.addEventListener('astro:page-load', () => {
    setupSidebarToggle()
    setupTerminalToggle()
    setupPanelResize()
    setupMermaidZoom()
    requestAnimationFrame(initLessonEmulation)
  })
  // Keep shared env alive across page transitions for persistent lesson terminal.
  window.addEventListener('beforeunload', () => {
    cleanupLessonEnv()
  })
</script>

<style>
  .lesson-layout-page {
    height: 100%;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  .lesson-layout-root {
    flex: 1;
    min-height: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .lesson-layout {
    background-color: var(--color-gray-1);
    flex: 1;
    min-height: 0;
    display: flex;
    overflow: hidden;
  }

  .lesson-layout__sidebar {
    flex-shrink: 0;
    border-right: 1px solid var(--color-gray-6);
    background-color: var(--color-gray-1);
    overflow: hidden;
    transition: width var(--duration-normal) ease-out;
    display: flex;
    flex-direction: column;
  }

  .lesson-layout__sidebar--collapsed {
    width: 41px;
  }

  .lesson-layout__sidebar-icon {
    display: none;
  }

  .lesson-layout__sidebar:not(.lesson-layout__sidebar--collapsed)
    .lesson-layout__sidebar-icon--collapse {
    display: inline-flex;
  }

  .lesson-layout__sidebar--collapsed .lesson-layout__sidebar-icon--expand {
    display: inline-flex;
  }

  .lesson-layout__sidebar-content {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
    overflow: hidden;
    width: 250px;
    min-width: 250px;
    opacity: 1;
    transition: opacity var(--duration-normal) ease-out;
  }

  .lesson-layout__sidebar--collapsed .lesson-layout__sidebar-content {
    opacity: 0;
    pointer-events: none;
  }

  .lesson-layout__sidebar-footer {
    margin-top: auto;
    padding: var(--spacing-2) 0;
    border-top: 1px solid var(--color-gray-6);
    display: flex;
    flex-shrink: 0;
  }

  .lesson-layout__sidebar-toggle {
    height: var(--spacing-9);
    min-width: var(--spacing-9);
    padding-inline: var(--spacing-2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-palette-gray-plain-fg);
    background: transparent;
    border: none;
    border-radius: var(--radius-l2);
    cursor: pointer;
    transition:
      background-color 0.2s,
      color 0.2s;
  }

  .lesson-layout__sidebar-toggle:hover {
    background: var(--color-palette-gray-plain-bg-hover);
  }

  .lesson-layout__sidebar-toggle:active {
    background: var(--color-palette-gray-plain-bg-active);
