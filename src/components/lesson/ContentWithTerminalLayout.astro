---
import LessonTerminal from '../LessonTerminal.astro'
import LessonContentBar from './LessonContentBar.astro'
import LessonClusterPanel from './LessonClusterPanel.astro'
import ContactSupportModal from './ContactSupportModal.astro'
import ScrollArea from '../ui/ScrollArea.astro'
import Button from '../ui/Button.astro'
import { useTranslations } from '../../i18n/utils'
import { ArrowLeftToLine, ArrowRightToLine, Terminal } from '@lucide/astro'
import { Kubernetes } from 'simple-icons-astro'

interface Props {
  seedName: string
  drillId?: string
  drillHasFsModule?: boolean
  drillHasClusterYaml?: boolean
  lang: 'en' | 'fr'
  showSidebar?: boolean
  supportContextId?: string
  /** When false, terminal is a locked placeholder (no cluster simulation). */
  terminalInteractive?: boolean
  terminalLockPrimaryHref?: string
  terminalLockPrimaryLabel?: string
  terminalLockSecondaryHref?: string
  terminalLockTitle?: string
  terminalLockBody?: string
  terminalDocsHref?: string
  terminalDocsTabLabel?: string
  terminalShellTabLabel?: string
}

const {
  seedName,
  drillId,
  drillHasFsModule = false,
  drillHasClusterYaml = false,
  lang,
  showSidebar = false,
  supportContextId,
  terminalInteractive = true,
  terminalLockPrimaryHref = '',
  terminalLockPrimaryLabel,
  terminalLockSecondaryHref = '',
  terminalLockTitle,
  terminalLockBody,
  terminalDocsHref = '',
  terminalDocsTabLabel = 'Docs',
  terminalShellTabLabel = 'Terminal'
} = Astro.props

const t = useTranslations(lang)

const hasTerminalDocsTab = terminalDocsHref.trim().length > 0

const KUBERNETES_DOCS_IFRAME_SANDBOX =
  'allow-scripts allow-same-origin allow-forms allow-popups allow-popups-to-escape-sandbox allow-downloads allow-modals'
---

<div class="lesson-layout-page">
  <div
    class="lesson-layout-root"
    data-seed-name={seedName}
    data-drill-id={drillId ?? undefined}
    data-drill-has-fs-module={drillHasFsModule ? 'true' : 'false'}
    data-drill-has-cluster-yaml={drillHasClusterYaml ? 'true' : 'false'}
    data-lang={lang}
    data-terminal-open="false"
    data-outline-open="false"
    data-terminal-interactive={terminalInteractive ? 'true' : 'false'}
    data-lesson-tour="layout-root"
  >
    <div class="lesson-layout">
      {
        showSidebar && (
          <aside
            id="lesson-sidebar"
            class="lesson-layout__sidebar"
            aria-label="Plan du cours"
            data-lesson-sidebar="true"
            data-lesson-tour="sidebar"
          >
            <div class="lesson-layout__sidebar-content">
              <ScrollArea>
                <slot name="sidebar" />
              </ScrollArea>
            </div>
            <div class="lesson-layout__sidebar-footer">
              <button
                id="lesson-sidebar-toggle"
                type="button"
                class="lesson-layout__sidebar-toggle"
                aria-label="Réduire le plan du cours"
                aria-expanded="true"
                data-lesson-tour="sidebar-toggle"
              >
                <span
                  class="lesson-layout__sidebar-icon lesson-layout__sidebar-icon--expand"
                  aria-hidden="true"
                >
                  <ArrowRightToLine size={18} />
                </span>
                <span
                  class="lesson-layout__sidebar-icon lesson-layout__sidebar-icon--collapse"
                  aria-hidden="true"
                >
                  <ArrowLeftToLine size={18} />
                </span>
              </button>
            </div>
          </aside>
        )
      }
      <div class="lesson-layout__body">
        <div class="lesson-layout__content">
          <div class="lesson-layout__content-body">
            <ScrollArea>
              <main class="lesson-layout__main">
                <slot />
              </main>
            </ScrollArea>
          </div>
        </div>
        <div
          class="lesson-layout__resizer"
          data-lesson-resizer
          data-lesson-tour="resizer"
          role="separator"
          aria-label="Redimensionner le contenu et le terminal"
          aria-orientation="vertical"
        >
        </div>
        <div
          class="lesson-layout__terminal-wrap"
          data-lesson-term-wrap
          data-lesson-tour="terminal"
        >
          <div class="lesson-layout__terminal-area">
            {
              hasTerminalDocsTab && (
                <div
                  class="lesson-layout__terminal-tabs"
                  role="tablist"
                  aria-label="Terminal tabs"
                >
                  <button
                    type="button"
                    class="lesson-layout__terminal-tab lesson-layout__terminal-tab--active"
                    role="tab"
                    id="lesson-terminal-tab-shell"
                    aria-controls="lesson-terminal-panel-shell"
                    aria-selected="true"
                    data-terminal-tab-trigger="shell"
                  >
                    <span class="lesson-layout__terminal-tab-icon" aria-hidden="true">
                      <Terminal size={14} />
                    </span>
                    {terminalShellTabLabel}
                  </button>
                  <button
                    type="button"
                    class="lesson-layout__terminal-tab"
                    role="tab"
                    id="lesson-terminal-tab-docs"
                    aria-controls="lesson-terminal-panel-docs"
                    aria-selected="false"
                    data-terminal-tab-trigger="docs"
                  >
                    <span class="lesson-layout__terminal-tab-icon" aria-hidden="true">
                      <Kubernetes size={14} />
                    </span>
                    {terminalDocsTabLabel}
                  </button>
                </div>
              )
            }
            <section
              class="lesson-layout__terminal-panel"
              id="lesson-terminal-panel-shell"
              role="tabpanel"
              aria-labelledby="lesson-terminal-tab-shell"
              data-terminal-tab-panel="shell"
            >
              <div
                class:list={[
                  'lesson-layout__terminal',
                  !terminalInteractive && 'lesson-layout__terminal--locked'
                ]}
              >
                {
                  terminalInteractive ? (
                    <LessonTerminal seedName={seedName} lang={lang} />
                  ) : (
                    <div class="lesson-terminal-lock">
                      <div class="lesson-terminal-lock__preview" aria-hidden="true">
                        <div class="lesson-terminal-lock__fake-session">
                          <div class="lesson-terminal-lock__session-line">~>kubectl apply -f deployment.yaml</div>
                          <div class="lesson-terminal-lock__session-line">
                            deployment.apps/nginx&nbsp;&nbsp;&nbsp;created
                          </div>
                          <div class="lesson-terminal-lock__session-line">~>kubectl get pods</div>
                          <div class="lesson-terminal-lock__session-line">
                            NAME&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;READY&nbsp;&nbsp;&nbsp;STATUS&nbsp;&nbsp;&nbsp;&nbsp;RESTARTS&nbsp;&nbsp;&nbsp;AGE
                          </div>
                          <div class="lesson-terminal-lock__session-line">
                            nginx-7b4c9d8f5-xk2j&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;1/1&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Running&nbsp;&nbsp;&nbsp;&nbsp;0&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;12s
                          </div>
                          <div class="lesson-terminal-lock__session-line">
                            nginx-7b4c9d8f5-hn4vw&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;1/1&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Running&nbsp;&nbsp;&nbsp;&nbsp;0&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;11s
                          </div>
                          <div class="lesson-terminal-lock__session-line">
                            nginx-7b4c9d8f5-qp9rm&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;1/1&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Running&nbsp;&nbsp;&nbsp;&nbsp;0&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;10s
                          </div>
                          <div class="lesson-terminal-lock__session-line">
                            <span>~></span><span class="lesson-terminal-lock__cursor">█</span>
                          </div>
                        </div>
                      </div>
                      <div class="lesson-terminal-lock__card">
                        <h2 class="lesson-terminal-lock__title">
                          {terminalLockTitle ?? t('lesson_terminalLock_title')}
                        </h2>
                        <p class="lesson-terminal-lock__body">
                          {terminalLockBody ?? t('lesson_terminalLock_body')}
                        </p>
                        <div class="lesson-terminal-lock__ctas">
                          <Button
                            href={terminalLockPrimaryHref}
                            variant="solid"
                            color="cyan"
                            size="sm"
                          >
                            {terminalLockPrimaryLabel ?? t('lesson_terminalLock_ctaUpgrade')}
                          </Button>
                          {terminalLockSecondaryHref && (
                            <Button
                              href={terminalLockSecondaryHref}
                              variant="outline"
                              color="gray"
                              size="sm"
                            >
                              {t('lesson_terminalLock_tryFreeCrashCourse')}
                            </Button>
                          )}
                        </div>
                      </div>
                    </div>
                  )
                }
              </div>
            </section>
            {
              hasTerminalDocsTab && (
                <section
                  class="lesson-layout__terminal-panel"
                  id="lesson-terminal-panel-docs"
                  role="tabpanel"
                  aria-labelledby="lesson-terminal-tab-docs"
                  data-terminal-tab-panel="docs"
                  hidden
                >
                  <iframe
                    class="lesson-layout__terminal-docs-frame"
                    src={terminalDocsHref}
                    title="Kubernetes documentation"
                    loading="lazy"
                    referrerpolicy="no-referrer"
                    sandbox={KUBERNETES_DOCS_IFRAME_SANDBOX}
                  />
                </section>
              )
            }
          </div>
          <LessonClusterPanel />
          <LessonContentBar
            lang={lang}
            showTerminalActions={terminalInteractive}
            showOutlineAction={showSidebar}
          />
        </div>
      </div>
    </div>
    {
      showSidebar && (
        <div
          class="lesson-layout__mobile-overlay"
          data-lesson-outline-backdrop
          aria-hidden="true"
        />
      )
    }
  </div>
  {
    supportContextId && (
      <ContactSupportModal
        title={t('lesson_contactSupport')}
        placeholder={t('courseLesson_suggestPlaceholder')}
        submitLabel={t('courseLesson_suggestSubmit')}
        cancelLabel={t('courseLesson_suggestCancel')}
        successToastTitle={t('toast_sendSuccess')}
        typeSupport={t('lesson_contactTypeSupport')}
        typeSuggestion={t('lesson_contactTypeSuggestion')}
        typeOther={t('lesson_contactTypeOther')}
        lessonId={supportContextId}
      />
    )
  }
</div>

<script>
  import { initializeContentWithTerminalLayout } from '../../lib/lesson/lessonContentWithTerminalLayout'

  initializeContentWithTerminalLayout()
</script>

<style>
  .lesson-layout-page {
    height: 100%;
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  .lesson-layout-root {
    flex: 1;
    min-height: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .lesson-layout {
    background-color: var(--color-gray-1);
    flex: 1;
    min-height: 0;
    display: flex;
    overflow: hidden;
  }

  .lesson-layout__sidebar {
    flex-shrink: 0;
    border-right: 1px solid var(--color-gray-6);
    background-color: var(--color-gray-1);
    overflow: hidden;
    transition: width var(--duration-normal) ease-out;
    display: flex;
    flex-direction: column;
  }

  .lesson-layout__sidebar--collapsed {
    width: 52px;
  }

  .lesson-layout__sidebar-icon {
    display: none;
  }

  .lesson-layout__sidebar:not(.lesson-layout__sidebar--collapsed)
    .lesson-layout__sidebar-icon--collapse {
    display: inline-flex;
  }

  .lesson-layout__sidebar--collapsed .lesson-layout__sidebar-icon--expand {
    display: inline-flex;
  }

  .lesson-layout__sidebar-content {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
    overflow: hidden;
    width: 250px;
    min-width: 250px;
    opacity: 1;
    transition: opacity var(--duration-normal) ease-out;
  }

  .lesson-layout__sidebar--collapsed .lesson-layout__sidebar-content {
    opacity: 0;
    pointer-events: none;
  }

  .lesson-layout__sidebar-footer {
    margin-top: auto;
    padding: var(--spacing-2);
    border-top: 1px solid var(--color-gray-6);
    display: flex;
    flex-shrink: 0;
  }

  .lesson-layout__sidebar-toggle {
    height: var(--spacing-9);
    min-width: var(--spacing-9);
    padding-inline: var(--spacing-2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-palette-gray-plain-fg);
    background: transparent;
    border: none;
    border-radius: var(--radius-l2);
    cursor: pointer;
    transition:
      background-color 0.2s,
      color 0.2s;
  }

  .lesson-layout__sidebar-toggle:hover {
    background: var(--color-palette-gray-plain-bg-hover);
  }

  .lesson-layout__sidebar-toggle:active {
    background: var(--color-palette-gray-plain-bg-active);
  }

  .lesson-layout__sidebar-toggle:focus-visible {
    outline: 2px solid var(--color-palette-cyan-solid-bg);
    outline-offset: 2px;
  }

  .lesson-layout__body {
    display: flex;
    flex-direction: row;
    flex: 1;
    min-height: 0;
    min-width: 0;
    background-color: var(--color-gray-1);
  }

  .lesson-layout__content {
    flex: 0.8;
    min-width: 0;
    min-height: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .lesson-layout__content-body {
    flex: 1;
    min-height: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .lesson-layout__terminal-wrap {
    flex: 1;
    min-width: 320px;
    min-height: 0;
    position: relative;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .lesson-layout__terminal-area {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .lesson-layout__terminal-tabs {
    flex-shrink: 0;
    display: flex;
    align-items: stretch;
    gap: var(--spacing-4);
    border-bottom: 1px solid var(--color-gray-6);
    padding: 0 var(--spacing-3);
    background: var(--color-gray-1);
  }

  .lesson-layout__terminal-tab {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border: 0;
    border-bottom: 2px solid transparent;
    border-radius: 0;
    background: transparent;
    color: var(--color-gray-11);
    padding: 0.72rem 0;
    margin-bottom: -1px;
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    cursor: pointer;
    transition:
      color 0.15s ease,
      border-color 0.15s ease;
  }

  .lesson-layout__terminal-tab:hover {
    color: var(--color-gray-12);
  }

  .lesson-layout__terminal-tab--active {
    border-bottom-color: var(--color-cyan-8);
    color: var(--color-gray-12);
  }

  .lesson-layout__terminal-tab-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    opacity: 0.9;
  }

  .lesson-layout__terminal-tab-icon :global(svg) {
    width: 14px;
    height: 14px;
    display: block;
  }

  .lesson-layout__terminal-tab:focus-visible {
    outline: 2px solid var(--color-palette-cyan-solid-bg);
    outline-offset: -2px;
  }

  .lesson-layout__terminal-panel {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .lesson-layout__terminal-panel[hidden] {
    display: none;
  }

  .lesson-layout__terminal-docs-frame {
    width: 100%;
    height: 100%;
    border: 0;
    margin: 0;
    padding: 0;
    display: block;
    background: var(--color-gray-1);
  }

  .lesson-layout__terminal {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .lesson-layout__terminal--locked {
    position: relative;
    min-height: 200px;
    /* Match TerminalWindow `.t-box` so locked state resembles the live lesson terminal */
    background: var(--color-gray-1);
  }

  .lesson-terminal-lock {
    position: relative;
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .lesson-terminal-lock__preview {
    position: relative;
    flex: 1;
    min-height: 0;
    filter: blur(1.25px);
    opacity: 0.92;
    pointer-events: none;
    user-select: none;
    display: flex;
    flex-direction: column;
    /* Same outer padding as TerminalWindow `.t-win` around `.t-box` */
    padding: var(--spacing-4);
    overflow: hidden;
  }

  .lesson-terminal-lock__fake-session {
    position: relative;
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    font-family: var(--font-mono, monospace);
    font-size: var(--text-sm);
    line-height: 1.45;
    color: var(--color-gray-12);
    text-align: left;
    overflow: hidden;
  }

  .lesson-terminal-lock__session-line {
    margin: 0;
  }

  .lesson-terminal-lock__cursor {
    display: inline-block;
    margin-left: 1px;
    color: var(--color-gray-12);
    animation: lesson-terminal-lock-cursor 1.1s step-end infinite;
  }

  @keyframes lesson-terminal-lock-cursor {
    0%,
    100% {
      opacity: 1;
    }

    50% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lesson-terminal-lock__cursor {
      animation: none;
    }
  }

  .lesson-terminal-lock__card {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    box-sizing: border-box;
    width: min(23rem, calc(100% - var(--spacing-8)));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-6);
    background: color-mix(in srgb, var(--color-gray-1) 88%, transparent);
    border: 1px solid var(--color-gray-6);
    border-radius: var(--radius-l2);
    z-index: 3;
    text-align: center;
    pointer-events: auto;
  }

  .lesson-terminal-lock__title {
    margin: 0 0 var(--spacing-2);
    font-size: var(--text-lg);
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-12);
    max-width: 100%;
  }

  .lesson-terminal-lock__body {
    margin: 0 0 var(--spacing-4);
    font-size: var(--text-sm);
    color: var(--color-gray-11);
    line-height: 1.45;
    max-width: 100%;
  }

  .lesson-terminal-lock__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-2);
    justify-content: center;
  }

  .lesson-layout__resizer {
    position: relative;
    flex: 0 0 10px;
    width: 10px;
    cursor: col-resize;
    touch-action: none;
    user-select: none;
  }

  .lesson-layout__resizer::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    background-color: var(--color-gray-6);
    transition: background-color var(--duration-normal);
  }

  .lesson-layout__resizer::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 4px;
    height: 44px;
    border-radius: 9999px;
    background-color: var(--color-gray-a7);
    opacity: 0;
    transition:
      opacity var(--duration-normal),
      background-color var(--duration-normal);
  }

  .lesson-layout__resizer:hover::before,
  .lesson-layout__resizer--dragging::before {
    background-color: var(--color-gray-8);
  }

  .lesson-layout__resizer:hover::after,
  .lesson-layout__resizer--dragging::after {
    opacity: 1;
  }

  :global(body.lesson-layout--resizing) {
    cursor: col-resize;
    user-select: none;
  }

  .lesson-layout__main {
    max-width: min(80ch, 100%);
    margin: 0 auto;
  }

  /* :global needed: slot content is rendered by parent, so it has parent's scope */
  :global(.lesson-layout__drill-complete),
  :global(.lp__drill-complete) {
    margin-top: 1.5rem;
    margin-bottom: 2rem;
    padding-bottom: 4rem;
    width: 100%;
    box-sizing: border-box;
    display: flex;
    justify-content: flex-end;
  }

  .lesson-layout__mobile-overlay {
    display: none;
  }

  /*
    Desktop: match the default post-JS split (~50% terminal, rest content + 10px resizer)
    without nested min/max in flex-basis (avoids first-paint sizing bugs). Hydration only
    nudges width when clamping or localStorage differs.
  */
  @media (min-width: 1025px) {
    .lesson-layout__content {
      flex: 1 1 auto;
    }

    .lesson-layout__terminal-wrap {
      flex: 0 0 50%;
    }
    .lesson-layout__terminal-tabs {
      gap: var(--spacing-3);
      padding: 0 var(--spacing-2);
    }
  }

  @media (max-width: 640px) {
    .lesson-layout__main {
      padding: var(--spacing-2);
    }
  }

  @media (max-width: 1024px) {
    .lesson-layout-root {
      --mobile-terminal-bar-height: 53px;
      --mobile-terminal-height: clamp(150px, 26dvh, 220px);
    }
    .lesson-layout__sidebar {
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      width: min(86vw, 22rem);
      background-color: var(--color-gray-1);
      z-index: 120;
      transform: translateX(-105%);
      transition: transform var(--duration-normal) ease-out;
      box-shadow: 0 12px 32px rgb(0 0 0 / 0.38);
      border-right: 1px solid var(--color-gray-6);
    }
    .lesson-layout__sidebar-content {
      width: auto;
      min-width: 0;
    }
    .lesson-layout__sidebar--collapsed {
      width: min(86vw, 22rem);
    }
    .lesson-layout__sidebar-footer {
      display: none;
    }
    .lesson-layout-root[data-outline-open='true'] .lesson-layout__sidebar {
      transform: translateX(0);
    }
    .lesson-layout__body {
      flex-direction: column;
    }
    .lesson-layout__content {
      flex: 1 1 auto;
    }
    .lesson-layout__terminal-wrap {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 100;
      min-width: unset;
      border-left: none;
      border-top: none;
      background-color: var(--color-gray-1);
      overflow: hidden;
    }
    .lesson-layout__resizer {
      display: none;
    }
    .lesson-layout__terminal {
      display: none;
      border-top: 1px solid var(--color-gray-6);
      flex: 0 0 auto;
    }
    .lesson-layout-root[data-terminal-open='true'] .lesson-layout__terminal {
      display: flex;
      height: min(
        var(--mobile-terminal-height),
        calc(
          100dvh - var(--mobile-terminal-bar-height) - env(safe-area-inset-bottom)
        )
      );
    }
    .lesson-layout__mobile-overlay {
      display: block;
      position: fixed;
      inset: 0;
      background: rgb(0 0 0 / 0.45);
      opacity: 0;
      pointer-events: none;
      transition: opacity var(--duration-normal) ease-out;
      z-index: 110;
    }
    .lesson-layout-root[data-outline-open='true'] .lesson-layout__mobile-overlay {
      opacity: 1;
      pointer-events: auto;
    }
    .lesson-layout__content-body :global(.scroll-area__viewport) {
