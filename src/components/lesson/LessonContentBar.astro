---
import Button from '../ui/Button.astro'
import { ListTree, MessageCircle, RefreshCw, Telescope, Terminal } from '@lucide/astro'

interface Props {
  labelVisualizer: string
  labelCourse: string
  labelShowTerminal: string
  labelHideTerminal: string
  labelContactSupport: string
  labelReloadTerminal: string
  /** When false, hide cluster and reload (no emulated environment). */
  showTerminalActions?: boolean
  /** Show course outline action (mobile drawer trigger). */
  showOutlineAction?: boolean
}
const {
  labelVisualizer,
  labelCourse,
  labelShowTerminal,
  labelHideTerminal,
  labelContactSupport,
  labelReloadTerminal,
  showTerminalActions = true,
  showOutlineAction = false
} = Astro.props
const labelTerminal = labelShowTerminal
---

<div class="lp__content-bar">
  <div class="lp__content-bar-group lp__content-bar-group--left">
    {
      showTerminalActions && (
        <Button
          type="button"
          variant="plain"
          size="sm"
          color="gray"
          class="lp__content-bar-btn lp__content-bar-btn--viz"
          data-cluster-trigger
          data-label-visualizer={labelVisualizer}
          data-label-course={labelCourse}
          aria-expanded="false"
          aria-label={labelVisualizer}
        >
          <Telescope size={18} />
        </Button>
      )
    }
    <span class="lp__term-toggle-wrap">
      <Button
        type="button"
        variant="plain"
        size="sm"
        color="gray"
        class="lp__content-bar-btn lp__content-bar-btn--term-toggle"
        data-lesson-term-toggle
        data-label-show-terminal={labelShowTerminal}
        data-label-hide-terminal={labelHideTerminal}
        aria-label={labelTerminal}
        title={labelTerminal}
      >
        <Terminal size={18} />
      </Button>
    </span>
    {
      showTerminalActions && (
        <Button
          type="button"
          variant="plain"
          size="sm"
          color="gray"
          class="lp__content-bar-btn lp__content-bar-btn--reload"
          data-lesson-terminal-reload
          aria-label={labelReloadTerminal}
          title={labelReloadTerminal}
        >
          <RefreshCw size={18} />
        </Button>
      )
    }
  </div>
  <div class="lp__content-bar-group lp__content-bar-group--right">
    <Button
      type="button"
      variant="plain"
      size="sm"
      color="gray"
      class="lp__content-bar-btn lp__content-bar-btn--contact"
      data-contact-support-trigger
      data-lesson-tour="feedback"
      aria-label={labelContactSupport}
      title={labelContactSupport}
    >
      <MessageCircle size={18} />
    </Button>
    {
      showOutlineAction && (
        <span class="lp__outline-wrap">
          <Button
            type="button"
            variant="plain"
            size="sm"
            color="gray"
            class="lp__content-bar-btn lp__content-bar-btn--outline"
            data-lesson-outline-toggle
            data-lesson-tour="outline"
            aria-label={labelCourse}
            title={labelCourse}
            aria-controls="lesson-sidebar"
            aria-expanded="false"
          >
            <ListTree size={18} />
          </Button>
        </span>
      )
    }
  </div>
</div>

<script>
  import { CLUSTER_PANEL_OPEN_SESSION_KEY } from '../../lib/lesson/clusterPanelSessionKey'

  function setVizState(btn: Element, expanded: boolean) {
    const labelV = btn.getAttribute('data-label-visualizer')
    const labelC = btn.getAttribute('data-label-course')
    const label = expanded ? labelC : labelV
    btn.setAttribute('aria-expanded', String(expanded))
    btn.setAttribute('aria-label', label ?? '')
    if (btn instanceof HTMLElement) {
      btn.setAttribute('title', label ?? '')
    }
  }

  function setTerminalToggleState(btn: Element) {
    if (!(btn instanceof HTMLElement)) {
      return
    }
    const root = document.querySelector('.lesson-layout-root')
    const isOpen = root?.getAttribute('data-terminal-open') === 'true'
    const showLabel = btn.getAttribute('data-label-show-terminal') ?? ''
    const hideLabel = btn.getAttribute('data-label-hide-terminal') ?? ''
    const label = isOpen ? hideLabel : showLabel
    btn.setAttribute('aria-label', label)
    btn.setAttribute('title', label)
  }

  document.addEventListener('cluster-panel-open', () => {
    const btn = document.querySelector('[data-cluster-trigger]')
    if (btn) {
      setVizState(btn, true)
    }
  })

  document.addEventListener('cluster-panel-close', () => {
    const btn = document.querySelector('[data-cluster-trigger]')
    if (btn) {
      setVizState(btn, false)
    }
  })

  document.addEventListener('lesson-terminal-state-changed', () => {
    document.querySelectorAll('[data-lesson-term-toggle]').forEach((btn) => {
      setTerminalToggleState(btn)
    })
  })

  document.addEventListener('click', (e) => {
    const btn = (e.target as Element).closest('[data-cluster-trigger]')
    if (btn) {
      e.preventDefault()
      const expanded = btn.getAttribute('aria-expanded') === 'true'
      setVizState(btn, !expanded)
      document.dispatchEvent(
        new CustomEvent(expanded ? 'cluster-panel-close' : 'cluster-panel-open')
      )
      return
    }
    const termBtn = (e.target as Element).closest('[data-lesson-term-toggle]')
    if (termBtn) {
      e.preventDefault()
      document.dispatchEvent(new CustomEvent('lesson-terminal-toggle'))
      return
    }
    const outlineBtn = (e.target as Element).closest(
      '[data-lesson-outline-toggle]'
    )
    if (outlineBtn) {
      e.preventDefault()
      document.dispatchEvent(new CustomEvent('lesson-outline-toggle'))
      return
    }
    const contactBtn = (e.target as Element).closest(
      '[data-contact-support-trigger]'
    )
    if (contactBtn) {
      e.preventDefault()
      document.dispatchEvent(new CustomEvent('contact-support-open'))
      return
    }
    const reloadBtn = (e.target as Element).closest(
      '[data-lesson-terminal-reload]'
    )
    if (reloadBtn) {
      e.preventDefault()
      document.dispatchEvent(new CustomEvent('lesson-terminal-reload'))
    }
  })

  document.addEventListener('astro:page-load', () => {
    const btn = document.querySelector('[data-cluster-trigger]')
    if (btn) {
      const panelOpen =
        sessionStorage.getItem(CLUSTER_PANEL_OPEN_SESSION_KEY) === 'true'
      setVizState(btn, panelOpen)
    }
    document.querySelectorAll('[data-lesson-term-toggle]').forEach((termBtn) => {
      setTerminalToggleState(termBtn)
    })
  })

  document.querySelectorAll('[data-lesson-term-toggle]').forEach((termBtn) => {
    setTerminalToggleState(termBtn)
  })
</script>

<style>
  .lp__content-bar {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    width: 100%;
    box-sizing: border-box;
    padding: var(--spacing-2) var(--spacing-3);
    border-top: 1px solid var(--color-gray-6);
    background: var(--color-gray-1);
  }

  .lp__content-bar-group {
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
    min-width: 0;
  }

  .lp__content-bar-group--right {
    margin-left: auto;
    flex-shrink: 0;
  }

  .lp__content-bar-btn--viz,
  .lp__content-bar-btn--term-toggle,
  .lp__content-bar-btn--outline,
  .lp__content-bar-btn--contact,
  .lp__content-bar-btn--reload {
    background: transparent;
    border: none;
  }

  :global([data-cluster-trigger][aria-expanded='true']) {
    background-color: var(--color-gray-4) !important;
    color: var(--color-gray-12) !important;
  }

  /* Wrapper masqué en grand écran (le bouton Button ne reçoit pas le scope Astro). */
  .lp__term-toggle-wrap {
    display: none;
  }

  .lp__outline-wrap {
    display: none;
  }

  @media (max-width: 1024px) {
    .lp__content-bar {
      padding-left: var(--spacing-2);
      padding-right: max(var(--spacing-2), env(safe-area-inset-right));
    }
    .lp__term-toggle-wrap {
      display: inline-flex;
    }
    .lp__outline-wrap {
      display: inline-flex;
    }
  }
</style>
