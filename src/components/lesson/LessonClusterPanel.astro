---
import ScrollArea from '../ui/ScrollArea.astro'
---

<div
  class="lp__cluster-panel"
  data-cluster-panel
  aria-hidden="true"
>
  <ScrollArea>
    <div class="lp__cluster-panel-bd" data-cluster-panel-content></div>
  </ScrollArea>
</div>

<script>
  import { mountClusterViewer } from '../cluster-viewer-mount'
  import { CLUSTER_PANEL_OPEN_SESSION_KEY } from '../../lib/lesson/clusterPanelSessionKey'

  let cleanup: (() => void) | null = null

  function setup() {
    const panelEl = document.querySelector<HTMLElement>('[data-cluster-panel]')
    const content = document.querySelector('[data-cluster-panel-content]')
    if (panelEl == null || content == null) {
      return
    }
    const panel = panelEl as HTMLElement

    const savedState = sessionStorage.getItem(CLUSTER_PANEL_OPEN_SESSION_KEY)

    function openPanel() {
      panel.classList.add('lp__cluster-panel--open')
      panel.setAttribute('aria-hidden', 'false')
      sessionStorage.setItem(CLUSTER_PANEL_OPEN_SESSION_KEY, 'true')
    }

    function closePanel() {
      panel.classList.remove('lp__cluster-panel--open')
      panel.setAttribute('aria-hidden', 'true')
      sessionStorage.setItem(CLUSTER_PANEL_OPEN_SESSION_KEY, 'false')
    }

    document.addEventListener('cluster-panel-open', openPanel)
    document.addEventListener('cluster-panel-close', closePanel)

    // Restore the panel state instantly (no animation) on lesson navigation
    if (savedState === 'true') {
      panel.style.transition = 'none'
      openPanel()
      requestAnimationFrame(() => {
        panel.style.transition = ''
      })
    }

    document.addEventListener('cluster-env-ready', ((e: CustomEvent) => {
      if (cleanup) {
        cleanup()
      }
      const env = e.detail?.env
      if (env && content instanceof HTMLElement) {
        cleanup = mountClusterViewer(content, { env })
      }
    }) as EventListener)
  }

  setup()
  document.addEventListener('astro:page-load', setup)

  document.addEventListener('astro:before-swap', () => {
    if (cleanup) {
      cleanup()
      cleanup = null
    }
  })
</script>

<style>
  .lp__cluster-panel {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    height: 0;
    overflow: hidden;
    background: transparent;
    border-top: 1px solid transparent;
    border-bottom: 1px solid transparent;
    transition:
      height 0.2s ease,
      border-color 0.15s ease;
  }

  .lp__cluster-panel.lp__cluster-panel--open {
    height: 280px;
    border-top-color: var(--color-gray-6);
    border-bottom-color: var(--color-gray-6);
  }

  .lp__cluster-panel-bd {
    padding: var(--spacing-4);
  }
</style>
