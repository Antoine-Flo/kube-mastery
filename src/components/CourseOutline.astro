---
import { ChevronDown, Circle, CircleCheck, CirclePlay } from '@lucide/astro'
import type {
  CourseOverview,
  OverviewModule,
  OverviewLesson
} from '../content/overview/facade'

interface Props {
  overview: CourseOverview
  currentLessonId: string
  lessonBaseUrl: string
  completedLessonIds?: Set<string>
}

const {
  overview,
  currentLessonId,
  lessonBaseUrl,
  completedLessonIds = new Set<string>()
} = Astro.props

const allModules = overview.content.sections.flatMap((s) => s.modules)
const currentModuleIndex = allModules.findIndex((m) =>
  m.lessons.some((l) => l.id === currentLessonId)
)
let moduleFlatIndex = 0
---

<div class="course-outline">
  <h2 class="course-outline__title">{overview.title}</h2>
  <div class="course-outline__module-list">
    {
      overview.content.sections.flatMap((section) =>
        section.modules.map((module: OverviewModule) => {
          const isCurrentModule = moduleFlatIndex === currentModuleIndex
          moduleFlatIndex += 1
          return (
            <details
              class:list={{
                'course-outline__module': true,
                'course-outline__module--locked': module.isLocked
              }}
              open={!module.isLocked && isCurrentModule}
            >
              <summary
                class="course-outline__module-summary"
                aria-disabled={module.isLocked ? 'true' : 'false'}
                tabindex={module.isLocked ? -1 : undefined}
              >
                <span class="course-outline__module-title">{module.title}</span>
                <span class="course-outline__module-chevron" aria-hidden="true">
                  <ChevronDown size={16} aria-hidden="true" />
                </span>
              </summary>
              <div class="course-outline__module-lessons">
                {module.lessons.map((lesson: OverviewLesson) =>
                  module.isLocked ? (
                    <span class="course-outline__lesson course-outline__lesson--locked">
                      <span
                        class="course-outline__lesson-icon course-outline__lesson-icon--pending"
                        aria-hidden="true"
                      >
                        <Circle size={16} />
                      </span>
                      <span class="course-outline__lesson-title">
                        {lesson.title}
                      </span>
                    </span>
                  ) : (
                    <a
                      href={`${lessonBaseUrl}/${lesson.id}`}
                      class:list={{
                        'course-outline__lesson': true,
                        'progress-completed': completedLessonIds.has(lesson.id),
                        'progress-current': lesson.id === currentLessonId
                      }}
                    >
                      <span
                        class="course-outline__lesson-icon course-outline__lesson-icon--pending"
                        aria-hidden="true"
                      >
                        <Circle size={16} />
                      </span>
                      <span
                        class="course-outline__lesson-icon course-outline__lesson-icon--current"
                        aria-hidden="true"
                      >
                        <CirclePlay size={16} />
                      </span>
                      <span
                        class="course-outline__lesson-icon course-outline__lesson-icon--completed"
                        aria-hidden="true"
                      >
                        <CircleCheck size={16} />
                      </span>
                      <span class="course-outline__lesson-title">
                        {lesson.title}
                      </span>
                    </a>
                  )
                )}
              </div>
            </details>
          )
        })
      )
    }
  </div>
</div>

<style>
  .course-outline {
    background-color: var(--color-gray-1);
    padding-top: var(--spacing-4);
    padding-right: var(--spacing-1);
    padding-bottom: var(--spacing-2);
    padding-left: var(--spacing-2);
  }

  .course-outline__title {
    font-size: var(--text-xl);
    font-weight: var(--font-weight-semibold);
    color: var(--color-gray-12);
    padding-bottom: var(--spacing-2);
    border-bottom: 1px solid var(--color-gray-6);
  }

  .course-outline__module-list {
    width: 100%;
    --course-outline-module-padding: var(--spacing-3);
  }

  .course-outline__module--locked {
    opacity: 0.6;
  }

  .course-outline__module {
    interpolate-size: allow-keywords;
  }

  .course-outline__module::details-content {
    height: 0;
    overflow: clip;
    transition:
      height var(--duration-slow) ease-out,
      content-visibility var(--duration-slow) allow-discrete;
  }

  .course-outline__module[open]::details-content {
    height: auto;
  }

  .course-outline__module-summary {
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
    padding: var(--course-outline-module-padding) 0;
    cursor: pointer;
    list-style: none;
    font-weight: var(--font-weight-semibold);
    color: var(--color-gray-12);
    background: none;
    border: none;
    width: 100%;
    text-align: left;
    font-size: var(--text-sm);
    font-family: inherit;
  }

  .course-outline__module--locked .course-outline__module-summary {
    cursor: not-allowed;
    pointer-events: none;
  }

  .course-outline__module--locked .course-outline__module-chevron {
    display: none;
  }

  .course-outline__module-summary::-webkit-details-marker,
  .course-outline__module-summary::marker {
    display: none;
  }

  .course-outline__module-summary:focus-visible {
    outline: 2px solid var(--color-cyan-9);
    outline-offset: 2px;
  }

  .course-outline__module-title {
    flex: 1;
  }

  .course-outline__module-chevron {
    flex-shrink: 0;
    color: var(--color-gray-9);
    transition: transform var(--duration-slow) ease-out;
  }

  .course-outline__module[open] .course-outline__module-chevron {
    transform: rotate(180deg);
  }

  .course-outline__module-lessons {
    padding: 0;
    padding-bottom: var(--course-outline-module-padding);
  }

  .course-outline__lesson {
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
    width: 100%;
    padding: var(--spacing-2);
    background: none;
    border: none;
    text-align: left;
    cursor: pointer;
    color: var(--color-gray-11);
    text-decoration: none;
    transition:
      background-color var(--duration-normal) ease-out,
      color var(--duration-normal) ease-out,
      font-weight var(--duration-normal) ease-out;
    font-family: inherit;
    font-size: inherit;
  }

  a.course-outline__lesson {
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }

  .course-outline__lesson:hover {
    background-color: var(--color-gray-3);
  }

  a.course-outline__lesson:active {
    background-color: var(--color-gray-2);
  }

  :global([data-theme='dark'])
    a.course-outline__lesson:active:not(.progress-current) {
    background-color: var(--color-gray-4);
  }

  a.course-outline__lesson.progress-current:active {
    background-color: var(--color-cyan-2);
  }

  :global([data-theme='dark'])
    a.course-outline__lesson.progress-current:active {
    background-color: var(--color-cyan-5);
  }

  .course-outline__lesson--locked {
    cursor: not-allowed;
    color: var(--color-gray-9);
  }

  .course-outline__lesson--locked:hover {
    background-color: transparent;
  }

  .course-outline__lesson-icon {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-gray-9);
    transition: color var(--duration-normal) ease-out;
  }
  .course-outline__lesson .course-outline__lesson-icon--current,
  .course-outline__lesson .course-outline__lesson-icon--completed {
    display: none;
  }

  .course-outline__lesson.progress-completed {
    opacity: 0.85;
  }
  .course-outline__lesson.progress-completed
    .course-outline__lesson-icon--pending,
  .course-outline__lesson.progress-completed
    .course-outline__lesson-icon--current {
    display: none;
  }
  .course-outline__lesson.progress-completed
    .course-outline__lesson-icon--completed {
    display: inline-flex;
    color: var(--color-green-9);
  }

  .course-outline__lesson.progress-current
    .course-outline__lesson-icon--pending,
  .course-outline__lesson.progress-current
    .course-outline__lesson-icon--completed {
    display: none;
  }
  .course-outline__lesson.progress-current
    .course-outline__lesson-icon--current {
    display: inline-flex;
    color: var(--color-cyan-11);
  }
  .course-outline__lesson.progress-current {
    background-color: var(--color-cyan-3);
    color: var(--color-gray-12);
    font-weight: var(--font-weight-semibold);
  }
  .course-outline__lesson.progress-current:hover {
    background-color: var(--color-cyan-4);
  }

  .course-outline__lesson-title {
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: var(--text-xs);
  }

  @media (prefers-reduced-motion: reduce) {
    .course-outline__module::details-content {
      transition: none;
    }

    .course-outline__module-chevron {
      transition: none;
    }
  }
</style>
