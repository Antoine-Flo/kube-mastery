---
import { SEO } from 'astro-seo'
import { ClientRouter } from 'astro:transitions'
import Footer from '../components/Footer.astro'
import GlobalStyles from '../components/GlobalStyles.astro'
import Navbar from '../components/Navbar.astro'
import PostHog from '../components/posthog.astro'
import Toaster from '../components/ui/Toaster.astro'
import { getLangFromUrl } from '../i18n/utils'
import { getLayoutAuthContext } from '../lib/auth/server'

interface LayoutSeoProps {
  title?: string
  description?: string
  canonical?: string
  noindex?: boolean
  nofollow?: boolean
  openGraphImage?: string
  openGraphType?: string
  twitterImage?: string
  twitterCard?: 'summary' | 'summary_large_image' | 'app' | 'player'
}

interface Props {
  bodyClass?: string
  showFooter?: boolean
  title?: string
  description?: string
  robots?: string
  seo?: LayoutSeoProps
}

const lang = getLangFromUrl(Astro.url)
const bodyClass = Astro.props.bodyClass
const showFooter = Astro.props.showFooter ?? true
const seoProps = Astro.props.seo ?? {}
const pageTitle = seoProps.title ?? Astro.props.title ?? 'KubeMastery'
const pageDescription = seoProps.description ?? Astro.props.description ?? null
const canonicalUrl = seoProps.canonical ?? Astro.url.href
const robots = Astro.props.robots ?? null
const openGraphType = seoProps.openGraphType ?? 'article'
const defaultPreviewImage = '/og/default.png'
const rawOpenGraphImage = seoProps.openGraphImage ?? defaultPreviewImage
const rawTwitterImage = seoProps.twitterImage ?? rawOpenGraphImage
const absoluteOpenGraphImage = new URL(rawOpenGraphImage, canonicalUrl).href
const absoluteTwitterImage = new URL(rawTwitterImage, canonicalUrl).href
const navbarVariant = bodyClass?.includes('navbar-app') ? 'app' : 'marketing'

const auth = await getLayoutAuthContext(
  Astro.locals,
  Astro.request,
  Astro.cookies
)
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script
      src="https://analytics.ahrefs.com/analytics.js"
      data-key="ShetoWtgnxoSbWIe61B6Fg"
      async></script>
    <script is:inline>
      try {
        const themeKey = 'kube-simulator-theme'
        const storedTheme = localStorage.getItem(themeKey)
        const theme =
          storedTheme === 'light' || storedTheme === 'dark'
            ? storedTheme
            : 'dark'
        document.documentElement.setAttribute('data-theme', theme)
      } catch {
        document.documentElement.setAttribute('data-theme', 'dark')
      }
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <SEO
      title={pageTitle}
      description={pageDescription ?? undefined}
      canonical={canonicalUrl}
      noindex={seoProps.noindex}
      nofollow={seoProps.nofollow}
      openGraph={{
        basic: {
          title: pageTitle,
          type: openGraphType,
          image: absoluteOpenGraphImage,
          url: canonicalUrl
        },
        optional: {
          description: pageDescription ?? undefined,
          locale: lang === 'fr' ? 'fr_FR' : 'en_US',
          localeAlternate: lang === 'fr' ? ['en_US'] : ['fr_FR'],
          siteName: 'KubeMastery'
        },
        image: {
          alt: pageTitle
        }
      }}
      twitter={{
        card: seoProps.twitterCard ?? 'summary_large_image',
        title: pageTitle,
        description: pageDescription ?? undefined,
        image: absoluteTwitterImage,
        imageAlt: pageTitle
      }}
    />
    {robots && <meta name="robots" content={robots} />}
    <PostHog />
    <ClientRouter />
  </head>
  <body class={bodyClass}>
    <GlobalStyles />
    <Navbar
      isLoggedIn={auth.isLoggedIn}
      user={auth.user}
      hasPaidSubscription={auth.hasPaidSubscription}
      variant={navbarVariant}
    />
    <main class="layout-main">
      <slot />
    </main>
    {showFooter && <Footer />}
    <Toaster />
  </body>
</html>

<style is:global>
  html,
  body {
    min-height: 100vh;
  }
  body {
    display: flex;
    flex-direction: column;
  }
  .layout-main {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }

  body.lp-fill {
    height: 100vh;
    min-height: 100svh;
    height: 100svh;
    overflow: hidden;
  }

  body.lp-fill .layout-main {
    overflow: auto;
  }
</style>
