---
interface Props {
  bodyClass?: string
  showFooter?: boolean
  title?: string
  description?: string
  robots?: string
}

import { ClientRouter } from 'astro:transitions'
import { getLangFromUrl } from '../i18n/utils'
import Footer from '../components/Footer.astro'
import GlobalStyles from '../components/GlobalStyles.astro'
import Navbar from '../components/Navbar.astro'
import PostHog from '../components/posthog.astro'
import Toaster from '../components/ui/Toaster.astro'
import { getLayoutAuthContext } from '../lib/auth/server'
import { isOpenLearningEnabled } from '../lib/env'

const lang = getLangFromUrl(Astro.url)
const bodyClass = Astro.props.bodyClass
const showFooter = Astro.props.showFooter ?? true
const pageTitle = Astro.props.title ?? 'KubeMastery'
const pageDescription = Astro.props.description ?? null
const robots = Astro.props.robots ?? null
const navbarVariant = bodyClass?.includes('navbar-app') ? 'app' : 'marketing'

const auth = await getLayoutAuthContext(
  Astro.locals,
  Astro.request,
  Astro.cookies
)
const openLearning = isOpenLearningEnabled(Astro.locals)
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      try {
        const themeKey = 'kube-simulator-theme'
        const storedTheme = localStorage.getItem(themeKey)
        const theme =
          storedTheme === 'light' || storedTheme === 'dark'
            ? storedTheme
            : 'dark'
        document.documentElement.setAttribute('data-theme', theme)
      } catch {
        document.documentElement.setAttribute('data-theme', 'dark')
      }
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    {pageDescription && <meta name="description" content={pageDescription} />}
    {robots && <meta name="robots" content={robots} />}
    <PostHog />
    <ClientRouter />
  </head>
  <body class={bodyClass}>
    <GlobalStyles />
    <Navbar
      isLoggedIn={auth.isLoggedIn}
      user={auth.user}
      hasPaidSubscription={auth.hasPaidSubscription}
      openLearning={openLearning}
      variant={navbarVariant}
    />
    <main class="layout-main">
      <slot />
    </main>
    {
      showFooter && (
        <Footer isLoggedIn={auth.isLoggedIn} openLearning={openLearning} />
      )
    }
    <Toaster />
  </body>
</html>

<style is:global>
  html,
  body {
    min-height: 100vh;
  }
  body {
    display: flex;
    flex-direction: column;
  }
  .layout-main {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }

  body.lp-fill {
    height: 100vh;
    overflow: hidden;
  }

  body.lp-fill .layout-main {
    overflow: auto;
  }
</style>
