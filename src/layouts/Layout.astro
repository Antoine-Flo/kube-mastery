---
interface Props {
  bodyClass?: string
  showFooter?: boolean
}

import { ClientRouter } from 'astro:transitions'
import { getLangFromUrl } from '../i18n/utils'
import Footer from '../components/Footer.astro'
import GlobalStyles from '../components/GlobalStyles.astro'
import Navbar from '../components/Navbar.astro'
import PostHog from '../components/posthog.astro'
import Toaster from '../components/ui/Toaster.astro'
import { getLayoutAuthContext } from '../lib/auth/server'

const lang = getLangFromUrl(Astro.url)
const bodyClass = Astro.props.bodyClass
const showFooter = Astro.props.showFooter ?? true
const navbarVariant = bodyClass?.includes('navbar-app') ? 'app' : 'marketing'

const auth = await getLayoutAuthContext(
  Astro.locals,
  Astro.request,
  Astro.cookies
)
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <title>KubeMastery</title>
    <PostHog />
    <ClientRouter />
  </head>
  <body class={bodyClass}>
    <GlobalStyles />
    <Navbar
      isLoggedIn={auth.isLoggedIn}
      user={auth.user}
      hasPaidSubscription={auth.hasPaidSubscription}
      variant={navbarVariant}
    />
    <main class="layout-main">
      <slot />
    </main>
    {showFooter && <Footer />}
    <Toaster />
  </body>
</html>

<style is:global>
  html,
  body {
    min-height: 100vh;
  }
  body {
    display: flex;
    flex-direction: column;
  }
  .layout-main {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }

  body.lp-fill {
    height: 100vh;
    overflow: hidden;
  }

  body.lp-fill .layout-main {
    overflow: auto;
  }
</style>
