# Environment: "development" | "staging" | "production"
ENVIRONMENT=development

# Supabase - Auth and progress storage
# https://supabase.com/dashboard/project/_/settings/api
DATABASE_URL=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_DEFAULT_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Paddle - Billing (optional for local dev)
# https://developer.paddle.com
PADDLE_API_KEY=
PADDLE_CLIENT_TOKEN_STAGING=
PADDLE_WEBHOOK_SECRET=

# Cloudflare - Deployment only (not needed for local dev)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_PAGES_PROJECT=

# Dagger Cloud - CI pipeline traces (optional)
DAGGER_CLOUD_TOKEN=

# PostHog - Analytics (optional for local dev)
POSTHOG_PROJECT_TOKEN=

# Sweego - Transactional email (optional for local dev)
SWEEGO_API_KEY=

# IndexNow - Search engine indexing (optional)
INDEXNOW_KEY=

# Feature flags
IS_LAUNCHED=false
EARLY_ACCESS=true
OPEN_LEARNING=false
